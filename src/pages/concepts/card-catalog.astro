---
/* ============================================================
   THE CARD CATALOG — concept page
   --------------------------------------------------------------
   The homepage IS a vintage library card-catalog cabinet, dead
   center on the cream canvas. Each drawer = one section of the
   site. Click a drawer's brass label and an actual catalog INDEX
   CARD slides out from inside the cabinet. The card holds the
   section's content — typewritten copy on lined card stock,
   classified with a Dewey-style number, stamped, dated, hand-
   signed by Bill & Lisa.
   --------------------------------------------------------------
   No JS framework. Pure CSS animation + tiny inline click handler.
   ============================================================ */

import Layout from "../../layouts/Layout.astro";
import Drawer from "../../components/concepts/card-catalog/Drawer.astro";

const BOOTH = {
  street: "3565 E. Flamingo Road",
  city: "Las Vegas, Nevada 89121",
  phone: "(516) 446-2693",
  phoneHref: "tel:+15164462693",
  hours: "Open daily, 10 'til 6",
  bill: "Bill works the booth Weds & Sun",
  mapHref:
    "https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121",
  mapEmbed:
    "https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed",
};

// The Collection — six categories, with the photo on file
const CATEGORIES = [
  { name: "Toys & Trucks",          photo: "/photos/case-buddy-l-trucks.jpg" },
  { name: "Art Glass & Bottles",    photo: "/photos/shelves-bottles.jpg" },
  { name: "Advertising & Signage",  photo: "/photos/signage.jpg" },
  { name: "Jewelry & Adornment",    photo: "/photos/jewelry.jpg" },
  { name: "Americana & Ephemera",   photo: "/photos/americana.jpg" },
  { name: "Curiosities",            photo: "/photos/curiosities.jpg" },
];

// Tonight's Lineup — real items off Bill's handwritten tags
const LINEUP = [
  {
    no: "01",
    name: "1934 Ludwig Scherk Renaissance Perfume Bottle",
    era: "German, 1934 — w/ Marie Antoinette miniature",
    note: "Renaissance-style ground crystal. The miniature inside is original and signed. One of three Scherks left in the case.",
    price: "$225",
    photo: "/photos/tag-perfume-bottle.jpg",
  },
  {
    no: "02",
    name: "1930s Hobby Kiddie Diecast Race Car",
    era: "American, 1930–40s — all original paint",
    note: "Numbered hood, rubber tires intact, no repaint. Hard to find one this clean.",
    price: "$65",
    photo: "/photos/tag-race-car.jpg",
  },
  {
    no: "03",
    name: "1930s GE Cast-Iron Oscillating Fan",
    era: "American, 1930s — original brass blade",
    note: "Original brass blade. Still oscillates. The kind of piece Bill takes off the shelf so you can hear it run.",
    price: "ask Bill",
    photo: "/photos/fan-perfumes.jpg",
  },
  {
    no: "04",
    name: "Awaiting Bill's pick",
    era: "— to be filed —",
    note: "Bill's working on it. Drop in Wednesday and ask him what's about to go on this card.",
    price: "—",
    photo: "/photos/case-toys.jpg",
  },
];
---

<Layout
  title="TreasureTroveFinds · The Card Catalog · Booth #18, Las Vegas"
  description="Bill and Lisa's curated antique booth at Paradise Mall, Las Vegas. Pull a drawer."
>
  <!-- ============================================================
       PAGE — cream canvas, the cabinet floats in the middle
       ============================================================ -->
  <main class="cc">

    <!-- Masthead (typographic, no logo, no nav bar) -->
    <header class="cc__mast">
      <p class="cc__pre">— A Reading-Room Index of —</p>
      <h1 class="cc__wordmark">
        Treasure&nbsp;Trove<span class="cc__amp">·</span>Finds
      </h1>
      <p class="cc__tag">
        Paradise Mall · Booth&nbsp;#18 · Las Vegas
      </p>
      <div class="cc__rule" aria-hidden="true">
        <span>◆</span>
      </div>
      <p class="cc__instruct">
        Pull a drawer. The card slides out.
      </p>
    </header>

    <!-- ============================================================
         THE CABINET — the centerpiece of the page
         ============================================================ -->
    <section class="cabinet" aria-label="Card catalog cabinet — the index of this site">
      <!-- Brass nameplate at the top of the cabinet -->
      <div class="cabinet__crown">
        <span class="cabinet__crown-line">TREASURE TROVE FINDS</span>
        <span class="cabinet__crown-sub">— index · est. 1973 —</span>
      </div>

      <!-- Cabinet body — wood frame holding the grid of drawers -->
      <div class="cabinet__body">

        <!-- Drawer grid: 3 columns x N rows -->
        <div class="cabinet__grid">

          <!-- 1. FIND THE JOINT -->
          <Drawer
            drawerId="joint"
            dewey="917.93"
            label="Find the Joint"
            subLabel="visit · phone · map"
            cardTitle="Paradise Mall · Booth #18"
            cardEyebrow="Where to find us"
            stamp="OPEN"
            col={1}
          >
            <p>
              <strong>Address.</strong><br/>
              3565 E. Flamingo Road<br/>
              Las Vegas, Nevada 89121
            </p>
            <p>
              <strong>Hours.</strong><br/>
              Open daily, 10 'til 6.<br/>
              Bill works the booth Wednesdays &amp; Sundays.
            </p>
            <p>
              <strong>Ring Bill up.</strong><br/>
              <a href={BOOTH.phoneHref}>(516) 446-2693</a><br/>
              He likes a phone call. Call ahead and he'll set the piece aside.
            </p>

            <div class="cc-map" aria-hidden="false">
              <iframe
                title="Map to Paradise Mall, Booth 18, Las Vegas"
                src={BOOTH.mapEmbed}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>

            <div class="cc-ctas">
              <a class="ttf-btn ttf-btn-primary" href={BOOTH.mapHref} target="_blank" rel="noopener">
                Get Directions
              </a>
              <a class="ttf-btn ttf-btn-secondary" href={BOOTH.phoneHref}>
                Call Bill
              </a>
            </div>
          </Drawer>

          <!-- 2. HOW WE GOT HERE -->
          <Drawer
            drawerId="story"
            dewey="921.B"
            label="How We Got Here"
            subLabel="bill &amp; lisa, on the record"
            cardTitle="Fifty Years On the Hunt"
            cardEyebrow="The Personal File"
            stamp="VERIFIED"
            col={2}
          >
            <p>
              Bill started with baseball cards. Eight years old, working the backs
              of them — the stats, the years, the batting averages — chasing
              the history hiding inside the numbers.
            </p>
            <p>
              The cards led to bottles. Bottles led to signs. Signs led to toys.
              Toys led to anything with a story he hadn't heard yet. Not just
              antique — <em>nostalgic.</em> Things that meant something to
              somebody, once.
            </p>
            <p>
              Then Lisa came along and made it a life. Two collectors, one booth,
              fifty years of homework. In the booth Bill is animated — hands
              moving, leaning on the case, telling you what year the piece is
              from before you've finished asking.
            </p>
            <p>
              This is not your sixth-grade Social Studies teacher's lecture.
              This is the guy who's been at it since '73 and still gets a kick
              out of every new piece.
            </p>
          </Drawer>

          <!-- 3. THE COLLECTION -->
          <Drawer
            drawerId="collection"
            dewey="745.1"
            label="The Collection"
            subLabel="six departments"
            cardTitle="What's On the Shelves"
            cardEyebrow="Departments of the Booth"
            stamp="INDEXED"
            col={3}
          >
            <p>
              Six departments. About a thousand pieces in rotation. Everything
              dated and recorded — Bill writes the homework on the tag.
            </p>
            <ul class="cc-cats">
              {CATEGORIES.map((c, i) => (
                <li class="cc-cats__item">
                  <img src={c.photo} alt={`Section of the booth — ${c.name}`} loading="lazy" />
                  <span class="cc-cats__no">No. {String(i + 1).padStart(2, "0")}</span>
                  <span class="cc-cats__name">{c.name}</span>
                </li>
              ))}
            </ul>
          </Drawer>

          <!-- 4. TONIGHT'S LINEUP -->
          <Drawer
            drawerId="lineup"
            dewey="745.4"
            label="Tonight's Lineup"
            subLabel="four pieces, picked by bill"
            cardTitle="Tonight's Lineup"
            cardEyebrow="Featured Plates"
            stamp="FEATURED"
            col={1}
          >
            <p>
              Four pieces off the case this week. Bill picked them. Prices are
              firm unless you're a regular, in which case ask anyway.
            </p>
            <ol class="cc-lineup">
              {LINEUP.map((item) => (
                <li class="cc-lineup__plate">
                  <div class="cc-lineup__photo">
                    <img src={item.photo} alt={item.name} loading="lazy" />
                  </div>
                  <div class="cc-lineup__copy">
                    <span class="cc-lineup__no">Plate No. {item.no}</span>
                    <span class="cc-lineup__name">{item.name}</span>
                    <span class="cc-lineup__era">{item.era}</span>
                    <span class="cc-lineup__note">{item.note}</span>
                    <span class="cc-lineup__price">{item.price}</span>
                  </div>
                </li>
              ))}
            </ol>
          </Drawer>

          <!-- 5. EVERY PIECE HAS A RECORD — the one emerald-felt card -->
          <Drawer
            drawerId="record"
            dewey="000.0"
            label="The House Rule"
            subLabel="every piece has a record"
            cardTitle="Every Piece Has a Record"
            cardEyebrow="The Brand Promise"
            stamp="ON FILE"
            col={2}
          >
            <div class="cc-record">
              <img class="cc-record__tag" src="/photos/tag-detail.jpg" alt="Close-up of one of Bill's handwritten paper tags on twine" />
              <div class="cc-record__copy">
                <p>
                  Other vendors put a price on the tag. Bill and Lisa put the
                  <em> record</em> — the maker, the year, the homework — in
                  their own hand. Fifty years of it.
                </p>
                <p>
                  If you bought the piece from us, you got the story with it.
                  That's the house rule.
                </p>
              </div>
            </div>
          </Drawer>

          <!-- 6. ETSY'S COMING -->
          <Drawer
            drawerId="etsy"
            dewey="380.1"
            label="Etsy's Coming"
            subLabel="get on the list"
            cardTitle="Get the Word First"
            cardEyebrow="The Waiting List"
            stamp="PENDING"
            col={3}
          >
            <p>
              We're putting a few of the better pieces on Etsy soon. If you'd
              like a head start — leave us an address.
            </p>
            <p>
              We don't have time for spam. One note when listings open, another
              if a piece you'd love comes in. That's it.
            </p>
            <form class="cc-form" onsubmit="event.preventDefault(); this.querySelector('.cc-form__msg').hidden = false;">
              <label class="cc-form__row">
                <span class="cc-form__lab">Your name</span>
                <input type="text" name="name" autocomplete="name" />
              </label>
              <label class="cc-form__row">
                <span class="cc-form__lab">Email</span>
                <input type="email" name="email" autocomplete="email" required />
              </label>
              <button class="ttf-btn ttf-btn-primary" type="submit">Put me on the list</button>
              <p class="cc-form__msg" hidden>
                Filed. Bill &amp; Lisa will be in touch.
              </p>
            </form>
            <p class="cc-form__sig">— Bill &amp; Lisa</p>
          </Drawer>
        </div>
      </div>

      <!-- Cabinet base / kick -->
      <div class="cabinet__base" aria-hidden="true"></div>
    </section>

    <!-- ============================================================
         FOOTER
         ============================================================ -->
    <footer class="cc__foot">
      <div class="cc__foot-rule" aria-hidden="true"></div>
      <p class="cc__foot-line">
        Est. 2022 · Collecting since 1973 · Pieces back to 1850.<br/>
        <em>Bill knows everybody. Ask no questions.</em>
      </p>
      <p class="cc__foot-addr">
        TREASURE TROVE FINDS · PARADISE MALL · BOOTH #18 · LAS VEGAS, NEVADA
      </p>
      <p class="cc__foot-otranto">An Otranto Labs project</p>
    </footer>
  </main>

  <!-- ============================================================
       Click handler — pull a drawer, slide its index card out.
       Only one drawer open at a time (a real cabinet works that way).
       ============================================================ -->
  <script is:inline>
    (function () {
      const drawers = document.querySelectorAll(".cc-drawer");
      const toggles = document.querySelectorAll("[data-toggle]");

      function closeAll() {
        drawers.forEach((d) => {
          d.classList.remove("is-open");
          const face = d.querySelector(".cc-drawer__face");
          const card = d.querySelector(".cc-card");
          if (face) face.setAttribute("aria-expanded", "false");
          if (card) card.setAttribute("hidden", "");
        });
      }

      function openDrawer(drawer) {
        const id = drawer.dataset.drawer;
        const wasOpen = drawer.classList.contains("is-open");
        closeAll();
        if (wasOpen) return; // second click closes
        drawer.classList.add("is-open");
        const face = drawer.querySelector(".cc-drawer__face");
        const card = drawer.querySelector(".cc-card");
        if (face) face.setAttribute("aria-expanded", "true");
        if (card) card.removeAttribute("hidden");
        // Scroll the card into view (it sits below the drawer)
        setTimeout(() => {
          if (card) card.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }, 220);
      }

      toggles.forEach((el) => {
        el.addEventListener("click", function () {
          const drawer = el.closest(".cc-drawer");
          if (drawer) openDrawer(drawer);
        });
      });

      // ESC closes any open drawer
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeAll();
      });
    })();
  </script>
</Layout>

<style>
  /* ============================================================
     PAGE CHROME — cream canvas, narrow column, no white anywhere
     ============================================================ */
  .cc {
    max-width: 1100px;
    margin: 0 auto;
    padding: 56px 22px 80px;
  }

  /* ---- Masthead ---- */
  .cc__mast { text-align: center; margin-bottom: 36px; }
  .cc__pre {
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    font-size: 0.7rem;
    color: var(--color-brass);
    margin: 0 0 10px;
  }
  .cc__wordmark {
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 0.95;
    letter-spacing: 0.01em;
    color: var(--color-ink);
    margin: 0;
    text-transform: uppercase;
  }
  .cc__amp {
    color: var(--color-buddy-red);
    font-family: "Bodoni Moda", Georgia, serif;
    font-style: italic;
    margin: 0 0.18em;
  }
  .cc__tag {
    font-family: "Bodoni Moda", Georgia, serif;
    font-style: italic;
    font-size: 1.05rem;
    color: var(--color-ink);
    margin: 8px 0 12px;
  }
  .cc__rule {
    border-top: 1.4px solid var(--color-brass);
    border-bottom: 1.4px solid var(--color-brass);
    height: 5px;
    max-width: 380px;
    margin: 18px auto 14px;
    position: relative;
  }
  .cc__rule span {
    position: absolute;
    top: -13px; left: 50%; transform: translateX(-50%);
    background: var(--color-cream);
    color: var(--color-brass);
    padding: 0 12px;
    font-size: 14px;
  }
  .cc__instruct {
    font-family: "Permanent Marker", cursive;
    color: var(--color-buddy-red);
    font-size: 1rem;
    margin: 0;
    transform: rotate(-1.4deg);
  }

  /* ============================================================
     THE CABINET
     ============================================================ */
  .cabinet {
    margin: 40px auto 0;
    max-width: 880px;
    position: relative;
  }

  /* Brass nameplate sign across the top */
  .cabinet__crown {
    text-align: center;
    background:
      linear-gradient(180deg, #f0d56a 0%, #C9A227 50%, #8a6e1c 100%);
    border: 1.5px solid #4a3a0e;
    padding: 8px 18px 7px;
    margin: 0 14px;
    position: relative;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.45),
      0 2px 0 rgba(0,0,0,0.45);
  }
  .cabinet__crown::before,
  .cabinet__crown::after {
    content: "";
    position: absolute;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #fff2b0 0%, #8a6e1c 80%);
    top: 50%; transform: translateY(-50%);
  }
  .cabinet__crown::before { left: 8px; }
  .cabinet__crown::after  { right: 8px; }
  .cabinet__crown-line {
    display: block;
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.36em;
    font-size: 1.05rem;
    color: var(--color-ink);
  }
  .cabinet__crown-sub {
    display: block;
    font-family: "Bodoni Moda", Georgia, serif;
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: rgba(26,22,20,0.78);
    margin-top: 2px;
  }

  /* Cabinet wood frame — surrounds the drawer grid */
  .cabinet__body {
    margin-top: -1px;
    padding: 18px;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(0,0,0,0.06) 0 1px,
        transparent 1px 7px
      ),
      linear-gradient(180deg, #4a3220 0%, #3D2A1E 60%, #2a1c12 100%);
    border: 1.5px solid #1a0e07;
    box-shadow:
      inset 0 0 0 2px rgba(201,162,39,0.32),
      inset 0 0 30px rgba(0,0,0,0.45),
      0 6px 0 rgba(0,0,0,0.55),
      0 18px 30px rgba(0,0,0,0.18);
  }

  /* The grid of drawers */
  .cabinet__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 6px;
    background: #1a0e07;
    padding: 4px;
    border: 1px solid #0d0905;
  }

  /* Cabinet base / kick board */
  .cabinet__base {
    height: 22px;
    margin: 0 22px;
    background:
      linear-gradient(180deg, #2a1c12 0%, #1a0e07 100%);
    border: 1.5px solid #0d0905;
    border-top: 0;
    box-shadow:
      inset 0 1px 0 rgba(201,162,39,0.18),
      0 4px 0 rgba(0,0,0,0.4);
  }

  /* On smaller screens, collapse the cabinet to 2 columns then 1 */
  @media (max-width: 720px) {
    .cabinet__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .cabinet__grid { grid-template-columns: 1fr; }
  }

  /* ============================================================
     CARD CONTENT BLOCKS — used inside index cards
     ============================================================ */

  /* Map embed inside the card */
  .cc-map {
    margin: 14px 0 18px;
    border: 1.5px solid #1A1614;
    box-shadow: 4px 4px 0 rgba(26,22,20,0.22);
    background: #1A1614;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    filter: sepia(0.18) saturate(0.9);
  }
  .cc-map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .cc-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 6px;
  }

  /* The Collection — six category mini-plates */
  .cc-cats {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  .cc-cats__item {
    display: block;
    position: relative;
    background: var(--color-cream);
    border: 1.4px solid #1A1614;
    padding: 8px 8px 10px;
    box-shadow: 3px 3px 0 rgba(26,22,20,0.22);
  }
  .cc-cats__item img {
    display: block;
    width: 100%;
    height: 78px;
    object-fit: cover;
    filter: sepia(0.18) saturate(0.85) contrast(1.04);
    border: 1px solid rgba(26,22,20,0.4);
  }
  .cc-cats__no {
    display: block;
    font-family: "Oswald", sans-serif;
    letter-spacing: 0.28em;
    font-size: 0.55rem;
    color: var(--color-brass);
    margin: 6px 0 2px;
  }
  .cc-cats__name {
    display: block;
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    line-height: 1.1;
  }

  /* Tonight's Lineup — four catalog plates */
  .cc-lineup {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    display: grid;
    gap: 18px;
  }
  .cc-lineup__plate {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 14px;
    align-items: flex-start;
    padding-bottom: 16px;
    border-bottom: 1px dashed rgba(26,22,20,0.4);
  }
  .cc-lineup__plate:last-child { border-bottom: 0; padding-bottom: 0; }
  .cc-lineup__photo {
    background: var(--color-cream);
    border: 1.4px solid #1A1614;
    padding: 4px;
    box-shadow: 3px 3px 0 rgba(26,22,20,0.22);
  }
  .cc-lineup__photo img {
    display: block;
    width: 100%;
    height: 92px;
    object-fit: cover;
    filter: sepia(0.18) saturate(0.85);
  }
  .cc-lineup__copy { display: flex; flex-direction: column; gap: 2px; }
  .cc-lineup__no {
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    font-size: 0.6rem;
    color: var(--color-brass);
  }
  .cc-lineup__name {
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    line-height: 1.1;
    color: var(--color-ink);
  }
  .cc-lineup__era {
    font-family: "Bodoni Moda", Georgia, serif;
    font-style: italic;
    font-size: 0.78rem;
    color: rgba(26,22,20,0.75);
    margin-top: 2px;
  }
  .cc-lineup__note {
    font-family: "EB Garamond", Georgia, serif;
    font-size: 0.85rem;
    line-height: 1.3;
    margin: 4px 0 4px;
    color: var(--color-ink);
  }
  .cc-lineup__price {
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-buddy-red);
    margin-top: 2px;
  }

  /* The Record card — the emerald-felt block, the one section
     that breaks from cream. It lives INSIDE its index card. */
  .cc-record {
    margin: 12px -10px 0;
    padding: 22px 22px 26px;
    background:
      repeating-linear-gradient(
        135deg,
        rgba(0,0,0,0.06) 0 2px,
        transparent 2px 5px
      ),
      #1F4D3F;
    color: var(--color-cream);
    border: 1.4px solid #0e2a22;
    box-shadow:
      inset 0 0 0 1px rgba(201,162,39,0.45),
      4px 4px 0 rgba(26,22,20,0.4);
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 18px;
    align-items: center;
  }
  .cc-record__tag {
    display: block;
