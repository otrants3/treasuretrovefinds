---
import Layout from "../layouts/Layout.astro";
import SunburstSeal from "../components/SunburstSeal.astro";
import PaperTag from "../components/PaperTag.astro";
import BoxingBilling from "../components/BoxingBilling.astro";
import CatalogPlate from "../components/CatalogPlate.astro";
import AdmissionStub from "../components/AdmissionStub.astro";
import CabinetDoors from "../components/CabinetDoors.astro";
import ShelfScene from "../components/ShelfScene.astro";

// Source of truth for booth facts — single edit point.
const BOOTH = {
  name: "Paradise Mall · Booth #18",
  street: "3565 E. Flamingo Road",
  city: "Las Vegas, Nevada 89121",
  phone: "(516) 446-2693",
  phoneHref: "tel:+15164462693",
  hoursLine: "Open daily, 10 'til 6",
  billLine: "Bill works the booth Weds & Sun",
  mapHref:
    "https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121",
};
---

<Layout>
  <!-- ============================================================
       ENTRY — Cabinet doors that open onto the booth interior.
       The first thing every visitor sees. Click "Pull to enter".
       ============================================================ -->
  <CabinetDoors>
    <!-- INTERIOR of the cabinet — visible after doors swing open -->
    <div class="ttf-interior">
      <img
        class="ttf-interior__photo"
        src="/photos/booth-wide.jpg"
        alt="Inside Booth #18 at Paradise Mall — glass cases stacked floor-to-ceiling with vintage Buddy L trucks, perfume bottles, art glass and Americana"
      />
      <div class="ttf-interior__vignette" aria-hidden="true"></div>

      <div class="ttf-interior__overlay">
        <div class="ttf-interior__billing">
          <p class="ttf-interior__eyebrow">— For Your Inspection, Nightly —</p>
          <h2 class="ttf-headline ttf-interior__headline">Every Piece<br />Has a Record.</h2>
          <p class="ttf-interior__sub">
            Fifty years on the hunt — now showing at Paradise Mall, Booth&nbsp;#18,&nbsp;Las&nbsp;Vegas.
          </p>
          <div class="ttf-interior__ctas">
            <a class="ttf-btn ttf-btn-primary" href="#joint">Drop in — Booth #18</a>
            <a class="ttf-btn ttf-btn-secondary" href={BOOTH.phoneHref}>
              Ring Bill up · {BOOTH.phone}
            </a>
          </div>
        </div>
        <div class="ttf-interior__stub">
          <AdmissionStub
            line1="ADMIT ONE"
            line2="NO COVER"
            line3="Walk in. Ask Bill about anything."
            serial="№ 0418"
            rotate={-3}
          />
        </div>
      </div>
    </div>
  </CabinetDoors>

  <!-- ============================================================
       MASTHEAD STRIP — wordmark + nav + seal once you've entered
       ============================================================ -->
  <header class="ttf-mast">
    <div class="ttf-mast__inner">
      <nav class="ttf-mast__nav" aria-label="Primary">
        <a href="#joint">Find the Joint</a>
        <span aria-hidden="true">◆</span>
        <a href="#story">How We Got Here</a>
        <span aria-hidden="true">◆</span>
        <a href="#cabinet">The Cabinet</a>
        <span aria-hidden="true">◆</span>
        <a href="#lineup">Tonight's Lineup</a>
      </nav>

      <div class="ttf-mast__center">
        <p class="ttf-mast__eyebrow">— Fine Curiosities &amp; Relics · Vol. I, No. 1 —</p>
        <p class="ttf-mast__wordmark">TREASURE TROVE FINDS</p>
        <p class="ttf-mast__sub">A back-room of American oddments, kept by Bill &amp; Lisa.</p>
      </div>

      <div class="ttf-mast__seal">
        <SunburstSeal size={94} est="2022" since="'73" />
      </div>
    </div>
    <div class="ttf-double-rule"></div>
  </header>

  <!-- ============================================================
       FIND THE JOINT — booth, hours, phone, map (high priority)
       ============================================================ -->
  <section id="joint" class="ttf-joint">
    <BoxingBilling
      eyebrow="Directions"
      title="FIND THE JOINT"
      sub="no GPS required, but it helps"
    />
    <div class="ttf-joint__grid">
      <div class="ttf-map-frame">
        <iframe
          title="Map to Paradise Mall, Booth #18"
          src="https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <aside class="ttf-card">
        <span class="ttf-card__corner ttf-card__corner--tl"></span>
        <span class="ttf-card__corner ttf-card__corner--tr"></span>
        <span class="ttf-card__corner ttf-card__corner--bl"></span>
        <span class="ttf-card__corner ttf-card__corner--br"></span>

        <p class="ttf-label">Directions</p>
        <p class="ttf-card__line ttf-card__line--bold">{BOOTH.name.toUpperCase()}</p>
        <p class="ttf-card__line">{BOOTH.street}</p>
        <p class="ttf-card__line">{BOOTH.city}</p>

        <div class="ttf-card__divider"></div>

        <p class="ttf-label">Hours</p>
        <p class="ttf-card__line">{BOOTH.hoursLine}</p>
        <p class="ttf-card__line ttf-card__line--italic">{BOOTH.billLine}</p>

        <div class="ttf-card__divider"></div>

        <p class="ttf-label">Ring Bill Up</p>
        <p class="ttf-card__line ttf-card__line--phone">{BOOTH.phone}</p>
        <p class="ttf-card__line ttf-card__line--italic">
          Call ahead and we'll set things aside.
        </p>

        <div class="ttf-card__buttons">
          <a class="ttf-btn ttf-btn-primary" href={BOOTH.mapHref} target="_blank" rel="noopener">Get Directions</a>
          <a class="ttf-btn ttf-btn-secondary" href={BOOTH.phoneHref}>Call Bill</a>
        </div>
      </aside>
    </div>
  </section>

  <hr class="ttf-rule" />

  <!-- ============================================================
       HOW WE GOT HERE — Bill's real origin story
       ============================================================ -->
  <section id="story" class="ttf-story">
    <BoxingBilling
      eyebrow="The Proprietors"
      title="HOW WE GOT HERE"
      sub="baseball cards, then everything else"
    />

    <div class="ttf-story__grid">
      <figure class="ttf-portrait">
        <div class="ttf-portrait__frame">
          <!-- AWAITING: sepia portrait of Bill & Lisa. Holding shot for now. -->
          <img src="/photos/fan-perfumes.jpg" alt="A corner of Bill & Lisa's booth — the kind of room you don't find in 2026" />
        </div>
        <figcaption>
          <span class="ttf-portrait__caption">Bill &amp; Lisa Otranto</span>
          <span class="ttf-portrait__subcap">Proprietors · Booth #18 · since the right room came along</span>
        </figcaption>
      </figure>

      <div class="ttf-story__copy">
        <h3 class="ttf-story__pullquote">
          “Bill wasn't collecting antiques. <em>He was collecting the stories behind the numbers.</em>”
        </h3>

        <p>
          Bill caught the bug the way most boys did — a stack of baseball cards. But the
          players weren't the point. The <strong>numbers on the back</strong> were. The years,
          the batting averages, the team names, the stadiums. The history hiding inside
          the data. He'd memorize them. He'd cross-reference them. He'd
          want to know <em>what else</em> was happening the year a player hit .357.
        </p>

        <p>
          That curiosity never quit. From cards he moved to bottles, then signs,
          then toys, then anything that came with a story he hadn't heard yet.
          Not just antique. Not just vintage. <em>Nostalgic</em> — pieces with a hold
          on the room they came out of. A perfume bottle from 1934 with a Marie
          Antoinette miniature painted on the front. A pressed-steel race car from
          when steel was the right material for a toy. A General Electric oscillating
          fan, cast iron and brass, that's been moving air through living rooms
          since before the war. Things that catch the mind.
        </p>

        <p>
          Lisa came along, made it a life. Together they've spent the last
          half-century chasing American oddments up and down two coasts —
          <em>not for the price tags but for the moments the objects remember.</em>
        </p>

        <p>
          Walk into Booth #18 and point at anything. Bill will not hesitate. He'll
          tell you the year it was made, the maker, what it sold for new, who
          probably bought it first, and what was happening in America that month.
          And he'll tell it animated — hands moving, leaning on the case,
          getting <em>into it</em>. This is not your sixth-grade Social Studies
          teacher's history lecture. This is history told the way it should
          have been the first time. Lisa keeps the dates straight. Bill carries
          the rest.
        </p>

        <p class="ttf-story__sig">
          — <span>Bill &amp; Lisa</span>, Booth&nbsp;#18
        </p>
      </div>
    </div>
  </section>

  <hr class="ttf-rule" />

  <!-- ============================================================
       THE CABINET — three real shelves with tag callouts
       (Replaces the old "departments grid")
       ============================================================ -->
  <section id="cabinet" class="ttf-cabinet-section">
    <BoxingBilling
      eyebrow="Step Inside"
      title="THE CABINET"
      sub="three shelves · forty pieces in eyeshot · most of the 20th century"
    />

    <div class="ttf-shelves">
      <ShelfScene
        caption="Shelf I — The Trucks & Pressed Steel"
        byline="When toys were built to outlive their owners. Most of them did."
        photo="/photos/case-buddy-l-trucks.jpg"
        tags={[
          { era: "1938", item: "Buddy L Fire Engine", note: "all-original ladders", price: "$285.00", top: "16%", left: "8%", rotate: -5 },
          { era: "1940", item: "Allied Van", note: "original decals, honest paint", price: "$315.00", top: "58%", left: "62%", rotate: 4 },
        ]}
      />

      <ShelfScene
        caption="Shelf II — Glass, Bottles & Pre-war Americana"
        byline="Bottler wars, dairy routes, Mobil Pegasus signs — the paper trail that wasn't paper."
        photo="/photos/shelves-bottles.jpg"
        tags={[
          { era: "1932-48", item: "Embossed Milk-Bottle Lot", note: "six pieces, NY dairies", price: "$95.00", top: "14%", left: "60%", rotate: -3 },
          { era: "1942", item: "Mobil Gas Porcelain Sign", note: "Pegasus crest · honest wear", price: "$420.00", top: "55%", left: "12%", rotate: 5 },
        ]}
      />

      <ShelfScene
        caption="Shelf III — Oddments, Adornments & Curiosities"
        byline="Pieces Bill chased because they caught his mind. Ask him why."
        photo="/photos/fan-perfumes.jpg"
        tags={[
          { era: "1934", item: "Ludwig Scherk Perfume Bottle", note: "w/ Marie Antoinette miniature", price: "$225.00", top: "12%", left: "55%", rotate: -4 },
          { era: "1930s", item: "GE Cast-Iron Oscillating Fan", note: "still works · ask Bill to plug it in", price: "ask Bill", top: "60%", left: "8%", rotate: 3 },
        ]}
      />
    </div>

    <p class="ttf-shelves__foot">
      <span class="ttf-leaf">❦</span>
      Forty pieces visible from where you'd stand. Hundreds more under the cases.
      <a href={BOOTH.phoneHref}>Come look.</a>
      <span class="ttf-leaf">❦</span>
    </p>
  </section>

  <!-- ============================================================
       TONIGHT'S LINEUP — four favorite finds, catalog plates
       ============================================================ -->
  <section id="lineup" class="ttf-lineup">
    <BoxingBilling
      eyebrow="On the Bill Tonight"
      title="TONIGHT'S LINEUP"
      sub="four pieces, hand-picked, currently at the booth"
    />

    <div class="ttf-lineup__grid">
      <CatalogPlate
        plate="PLATE NO. 01"
        item="Ludwig Scherk Renaissance Perfume Bottle"
        era="1934 · German, silvered metalwork"
        note="w/ Marie Antoinette miniature"
        price="$225.00"
        photo="/photos/tag-perfume-bottle.jpg"
      />
      <CatalogPlate
        plate="PLATE NO. 02"
        item="Hobby Kiddie Die-cast Race Car"
        era="1930-1940s · pressed steel, original rubber"
        note="#SH-457, all-original"
        price="$65.00"
        photo="/photos/tag-race-car.jpg"
      />
      <CatalogPlate
        plate="PLATE NO. 03"
        item="General Electric Cast-Iron Fan"
        era="circa 1930s · oscillating, brass blade"
        note="still works · ask Bill to plug it in"
        price=""
        photo="/photos/fan-perfumes.jpg"
        awaiting={true}
      />
      <CatalogPlate
        plate="PLATE NO. 04"
        item="Awaiting Bill's Pick"
        era="he has thirty in mind, won't commit to one"
        note="check back Sunday"
        photo=""
        awaiting={true}
      />
    </div>

    <p class="ttf-lineup__foot">
      <span class="ttf-leaf">❦</span>
      The lineup turns over fast. <a href={BOOTH.phoneHref}>Call ahead</a> if you've got your eye on something.
      <span class="ttf-leaf">❦</span>
    </p>
  </section>

  <!-- ============================================================
       EVERY PIECE HAS A RECORD — emerald felt punch
       ============================================================ -->
  <section id="tags" class="ttf-felt ttf-on-emerald">
    <div class="ttf-felt__inner">
      <BoxingBilling
        eyebrow="On the Counter"
        title="EVERY PIECE HAS A RECORD"
        sub="the homework, in our own hand"
        onEmerald={true}
      />

      <div class="ttf-tag-row">
        <PaperTag era="1934" item="Ludwig Scherk Renaissance Perfume Bottle" notes="w/ Marie Antoinette picture · original metalwork" price="$225.00" rotate={-4} onFelt={true} />
        <PaperTag era="1930-1940" item="Hobby Kiddie Diecast Race Car" notes="green over silver, original rubber, #SH-457" price="$65.00" rotate={2} onFelt={true} />
        <PaperTag era="1938" item="Buddy L Fire Engine" notes="Am. pressed steel, E. Moline, IL. all-original ladders" price="$285.00" rotate={-1} onFelt={true} />
        <PaperTag era="1942" item="Mobil Gas Porcelain Sign" notes="Pegasus crest. some honest wear, no rust-through" price="$420.00" rotate={4} onFelt={true} />
        <PaperTag era="1930s" item="Carved Bakelite Cuff" notes="cherry red, faceted edge, two repairs Bill'll show you" price="$68.00" rotate={-3} onFelt={true} />
        <PaperTag era="1928" item="Tin Pan Alley Sheet Music" notes="signed in pencil. provenance on file." price="$42.00" rotate={1} onFelt={true} />
      </div>

      <p class="ttf-felt__footer">
        <span class="ttf-leaf">❦</span>
        Want the full story behind any of them? <a href={BOOTH.phoneHref}>Ring Bill up — {BOOTH.phone}</a>
        <span class="ttf-leaf">❦</span>
      </p>
    </div>
  </section>

  <!-- ============================================================
       ETSY
       ============================================================ -->
  <section id="etsy" class="ttf-etsy">
    <BoxingBilling
      eyebrow="Coming Soon"
      title="ETSY'S COMING."
      sub="get on the list · jump the queue"
    />

    <div class="ttf-etsy__inner">
      <p class="ttf-etsy__body">
        We're putting the listings together piece by piece. If you want first crack at
        the good stuff before it goes up — <em>and the first crack is what you want</em> —
        leave your name. No spam. No tricks. We don't have time for that.
      </p>

      <form class="ttf-etsy__form" action="#" method="post">
        <input
          type="email"
          name="email"
          placeholder="your.email@…"
          aria-label="Email address"
          required
        />
        <button class="ttf-btn ttf-btn-primary" type="submit">Get the word first</button>
      </form>

      <p class="ttf-label ttf-etsy__legal">No spam · No tricks · We don't have time for that</p>
    </div>
  </section>

  <!-- ============================================================
       FOOTER
       ============================================================ -->
  <footer class="ttf-footer">
    <div class="ttf-footer__seal">
      <SunburstSeal size={140} est="2022" since="'73" />
    </div>
    <div class="ttf-double-rule"></div>
    <p class="ttf-footer__tagline">
      Est. 2022 · Collecting since 1973 · <em>Pieces back to 1850.</em><br />
      Bill knows everybody. <em>Ask no questions.</em>
    </p>
    <p class="ttf-label ttf-footer__legal">
      TREASURE TROVE FINDS · PARADISE MALL · BOOTH #18 · LAS VEGAS, NEVADA
    </p>
    <p class="ttf-footer__labs">An Otranto Labs project</p>
  </footer>
</Layout>

<style>
  /* ----------------------------------------------------------------
     Cabinet interior — what you see after the doors open
  ---------------------------------------------------------------- */
  .ttf-interior {
    position: relative;
    width: 100%;
    min-height: 92vh;
    overflow: hidden;
    isolation: isolate;
  }
  .ttf-interior__photo {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 35%;
    filter: saturate(0.85) sepia(0.10) contrast(1.05);
    z-index: 0;
  }
  .ttf-interior__vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg,
        rgba(26,22,20,0.55) 0%,
        rgba(26,22,20,0.25) 25%,
        rgba(26,22,20,0.05) 45%,
        rgba(26,22,20,0.4) 80%,
        rgba(26,22,20,0.9) 100%),
      radial-gradient(ellipse at center, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 100%);
    pointer-events: none;
  }
  .ttf-interior__overlay {
    position: relative;
    z-index: 2;
    max-width: 1180px;
    margin: 0 auto;
    padding: 80px 32px 96px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 36px;
    align-items: end;
    min-height: 92vh;
  }
  .ttf-interior__billing {
    background: var(--color-cream);
    background-image: radial-gradient(rgba(61,42,30,0.06) 1px, transparent 1.4px);
    background-size: 4px 4px;
    border: 1.5px solid var(--color-walnut);
    box-shadow:
      0 6px 0 rgba(0,0,0,0.35),
      inset 0 0 0 5px var(--color-cream),
      inset 0 0 0 6px var(--color-brass);
    padding: 36px 40px 32px;
    max-width: 640px;
    position: relative;
  }
  .ttf-interior__billing::before, .ttf-interior__billing::after {
    content: "✦";
    position: absolute;
    color: var(--color-brass);
    font-size: 18px;
  }
  .ttf-interior__billing::before { top: 10px; left: 14px; }
  .ttf-interior__billing::after  { bottom: 10px; right: 14px; }
  .ttf-interior__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 12px;
    text-align: center;
    margin: 0 0 6px;
  }
  .ttf-interior__headline {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    text-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    transform: rotate(-0.5deg);
    font-size: clamp(48px, 7vw, 96px);
    line-height: 0.92;
    letter-spacing: 0.008em;
    margin: 0;
    text-align: center;
    text-transform: uppercase;
  }
  .ttf-interior__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: clamp(16px, 1.8vw, 20px);
    margin: 18px auto 24px;
    text-align: center;
    max-width: 32rem;
  }
  .ttf-interior__ctas {
    display: flex; gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ttf-interior__stub {
    align-self: end;
    display: flex; justify-content: flex-end;
    transform: translateY(-12px);
  }
  @media (max-width: 880px) {
    .ttf-interior__overlay { grid-template-columns: 1fr; gap: 24px; padding: 64px 20px 80px; }
    .ttf-interior__stub { justify-content: center; transform: none; }
    .ttf-interior__billing { padding: 28px 24px; }
  }

  /* ----------------------------------------------------------------
     Masthead (compact, post-entry)
  ---------------------------------------------------------------- */
  .ttf-mast { padding: 22px 32px 0; max-width: 1280px; margin: 0 auto; }
  .ttf-mast__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  .ttf-mast__nav {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-label);
    color: var(--color-brass);
    letter-spacing: 0.22em; font-size: 11px;
    text-transform: uppercase; flex-wrap: wrap;
  }
  .ttf-mast__nav a { color: var(--color-brass); text-decoration: none; }
  .ttf-mast__nav a:hover { color: var(--color-buddy-red); }
  .ttf-mast__nav span { font-size: 10px; opacity: 0.7; }

  .ttf-mast__center { text-align: center; }
  .ttf-mast__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 11px;
    margin: 0;
  }
  .ttf-mast__wordmark {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: clamp(28px, 4vw, 44px);
    line-height: 0.95;
    letter-spacing: 0.012em;
    margin: 4px 0 4px;
    text-shadow: 1.5px 1.5px 0 rgba(26,22,20,0.18);
    transform: rotate(-0.3deg);
  }
  .ttf-mast__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 15px;
    margin: 0;
  }
  .ttf-mast__seal { display: flex; justify-content: flex-end; }

  @media (max-width: 880px) {
    .ttf-mast__inner { grid-template-columns: 1fr; }
    .ttf-mast__nav { justify-content: center; }
    .ttf-mast__seal { justify-content: center; }
  }

  /* ----------------------------------------------------------------
     Joint
  ---------------------------------------------------------------- */
  .ttf-joint { max-width: 1180px; margin: 56px auto 0; padding: 0 24px; }
  .ttf-joint__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    margin-top: 12px;
  }
  @media (max-width: 880px) { .ttf-joint__grid { grid-template-columns: 1fr; } }
  .ttf-map-frame {
    position: relative;
    padding: 10px;
    border: 1.5px solid var(--color-brass);
    background: rgba(0,0,0,0.04);
    min-height: 380px;
  }
  .ttf-map-frame::before, .ttf-map-frame::after {
    content: "";
    position: absolute;
    width: 22px; height: 22px;
    border: 1.5px solid var(--color-brass);
  }
  .ttf-map-frame::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .ttf-map-frame::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
  .ttf-map-frame iframe {
    width: 100%; height: 100%; min-height: 380px;
    border: 1px solid var(--color-walnut);
    display: block;
    filter: sepia(0.3) saturate(0.7) contrast(1.05);
  }

  .ttf-card {
    background: var(--color-cream);
    border: 1.5px solid var(--color-walnut);
    position: relative;
    padding: 28px 24px;
  }
  .ttf-card__corner { position: absolute; width: 18px; height: 18px; border: 1.5px solid var(--color-brass); }
  .ttf-card__corner--tl { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .ttf-card__corner--tr { top: -1px; right: -1px; border-left: 0; border-bottom: 0; }
  .ttf-card__corner--bl { bottom: -1px; left: -1px; border-right: 0; border-top: 0; }
