---
import Layout from "../layouts/Layout.astro";
import SunburstSeal from "../components/SunburstSeal.astro";
import PaperTag from "../components/PaperTag.astro";
import BoxingBilling from "../components/BoxingBilling.astro";
import CurioDrawer from "../components/CurioDrawer.astro";

// Centralized facts — single source of truth, easy to swap later.
const BOOTH = {
  name: "Paradise Mall · Booth #18",
  street: "3565 E. Flamingo Road",
  city: "Las Vegas, Nevada 89121",
  phone: "(516) 446-2693",
  phoneHref: "tel:+15164462693",
  hoursLine: "Open daily, 10 'til 6",
  billLine: "Bill works the booth Weds & Sun",
  mapHref:
    "https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121",
};
---

<Layout>
  <!-- MASTHEAD -->
  <header class="ttf-mast">
    <div class="ttf-mast__inner">
      <nav class="ttf-mast__nav" aria-label="Primary">
        <a href="#collection">The Collection</a>
        <span aria-hidden="true">◆</span>
        <a href="#tags">The Record</a>
        <span aria-hidden="true">◆</span>
        <a href="#joint">Find the Joint</a>
        <span aria-hidden="true">◆</span>
        <a href="#etsy">Etsy</a>
      </nav>

      <div class="ttf-mast__center">
        <p class="ttf-mast__eyebrow">— Fine Curiosities &amp; Relics · Vol. I, No. 1 —</p>
        <h1 class="ttf-headline ttf-mast__wordmark">TREASURE TROVE FINDS</h1>
        <p class="ttf-mast__sub">
          Curated since 1973 — now showing at Paradise Mall, Booth #18, Las Vegas.
        </p>
      </div>

      <div class="ttf-mast__seal">
        <SunburstSeal size={108} est="2022" since="'73" />
      </div>
    </div>
    <div class="ttf-double-rule"></div>
  </header>

  <!-- HERO — Bill's Notebook page -->
  <section class="ttf-hero">
    <article class="ttf-notebook">
      <div class="ttf-notebook__margin"></div>

      <figure class="ttf-polaroid">
        <span class="ttf-clip" aria-hidden="true">
          <svg viewBox="0 0 60 90" width="38" height="58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M30 5 C18 5 12 14 12 26 V70 C12 78 18 84 26 84 C34 84 40 78 40 70 V36 C40 30 36 26 30 26 C24 26 20 30 20 36 V62"
              stroke="#5A554E" stroke-width="3" stroke-linecap="round" />
          </svg>
        </span>
        <img src="/photos/case-buddy-l-trucks.jpg" alt="Bill's display case stacked with vintage Buddy L fire trucks, Allied vans, and pressed-steel toys" />
        <figcaption>
          <span class="ttf-polaroid__caption">case #14 — the trucks, last Sunday</span>
        </figcaption>
      </figure>

      <div class="ttf-notebook__copy">
        <p class="ttf-margin-note">Bill's notes —</p>

        <h2 class="ttf-headline ttf-hero__headline">
          Every piece has a record.
        </h2>

        <p class="ttf-hero__body">
          Bill's been on the hunt since '73. <em>Some of the stuff in here predates the radio.</em>
          Other vendors put a price on a tag. Bill puts the <strong>homework</strong> —
          the maker, the era, the where-he-got-it, in his own hand.
          Walk into Booth #18 and ask him about anything. He loves to talk.
        </p>

        <div class="ttf-hero__ctas">
          <a class="ttf-btn ttf-btn-primary" href="#joint">Drop in — Booth #18</a>
          <a class="ttf-btn ttf-btn-secondary" href={BOOTH.phoneHref}>
            Ring Bill up · {BOOTH.phone}
          </a>
        </div>

        <p class="ttf-hero__hours">
          <span class="ttf-label">Open daily 10–6 · Bill works Weds &amp; Sun</span>
        </p>

        <div class="ttf-hero__tag">
          <PaperTag
            era="1934"
            item="Ludwig Scherk Renaissance Perfume Bottle"
            notes="w/ Marie Antoinette picture · original metalwork"
            price="$225.00"
            rotate={4}
            size="md"
          />
          <span class="ttf-tag-label">a tag, written by Bill, for what's at the booth right now</span>
        </div>
      </div>
    </article>
  </section>

  <hr class="ttf-rule" />

  <!-- THE COLLECTION -->
  <section id="collection" class="ttf-collection">
    <BoxingBilling
      eyebrow="The Cabinet"
      title="THE COLLECTION"
      sub="six drawers · fifty years deep · pieces back to 1850"
    />

    <div class="ttf-collection__grid">
      <CurioDrawer
        number="I."
        category="Toys &amp; Trucks"
        blurb="Buddy L, Tonka, Smith-Miller, Marx. The real pressed-steel stuff."
        photo="/photos/case-buddy-l-trucks.jpg"
      />
      <CurioDrawer
        number="II."
        category="Art Glass &amp; Bottles"
        blurb="Embossed milk bottles, depression glass, Mason's, oilers. Half a century of clear stories."
        photo="/photos/shelves-bottles.jpg"
      />
      <CurioDrawer
        number="III."
        category="Advertising &amp; Signage"
        blurb="Tin signs, gas-station relics, pre-war Americana. The real porcelain."
        photo="/photos/signage.jpg"
      />
      <CurioDrawer
        number="IV."
        category="Jewelry &amp; Adornment"
        blurb="Bakelite, costume, and the occasional piece Bill won't say where he got."
        photo="/photos/jewelry.jpg"
      />
      <CurioDrawer
        number="V."
        category="Americana &amp; Ephemera"
        blurb="Catalog pages, ticket stubs, fight cards, advertising tins. The paper trail."
        photo="/photos/americana.jpg"
      />
      <CurioDrawer
        number="VI."
        category="Curiosities"
        blurb="The whatsits. The wherefores. Walk in and ask — Bill'll tell you."
        photo="/photos/curiosities.jpg"
      />
    </div>
  </section>

  <!-- THE RECORD — emerald-felt punch -->
  <section id="tags" class="ttf-felt ttf-on-emerald">
    <div class="ttf-felt__inner">
      <BoxingBilling
        eyebrow="On the Counter"
        title="EVERY PIECE HAS A RECORD"
        sub="the homework, in Bill's own hand"
        onEmerald={true}
      />

      <div class="ttf-tag-row">
        <PaperTag era="1934" item="Ludwig Scherk Renaissance Perfume Bottle" notes="w/ Marie Antoinette picture · original metalwork" price="$225.00" rotate={-4} onFelt={true} />
        <PaperTag era="1930-1940" item="Hobby Kiddie Diecast Race Car" notes="green over silver, original rubber, #SH-457" price="$65.00" rotate={2} onFelt={true} />
        <PaperTag era="1938" item="Buddy L Fire Engine" notes="Am. pressed steel, E. Moline, IL. all-original ladders" price="$285.00" rotate={-1} onFelt={true} />
        <PaperTag era="1942" item="Mobil Gas Porcelain Sign" notes="Pegasus crest. some honest wear, no rust-through" price="$420.00" rotate={4} onFelt={true} />
        <PaperTag era="1930s" item="Carved Bakelite Cuff" notes="cherry red, faceted edge, two repairs Bill'll show you" price="$68.00" rotate={-3} onFelt={true} />
        <PaperTag era="1928" item="Tin Pan Alley Sheet Music" notes="signed in pencil. provenance on file." price="$42.00" rotate={1} onFelt={true} />
      </div>

      <p class="ttf-felt__footer">
        <span class="ttf-leaf">❦</span>
        Want the full story? <a href={BOOTH.phoneHref}>Ring Bill up — {BOOTH.phone}</a>
        <span class="ttf-leaf">❦</span>
      </p>
    </div>
  </section>

  <!-- FIND THE JOINT -->
  <section id="joint" class="ttf-joint">
    <BoxingBilling
      eyebrow="Directions"
      title="FIND THE JOINT"
      sub="no GPS required, but it helps"
    />

    <div class="ttf-joint__grid">
      <div class="ttf-map-frame">
        <iframe
          title="Map to Paradise Mall, Booth #18"
          src="https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

      <aside class="ttf-card">
        <span class="ttf-card__corner ttf-card__corner--tl"></span>
        <span class="ttf-card__corner ttf-card__corner--tr"></span>
        <span class="ttf-card__corner ttf-card__corner--bl"></span>
        <span class="ttf-card__corner ttf-card__corner--br"></span>

        <p class="ttf-label">Directions</p>
        <p class="ttf-card__line ttf-card__line--bold">{BOOTH.name.toUpperCase()}</p>
        <p class="ttf-card__line">{BOOTH.street}</p>
        <p class="ttf-card__line">{BOOTH.city}</p>

        <div class="ttf-card__divider"></div>

        <p class="ttf-label">Hours</p>
        <p class="ttf-card__line">{BOOTH.hoursLine}</p>
        <p class="ttf-card__line ttf-card__line--italic">{BOOTH.billLine}</p>

        <div class="ttf-card__divider"></div>

        <p class="ttf-label">Ring Bill Up</p>
        <p class="ttf-card__line ttf-card__line--phone">{BOOTH.phone}</p>
        <p class="ttf-card__line ttf-card__line--italic">
          Bill loves to talk. Call ahead and he'll set things aside.
        </p>

        <div class="ttf-card__buttons">
          <a class="ttf-btn ttf-btn-primary" href={BOOTH.mapHref} target="_blank" rel="noopener">Get Directions</a>
          <a class="ttf-btn ttf-btn-secondary" href={BOOTH.phoneHref}>Call Bill</a>
        </div>
      </aside>
    </div>
  </section>

  <hr class="ttf-rule" />

  <!-- ETSY -->
  <section id="etsy" class="ttf-etsy">
    <BoxingBilling
      eyebrow="Coming Soon"
      title="ETSY'S COMING."
      sub="get on the list, jump the queue"
    />

    <div class="ttf-etsy__inner">
      <p class="ttf-etsy__body">
        Bill's putting the listings together. If you want first crack at the good stuff
        before it goes up — <em>and the first crack is what you want</em> —
        leave your name. No spam. No tricks. Bill doesn't have time for that.
      </p>

      <form class="ttf-etsy__form" action="#" method="post">
        <input
          type="email"
          name="email"
          placeholder="your.email@…"
          aria-label="Email address"
          required
        />
        <button class="ttf-btn ttf-btn-primary" type="submit">Get the word first</button>
      </form>

      <p class="ttf-label ttf-etsy__legal">No spam · No tricks · Bill doesn't have time for that</p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="ttf-footer">
    <div class="ttf-footer__seal">
      <SunburstSeal size={140} est="2022" since="'73" />
    </div>
    <div class="ttf-double-rule"></div>
    <p class="ttf-footer__tagline">
      Est. 2022 · Collecting since 1973 · <em>Pieces back to 1850.</em><br />
      Ask no questions.
    </p>
    <p class="ttf-label ttf-footer__legal">
      TREASURE TROVE FINDS · PARADISE MALL · BOOTH #18 · LAS VEGAS, NEVADA
    </p>
    <p class="ttf-footer__labs">An Otranto Labs project</p>
  </footer>
</Layout>

<style>
  /* Masthead */
  .ttf-mast { padding: 22px 32px 0; max-width: 1280px; margin: 0 auto; }
  .ttf-mast__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 24px;
    align-items: center;
  }
  .ttf-mast__nav {
    display: flex; align-items: center; gap: 10px;
    font-family: var(--font-label);
    color: var(--color-brass);
    letter-spacing: 0.22em; font-size: 11px;
    text-transform: uppercase; flex-wrap: wrap;
  }
  .ttf-mast__nav a { color: var(--color-brass); text-decoration: none; }
  .ttf-mast__nav a:hover { color: var(--color-buddy-red); }
  .ttf-mast__nav span { font-size: 10px; opacity: 0.7; }

  .ttf-mast__center { text-align: center; }
  .ttf-mast__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 11px;
    margin: 0;
  }
  .ttf-mast__wordmark {
    font-size: clamp(40px, 6.2vw, 78px);
    margin: 8px 0 4px;
  }
  .ttf-mast__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 17px;
    margin: 0;
  }
  .ttf-mast__seal { display: flex; justify-content: flex-end; }

  /* Hero — Notebook */
  .ttf-hero { max-width: 1180px; margin: 36px auto 0; padding: 0 24px; }
  .ttf-notebook {
    position: relative;
    background: var(--color-cream);
    background-image: linear-gradient(rgba(61,42,30,0.05) 1px, transparent 1px);
    background-size: 100% 32px;
    background-position: 0 2.5rem;
    border: 1px solid rgba(61,42,30,0.18);
    box-shadow: 0 6px 0 rgba(26,22,20,0.08);
    padding: 48px 56px 48px 88px;
    display: grid;
    grid-template-columns: minmax(280px, 1.05fr) 1fr;
    gap: 48px;
    align-items: center;
  }
  .ttf-notebook__margin {
    position: absolute;
    left: 60px; top: 0; bottom: 0;
    width: 1px;
    background: rgba(158,42,43,0.5);
  }

  .ttf-polaroid {
    background: #fbf3dc;
    padding: 14px 14px 56px;
    border: 1px solid rgba(61,42,30,0.18);
    box-shadow: 4px 5px 0 rgba(26,22,20,0.18), inset 0 0 24px rgba(61,42,30,0.05);
    transform: rotate(-1.5deg);
    margin: 0;
    position: relative;
    max-width: 460px;
    justify-self: center;
  }
  .ttf-polaroid img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    filter: saturate(0.85) sepia(0.08) contrast(1.04);
    border: 1px solid rgba(61,42,30,0.3);
    display: block;
  }
  .ttf-polaroid figcaption { text-align: center; margin-top: 14px; }
  .ttf-polaroid__caption { font-family: var(--font-hand); color: var(--color-walnut); font-size: 18px; }
  .ttf-clip {
    position: absolute;
    top: -34px; left: 50%;
    transform: translateX(-50%) rotate(8deg);
    z-index: 2; line-height: 0;
  }

  .ttf-notebook__copy { display: flex; flex-direction: column; gap: 18px; }
  .ttf-margin-note {
    font-family: var(--font-hand);
    color: var(--color-buddy-red);
    font-size: 22px;
    margin: 0;
    transform: rotate(-1deg);
  }
  .ttf-hero__headline {
    font-size: clamp(40px, 5.5vw, 72px);
    line-height: 0.92;
    margin: 0;
    text-transform: uppercase;
  }
  .ttf-hero__body {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0;
    max-width: 30rem;
  }
  .ttf-hero__body em { font-style: italic; color: var(--color-walnut); }
  .ttf-hero__body strong { color: var(--color-buddy-red); font-weight: 700; }
  .ttf-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 4px; }
  .ttf-hero__hours { margin: 6px 0 0; }
  .ttf-hero__tag {
    margin-top: 22px;
    display: flex; align-items: center; gap: 18px;
  }
  .ttf-tag-label {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 14px;
    max-width: 220px;
  }

  @media (max-width: 880px) {
    .ttf-mast__inner { grid-template-columns: 1fr; }
    .ttf-mast__nav { justify-content: center; }
    .ttf-mast__seal { justify-content: center; }
    .ttf-notebook { grid-template-columns: 1fr; padding: 36px 28px 36px 52px; }
    .ttf-notebook__margin { left: 32px; }
  }

  /* Collection */
  .ttf-collection { max-width: 1180px; margin: 0 auto; padding: 32px 24px 8px; }
  .ttf-collection__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    margin-top: 24px;
  }
  @media (max-width: 980px) { .ttf-collection__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 620px) { .ttf-collection__grid { grid-template-columns: 1fr; } }

  /* Felt */
  .ttf-felt {
    background: var(--color-emerald);
    background-image:
      radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
      radial-gradient(rgba(0,0,0,0.18) 1px, transparent 1.5px);
    background-size: 3px 3px, 7px 7px;
    color: var(--color-cream);
    margin-top: 64px;
    padding: 72px 24px 80px;
    border-top: 8px double var(--color-brass);
    border-bottom: 8px double var(--color-brass);
  }
  .ttf-felt__inner { max-width: 1180px; margin: 0 auto; }
  .ttf-tag-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 28px 36px;
    margin: 32px 0 24px;
  }
  .ttf-felt__footer {
    text-align: center;
    margin: 24px 0 0;
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-cream);
    font-size: 17px;
  }
  .ttf-felt__footer a {
    color: var(--color-brass);
    text-decoration: none;
    border-bottom: 1px dotted var(--color-brass);
  }
  .ttf-leaf { color: var(--color-brass); font-size: 22px; margin: 0 12px; }

  /* Joint */
  .ttf-joint { max-width: 1180px; margin: 64px auto 0; padding: 0 24px; }
  .ttf-joint__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 32px;
    margin-top: 12px;
  }
  @media (max-width: 880px) { .ttf-joint__grid { grid-template-columns: 1fr; } }

  .ttf-map-frame {
    position: relative;
    padding: 10px;
    border: 1.5px solid var(--color-brass);
    background: rgba(0,0,0,0.04);
    min-height: 380px;
  }
  .ttf-map-frame::before, .ttf-map-frame::after {
    content: "";
    position: absolute;
    width: 22px; height: 22px;
    border: 1.5px solid var(--color-brass);
  }
  .ttf-map-frame::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .ttf-map-frame::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
  .ttf-map-frame iframe {
    width: 100%;
    height: 100%;
    min-height: 380px;
    border: 1px solid var(--color-walnut);
    display: block;
    filter: sepia(0.3) saturate(0.7) contrast(1.05);
  }

  .ttf-card {
    background: var(--color-cream);
    border: 1.5px solid var(--color-walnut);
    position: relative;
    padding: 28px 24px;
  }
  .ttf-card__corner { position: absolute; width: 18px; height: 18px; border: 1.5px solid var(--color-brass); }
  .ttf-card__corner--tl { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .ttf-card__corner--tr { top: -1px; right: -1px; border-left: 0; border-bottom: 0; }
  .ttf-card__corner--bl { bottom: -1px; left: -1px; border-right: 0; border-top: 0; }
  .ttf-card__corner--br { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
  .ttf-card .ttf-label { margin: 12px 0 6px; }
  .ttf-card .ttf-label:first-of-type { margin-top: 0; }
  .ttf-card__line { font-family: var(--font-billing); font-size: 17px; margin: 0; color: var(--color-ink); }
  .ttf-card__line--bold { font-weight: 700; }
  .ttf-card__line--italic { font-style: italic; color: var(--color-smoke); font-size: 14px; }
  .ttf-card__line--phone {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 40px;
    line-height: 1;
    letter-spacing: 0.01em;
    margin: 2px 0 6px;
    text-shadow: 1px 1px 0 rgba(26,22,20,0.15);
  }
  .ttf-card__divider {
    border-top: 1px solid var(--color-brass);
    margin: 14px 0;
    position: relative;
    height: 0;
  }
  .ttf-card__divider::after {
    content: "◆";
    position: absolute;
    top: -9px; left: 50%; transform: translateX(-50%);
    color: var(--color-brass);
    background: var(--color-cream);
    padding: 0 8px;
    font-size: 11px;
  }
  .ttf-card__buttons { display: flex; gap: 10px; margin-top: 18px; }
  .ttf-card__buttons .ttf-btn {
    flex: 1; padding: 10px 14px;
    font-size: 11px; letter-spacing: 0.22em;
    box-shadow: 2px 2px 0 rgba(26,22,20,0.22);
  }

  /* Etsy */
  .ttf-etsy { max-width: 720px; margin: 0 auto; padding: 32px 24px 0; }
  .ttf-etsy__inner { text-align: center; margin-top: 16px; }
  .ttf-etsy__body {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.6;
    color: var(--color-ink);
    margin: 0 auto 22px;
    max-width: 560px;
  }
  .ttf-etsy__body em { color: var(--color-walnut); }
  .ttf-etsy__form {
    display: flex; gap: 0;
    max-width: 520px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
  }
  .ttf-etsy__form input {
    flex: 1; min-width: 220px;
    background: var(--color-cream);
    color: var(--color-ink);
    border: 1.5px solid var(--color-walnut);
    border-right: 0;
    padding: 14px 16px;
    font-family: var(--font-serif);
    font-size: 16px;
    outline: none;
  }
  .ttf-etsy__form input:focus { background: #faf2d8; }
  .ttf-etsy__form .ttf-btn { border-left: 1.5px solid var(--color-walnut); }
  .ttf-etsy__legal { color: var(--color-brass); margin-top: 18px; }
  @media (max-width: 540px) {
    .ttf-etsy__form input { border-right: 1.5px solid var(--color-walnut); margin-bottom: 12px; }
  }

  /* Footer */
  .ttf-footer {
    text-align: center;
    padding: 64px 24px 48px;
    max-width: 720px;
    margin: 56px auto 0;
  }
  .ttf-footer__seal { display: flex; justify-content: center; margin-bottom: 14px; }
  .ttf-footer__tagline {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 18px;
    line-height: 1.6;
    margin: 22px 0 16px;
  }
  .ttf-footer__tagline em { color: var(--color-walnut); }
