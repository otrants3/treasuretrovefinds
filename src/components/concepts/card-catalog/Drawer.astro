---
// A single drawer on the card-catalog cabinet front.
// Renders the drawer face (brass label-holder + brass pull) AND
// the index card slot that lives "inside" the drawer.
//
// The actual content (long-form card body) is passed via <slot />
// and rendered into the index card that slides out on open.

interface Props {
  drawerId: string;       // unique id, used to wire click + aria-controls
  dewey: string;          // Dewey-style classification, e.g. "917.93"
  label: string;          // small-caps drawer label (Bodoni)
  subLabel?: string;      // optional second line on the brass label
  cardTitle: string;      // title rendered on the index card
  cardEyebrow?: string;   // optional eyebrow above title
  stamp?: string;         // optional red ink stamp (e.g. "FILED", "VEGAS")
  /** column position (1-3) — used for the slide direction */
  col?: 1 | 2 | 3;
}

const {
  drawerId,
  dewey,
  label,
  subLabel,
  cardTitle,
  cardEyebrow,
  stamp,
  col = 2,
} = Astro.props;

const today = new Date();
const filed = today.toLocaleDateString("en-US", {
  month: "short",
  day: "2-digit",
  year: "numeric",
}).toUpperCase();
---

<div class={`cc-drawer cc-drawer--col-${col}`} data-drawer={drawerId}>
  <!-- The wooden drawer face. Click anywhere on it to pull. -->
  <button
    type="button"
    class="cc-drawer__face"
    aria-expanded="false"
    aria-controls={`card-${drawerId}`}
    data-toggle={drawerId}
  >
    <!-- Dewey number, typewriter, top-left -->
    <span class="cc-drawer__dewey">{dewey}</span>

    <!-- Brass label-holder, centered -->
    <span class="cc-drawer__plate">
      <span class="cc-drawer__plate-line">{label}</span>
      {subLabel && <span class="cc-drawer__plate-sub">{subLabel}</span>}
    </span>

    <!-- Brass pull, bottom-center -->
    <span class="cc-drawer__pull" aria-hidden="true">
      <span class="cc-drawer__pull-bar"></span>
    </span>

    <!-- Wood grain overlay (pseudo-element handles it) -->
  </button>

  <!-- The index card that lives "inside" the drawer.
       Hidden by default; .is-open on the parent .cc-drawer
       slides it out and reveals contents. -->
  <div
    class="cc-card"
    id={`card-${drawerId}`}
    role="region"
    aria-label={cardTitle}
    hidden
  >
    <button
      type="button"
      class="cc-card__close"
      aria-label="Close drawer"
      data-toggle={drawerId}
    >
      <span aria-hidden="true">×</span> Close
    </button>

    <!-- Card header: classification block -->
    <header class="cc-card__head">
      <div class="cc-card__class">
        <span class="cc-card__class-num">{dewey}</span>
        <span class="cc-card__class-lib">TTF · LAS VEGAS</span>
      </div>
      <div class="cc-card__filed">
        <span>FILED</span>
        <strong>{filed}</strong>
      </div>
    </header>

    <!-- Hole-punch at top-center -->
    <span class="cc-card__hole" aria-hidden="true"></span>

    <!-- Title block -->
    {cardEyebrow && <p class="cc-card__eyebrow">— {cardEyebrow} —</p>}
    <h3 class="cc-card__title">{cardTitle}</h3>

    <!-- Lined card body -->
    <div class="cc-card__body">
      <slot />
    </div>

    <!-- Optional ink stamp, bottom-right -->
    {stamp && (
      <span class="cc-card__stamp" aria-hidden="true">{stamp}</span>
    )}

    <!-- Hand-signed footer -->
    <footer class="cc-card__sign">
      <span class="cc-card__sign-line">— filed by Bill &amp; Lisa —</span>
    </footer>
  </div>
</div>

<style>
  /* ============================================================
     ONE DRAWER — wooden face + brass + index card slot
     ============================================================ */
  .cc-drawer {
    position: relative;
    /* the drawer face is a fixed-height wooden rectangle */
  }

  /* ------------------------------------------------------------
     The drawer FACE — wooden, brass label plate, brass pull
     ------------------------------------------------------------ */
  .cc-drawer__face {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    min-height: 132px;
    padding: 14px 18px 32px;
    border: 0;
    cursor: pointer;
    text-align: center;
    color: inherit;
    overflow: hidden;

    /* WOOD — diagonal grain on walnut */
    background:
      linear-gradient(
        96deg,
        rgba(0,0,0,0.18) 0%,
        rgba(0,0,0,0) 12%,
        rgba(255,255,255,0.04) 32%,
        rgba(0,0,0,0) 56%,
        rgba(0,0,0,0.22) 100%
      ),
      repeating-linear-gradient(
        92deg,
        rgba(0,0,0,0.07) 0 1px,
        transparent 1px 6px
      ),
      linear-gradient(180deg, #4a3220 0%, #3D2A1E 55%, #2a1c12 100%);

    /* Hard ink shadow on bottom edge — the drawer sits PROUD,
       casting a hard line onto the drawer below it. No soft modern shadow. */
    box-shadow:
      inset 0 1px 0 rgba(201,162,39,0.22),
      inset 0 -1px 0 rgba(0,0,0,0.55),
      inset 1px 0 0 rgba(0,0,0,0.45),
      inset -1px 0 0 rgba(0,0,0,0.45),
      0 2px 0 rgba(0,0,0,0.6);

    transition: transform 360ms cubic-bezier(.2,.7,.2,1),
                box-shadow 360ms ease;
  }

  /* Two brass-pin "screws" on the side cheeks of the drawer */
  .cc-drawer__face::before,
  .cc-drawer__face::after {
    content: "";
    position: absolute;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #f0d56a 0%, #C9A227 55%, #6b5314 100%);
    box-shadow: 0 1px 1px rgba(0,0,0,0.6);
    top: 50%; transform: translateY(-50%);
  }
  .cc-drawer__face::before { left: 6px; }
  .cc-drawer__face::after  { right: 6px; }

  /* Dewey number — small typewriter tag, top-left */
  .cc-drawer__dewey {
    position: absolute;
    top: 7px; left: 14px;
    font-family: "Oswald", Impact, sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    color: rgba(232, 213, 168, 0.72);
  }

  /* The brass label-holder plate (where the drawer label sits) */
  .cc-drawer__plate {
    display: inline-block;
    margin-top: 14px;
    padding: 6px 18px 5px;
    min-width: 65%;
    background:
      linear-gradient(180deg, #f0d56a 0%, #C9A227 45%, #8a6e1c 100%);
    border: 1px solid #6b5314;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.45),
      inset 0 -1px 0 rgba(0,0,0,0.35),
      0 1px 0 rgba(0,0,0,0.55);
  }
  .cc-drawer__plate-line {
    display: block;
    font-family: "Bodoni Moda", "Big Caslon", Georgia, serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #1A1614;
    line-height: 1;
  }
  .cc-drawer__plate-sub {
    display: block;
    font-family: "Bodoni Moda", Georgia, serif;
    font-style: italic;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    color: #1A1614;
    margin-top: 2px;
    text-transform: lowercase;
  }

  /* Brass pull at the bottom of the drawer */
  .cc-drawer__pull {
    position: absolute;
    left: 50%; bottom: 8px;
    transform: translateX(-50%);
    width: 56px;
    height: 16px;
    display: block;
    background:
      radial-gradient(ellipse at 50% 25%, #f0d56a 0%, #C9A227 45%, #6b5314 100%);
    border: 1px solid #4a3a0e;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.4),
      0 1px 0 rgba(0,0,0,0.55);
  }
  .cc-drawer__pull-bar {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    width: 32px; height: 4px;
    background: linear-gradient(180deg, #8a6e1c 0%, #4a3a0e 100%);
    box-shadow: inset 0 1px 0 rgba(0,0,0,0.45);
  }

  /* Hover/focus — drawer eases out a hair, brass brightens */
  .cc-drawer__face:hover,
  .cc-drawer__face:focus-visible {
    transform: translateZ(0) translateY(-2px);
    outline: 0;
  }
  .cc-drawer__face:focus-visible {
    box-shadow:
      inset 0 0 0 2px var(--color-brass),
      0 2px 0 rgba(0,0,0,0.6);
  }

  /* OPEN STATE — the drawer face slides OUTWARD off its cabinet slot */
  .cc-drawer.is-open .cc-drawer__face {
    transform: translateY(14px);
    box-shadow:
      inset 0 1px 0 rgba(201,162,39,0.35),
      inset 0 -1px 0 rgba(0,0,0,0.55),
      0 8px 0 rgba(0,0,0,0.55),
      0 14px 24px rgba(0,0,0,0.45);
  }

  /* ------------------------------------------------------------
     The INDEX CARD that slides out of the drawer
     ------------------------------------------------------------ */
  .cc-card {
    position: absolute;
    /* Anchored so it APPEARS to come out of this drawer slot */
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(-20px) scale(0.98);
    width: min(560px, calc(100vw - 40px));
    background: #f5ecd2;
    color: #1A1614;

    padding: 28px 30px 64px;
    z-index: 5;

    /* hard ink-offset shadow, NOT modern soft shadow */
    box-shadow:
      0 0 0 1px rgba(26,22,20,0.18),
      6px 6px 0 rgba(26,22,20,0.28),
      10px 10px 0 rgba(26,22,20,0.10);

    /* Card stock — faint horizontal lines like an old library card */
    background-image:
      linear-gradient(
        180deg,
        rgba(26,22,20,0) 0%,
        rgba(26,22,20,0) 92px,
        rgba(31,77,63,0.18) 92px,
        rgba(31,77,63,0.18) 93px,
        rgba(26,22,20,0) 93px
      ),
      repeating-linear-gradient(
        to bottom,
        transparent 0,
        transparent 27px,
        rgba(31,77,63,0.16) 27px,
        rgba(31,77,63,0.16) 28px
      );
    background-size: 100% 100%, 100% 28px;
    background-position: 0 0, 0 110px;

    opacity: 0;
    pointer-events: none;
    transition:
      transform 380ms cubic-bezier(.2,.7,.2,1),
      opacity 280ms ease;
  }

  .cc-drawer.is-open .cc-card {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0) scale(1);
  }
  .cc-drawer.is-open .cc-card[hidden] {
    /* astro renders `hidden`; we override at open time */
    display: block;
  }

  /* Slide direction tweak per column — center column comes straight down,
     left column drifts slightly right, right column drifts slightly left,
     so a card from a corner drawer doesn't run off-screen */
  .cc-drawer--col-1 .cc-card { transform: translateX(-30%) translateY(-20px) scale(0.98); }
  .cc-drawer--col-1.is-open .cc-card { transform: translateX(-30%) translateY(0) scale(1); }
  .cc-drawer--col-3 .cc-card { transform: translateX(-70%) translateY(-20px) scale(0.98); }
  .cc-drawer--col-3.is-open .cc-card { transform: translateX(-70%) translateY(0) scale(1); }

  /* Close button */
  .cc-card__close {
    position: absolute;
    top: 10px; right: 12px;
    background: transparent;
    border: 1px solid rgba(26,22,20,0.45);
    padding: 3px 9px 4px;
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.65rem;
    color: #1A1614;
    cursor: pointer;
  }
  .cc-card__close:hover { background: rgba(158,42,43,0.12); }
  .cc-card__close span { font-size: 1rem; line-height: 0; margin-right: 4px; }

  /* Classification header — looks like a real catalog card */
  .cc-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: 1.2px solid rgba(26,22,20,0.4);
    padding-bottom: 6px;
    margin-bottom: 24px;
  }
  .cc-card__class-num {
    display: block;
    font-family: "Oswald", sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    color: #9E2A2B;
    line-height: 1;
  }
  .cc-card__class-lib {
    display: block;
    font-family: "Oswald", sans-serif;
    font-size: 0.55rem;
    letter-spacing: 0.32em;
    color: rgba(26,22,20,0.65);
    margin-top: 4px;
  }
  .cc-card__filed {
    text-align: right;
    font-family: "Oswald", sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    color: rgba(26,22,20,0.7);
    text-transform: uppercase;
  }
  .cc-card__filed strong {
    display: block;
    color: #1A1614;
    font-weight: 600;
    margin-top: 2px;
    letter-spacing: 0.15em;
  }

  /* The hole-punch at top center */
  .cc-card__hole {
    position: absolute;
    top: 60px; left: 50%;
    transform: translateX(-50%);
    width: 10px; height: 10px;
    background: var(--color-cream);
    border: 1.4px solid rgba(26,22,20,0.55);
    border-radius: 50%;
    box-shadow: inset 0 1px 1.5px rgba(26,22,20,0.35);
  }

  .cc-card__eyebrow {
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.65rem;
    color: #1F4D3F;
    text-align: center;
    margin: 0 0 6px;
  }
  .cc-card__title {
    font-family: "Bodoni Moda", Georgia, serif;
    font-weight: 700;
    font-size: 1.55rem;
    line-height: 1.05;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #1A1614;
    margin: 0 0 18px;
  }

  /* The lined body — typewritten copy */
  .cc-card__body {
    font-family: "EB Garamond", Georgia, serif;
    font-size: 1rem;
    line-height: 28px;          /* must match the line-rule background */
    color: #1A1614;
  }
  .cc-card__body :global(p) {
    margin: 0 0 28px;
  }
  .cc-card__body :global(p:last-child) { margin-bottom: 0; }
  .cc-card__body :global(strong) {
    font-family: "Oswald", sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-weight: 500;
    font-size: 0.78rem;
    color: #9E2A2B;
  }
  .cc-card__body :global(a) {
    color: #9E2A2B;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  /* Ink stamp — diagonal red, bottom-right */
  .cc-card__stamp {
    position: absolute;
    right: 22px;
    bottom: 38px;
    font-family: "Oswald", sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.22em;
    color: rgba(158,42,43,0.78);
    border: 1.6px solid rgba(158,42,43,0.78);
    padding: 4px 10px 3px;
    text-transform: uppercase;
    transform: rotate(-9deg);
    pointer-events: none;
    /* faint ink-bleed feel */
    text-shadow: 0.5px 0 0 rgba(158,42,43,0.4);
  }

  /* Hand-signed footer line */
  .cc-card__sign {
    position: absolute;
    bottom: 14px;
    left: 30px; right: 30px;
    text-align: center;
  }
  .cc-card__sign-line {
    font-family: "Permanent Marker", cursive;
    font-size: 0.85rem;
    color: rgba(26,22,20,0.72);
  }

  /* When the card is OPEN we still want hidden attr cleared.
     Astro emits `hidden` as a real attribute. JS toggles it. */
  .cc-card:not([hidden]) { display: block; }

  /* Reduced motion: snap, don't slide */
  @media (prefers-reduced-motion: reduce) {
    .cc-drawer__face,
    .cc-card { transition: none !important; }
  }
</style>
