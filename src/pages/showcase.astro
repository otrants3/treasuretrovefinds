---
import Layout from "../layouts/Layout.astro";
import SiteBar from "../components/SiteBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import items from "../data/cabinet.json";

// 12 hero items, arranged in 4 shelves × 3 slots. Pick the items
// whose pen-and-ink plates render most distinctively. Order is
// [row][col] reading left-to-right, top-to-bottom.
const SHELF_LAYOUT = [
  ["perfume-bottle", "candy-dish-box", "cobalt-bottle"],   // shelf 1 — glass + jewelry
  ["ge-fan", "brookins-can", "pulleys"],                   // shelf 2 — curiosities
  ["krueger-beer", "pepsi-crate", "shasta-bitters"],       // shelf 3 — advertising
  ["dress-form", "teddy-school-desk", "raggedy-anns"],     // shelf 4 — textiles + toys
];

const bySlug = new Map((items as any[]).map((i) => [i.slug, i]));
const grid = SHELF_LAYOUT.map((row) => row.map((slug) => bySlug.get(slug)).filter(Boolean));
const allShown = grid.flat();
---

<Layout
  title="The Showcase · TreasureTroveFinds · Step Into the Cabinet"
  description="Step into the cabinet. A scene of twelve hand-picked pieces from Bill's booth, rendered as engraved catalog plates and arranged on the shelves. Click any to see the real piece."
>
  <SiteBar />

  <section class="sc-hero">
    <p class="ttf-label sc-hero__eyebrow">— STEP INTO THE CABINET —</p>
    <h1 class="sc-hero__title">The Showcase</h1>
    <div class="sc-hero__rule"></div>
    <p class="sc-hero__sub">
      Twelve pieces from the booth, rendered as the catalog plates Bill might have drawn himself, arranged on the emerald-felt shelves. <em>Click any plate for the real piece.</em>
    </p>
  </section>

  <section class="sc-stage">
    <div class="sc-stage__inner">
      <div class="sc-cabinet">
        <img class="sc-cabinet__bg" src="/cabinet/showcase/cabinet-v2-emerald.png" alt="Open antique walnut display cabinet with emerald-felt shelves" />
        <div class="sc-cabinet__shelves" aria-label="Cabinet shelves with items">
          {grid.map((row, ri) => (
            <div class={`sc-shelf sc-shelf--${ri + 1}`}>
              {row.map((it: any, ci) => (
                <button
                  type="button"
                  class={`sc-slot sc-slot--${ci + 1}`}
                  data-slug={it.slug}
                  style={`--tilt: ${[-1, 0.5, -0.5][ci]}deg;`}
                  aria-label={`Open ${it.displayName}`}
                >
                  <img
                    class="sc-slot__plate"
                    src={it.hasPlate === false ? it.thumb : `/cabinet/plates/${it.slug}.png`}
                    alt={it.displayName}
                    loading="lazy"
                  />
                  <span class="sc-slot__caption">
                    <span class="sc-slot__name">{it.itemName || it.displayName}</span>
                    <span class="sc-slot__price">{it.price}</span>
                  </span>
                </button>
              ))}
            </div>
          ))}
        </div>
      </div>

      <p class="sc-stage__foot">
        <a class="sc-stage__cta" href="/cabinet">Browse all 24 pieces in the cabinet →</a>
      </p>
    </div>
  </section>

  <!-- Reuse the same modal pattern from /cabinet -->
  <dialog class="cab-modal" id="cabModal" aria-labelledby="cabModalTitle">
    <button type="button" class="cab-modal__close" data-modal-close aria-label="Close">×</button>
    <div class="cab-modal__inner">
      <figure class="cab-modal__photo-wrap">
        <img class="cab-modal__photo" alt="" />
      </figure>
      <div class="cab-modal__body">
        <p class="ttf-label cab-modal__category"></p>
        <h2 class="cab-modal__title" id="cabModalTitle"></h2>
        <div class="cab-modal__rule"></div>
        <p class="cab-modal__blurb"></p>

        <aside class="cab-modal__tag">
          <span class="cab-modal__tag-hole" aria-hidden="true"></span>
          <p class="cab-modal__tag-eyebrow">— Bill's Tag —</p>
          <p class="cab-modal__tag-note"></p>
          <p class="cab-modal__tag-price"></p>
        </aside>

        <div class="cab-modal__cta">
          <a class="ttf-btn ttf-btn-primary" href="tel:+15164462693">Ring Bill to Hold It</a>
          <a class="ttf-btn ttf-btn-secondary" href="/#find">Get Directions</a>
        </div>
      </div>
    </div>
  </dialog>

  <SiteFooter />

  <script is:inline define:vars={{ items: allShown }}>
    window.__CAB_ITEMS__ = items;
  </script>
  <script>
    const modal = document.getElementById("cabModal") as HTMLDialogElement | null;
    const closeBtn = document.querySelector<HTMLButtonElement>("[data-modal-close]");
    const photo = modal?.querySelector<HTMLImageElement>(".cab-modal__photo");
    const cat = modal?.querySelector<HTMLElement>(".cab-modal__category");
    const title = modal?.querySelector<HTMLElement>(".cab-modal__title");
    const blurb = modal?.querySelector<HTMLElement>(".cab-modal__blurb");
    const tagNote = modal?.querySelector<HTMLElement>(".cab-modal__tag-note");
    const tagPrice = modal?.querySelector<HTMLElement>(".cab-modal__tag-price");

    function open(slug: string) {
      const all = (window as any).__CAB_ITEMS__ || [];
      const item = all.find((i: any) => i.slug === slug);
      if (!item || !modal) return;
      if (photo) { photo.src = item.image; photo.alt = item.displayName; }
      if (cat) cat.textContent = `— ${item.category} —`;
      if (title) title.textContent = item.displayName;
      if (blurb) blurb.textContent = item.shortBlurb;
      if (tagNote) tagNote.innerHTML = (item.billsNote || "").replace(/\s*\/\s*/g, "<br/>");
      if (tagPrice) tagPrice.textContent = item.price;
      modal.showModal();
      document.body.style.overflow = "hidden";
    }
    function close() { if (modal) { modal.close(); document.body.style.overflow = ""; } }
    document.querySelectorAll<HTMLButtonElement>(".sc-slot").forEach((b) => {
      b.addEventListener("click", () => open(b.dataset.slug || ""));
    });
    closeBtn?.addEventListener("click", close);
    modal?.addEventListener("click", (e) => { if (e.target === modal) close(); });
  </script>

  <style>
    body { padding-top: 48px; }
    @media (max-width: 720px) { body { padding-top: 42px; } }

    /* ============ HERO ============ */
    .sc-hero {
      padding: 4rem 1.5rem 1.5rem;
      text-align: center;
      background: var(--color-cream);
    }
    .sc-hero__eyebrow { color: var(--color-brass); margin: 0 0 0.5rem; }
    .sc-hero__title {
      font-family: var(--font-display);
      color: var(--color-ink);
      font-size: clamp(44px, 7vw, 84px);
      line-height: 0.9; margin: 0.25rem 0 0.75rem;
      text-shadow: 2px 3px 0 rgba(26,22,20,0.08);
    }
    .sc-hero__rule {
      width: 84px; height: 2px; background: var(--color-brass);
      margin: 0.5rem auto 1.25rem; position: relative;
    }
    .sc-hero__rule::before {
      content: "✦"; position: absolute; left: 50%; top: 50%;
      transform: translate(-50%, -50%); color: var(--color-brass);
      background: var(--color-cream); padding: 0 10px; font-size: 16px;
    }
    .sc-hero__sub {
      font-family: var(--font-serif); color: var(--color-ink);
      font-size: clamp(15px, 1.5vw, 17px); line-height: 1.6;
      max-width: 640px; margin: 0 auto;
    }

    /* ============ STAGE — the cabinet ============ */
    .sc-stage {
      padding: 2rem 1.5rem 5rem;
      background:
        radial-gradient(ellipse at top, rgba(31,77,63,0.06), transparent 60%),
        var(--color-cream);
    }
    .sc-stage__inner {
      max-width: 1240px; margin: 0 auto;
    }
    .sc-cabinet {
      position: relative;
      width: 100%;
      box-shadow: 0 30px 80px rgba(0,0,0,0.35);
    }
    .sc-cabinet__bg {
      display: block; width: 100%; height: auto;
      filter: saturate(0.96) contrast(1.04);
    }
    /* Overlay shelf grid positioned over the cabinet image. Numbers are
       tuned to the v2-emerald cabinet illustration's interior. */
    .sc-cabinet__shelves {
      position: absolute;
      /* Cabinet interior bounding box (percentages of the bg image) */
      top: 17%;   bottom: 12%;
      left: 11%;  right: 11%;
      display: grid;
      grid-template-rows: repeat(4, 1fr);
      gap: 0.25rem;
    }
    .sc-shelf {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
      align-items: end;
    }
    .sc-slot {
      position: relative;
      background: transparent; border: 0; padding: 0; margin: 0;
      cursor: pointer;
      display: flex; flex-direction: column; align-items: center; justify-content: flex-end;
      transition: transform 220ms ease;
      transform: rotate(var(--tilt, 0));
      width: 100%; height: 100%;
    }
    .sc-slot:hover { transform: rotate(0) scale(1.12); z-index: 2; }
    .sc-slot:focus-visible { outline: 2px dashed var(--color-brass); outline-offset: 4px; }
    .sc-slot__plate {
      max-width: 78%; max-height: 78%;
      width: auto; height: auto;
      object-fit: contain;
      display: block;
      /* multiply blend drops the cream paper bg onto the emerald felt
         shelves, so only the black ink line-drawing floats on the felt */
      mix-blend-mode: multiply;
      filter: contrast(1.15) brightness(0.95);
    }
    /* Brass display "easel" plinth under each item, like a museum stand */
    .sc-slot::after {
      content: "";
      position: absolute; bottom: 4%;
      left: 35%; right: 35%;
      height: 3px;
      background: linear-gradient(180deg, rgba(201,162,39,0.55), rgba(201,162,39,0));
      border-radius: 50%;
      filter: blur(2px);
      pointer-events: none;
    }
    .sc-slot__caption {
      position: absolute; bottom: -1px; left: 50%;
      transform: translateX(-50%) translateY(100%);
      display: flex; flex-direction: column; align-items: center;
      gap: 1px; padding: 0.45rem 0.6rem;
      background: rgba(26,22,20,0.92);
      border: 1px solid var(--color-brass);
      color: var(--color-cream);
      font-family: var(--font-label);
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-size: 0.6rem;
      white-space: nowrap;
      opacity: 0; pointer-events: none;
      transition: opacity 180ms ease, transform 180ms ease;
      z-index: 3;
    }
    .sc-slot__price { color: var(--color-brass); font-size: 0.7rem; letter-spacing: 0.1em; }
    .sc-slot:hover .sc-slot__caption,
    .sc-slot:focus-visible .sc-slot__caption {
      opacity: 1;
      transform: translateX(-50%) translateY(110%);
    }

    .sc-stage__foot {
      margin: 2.5rem 0 0; text-align: center;
    }
    .sc-stage__cta {
      font-family: var(--font-label); letter-spacing: 0.24em;
      text-transform: uppercase; font-size: 0.78rem;
      color: var(--color-walnut); text-decoration: none;
      padding-bottom: 4px; border-bottom: 1.5px solid var(--color-brass);
    }
    .sc-stage__cta:hover { color: var(--color-buddy-red); }

    /* ============ MODAL (lifted from /cabinet styles) ============ */
    .cab-modal[open] { display: flex; flex-direction: column; align-items: center; justify-content: center; }
    .cab-modal {
      padding: 0; border: 0; background: transparent;
      width: 100%; max-width: none; max-height: none;
      inset: 0; margin: 0; height: 100vh;
    }
    .cab-modal::backdrop {
      background: rgba(14, 10, 7, 0.82);
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    }
    .cab-modal[open] .cab-modal__inner {
      animation: cab-modal-in 360ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }
    @keyframes cab-modal-in {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .cab-modal__inner {
      position: relative; width: min(1100px, 94vw); max-height: 90vh;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      box-shadow: 0 30px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(201,162,39,0.4);
      display: grid; grid-template-columns: 1.05fr 1fr; overflow: hidden;
    }
    .cab-modal__inner::before, .cab-modal__inner::after {
      content: ""; position: absolute; width: 28px; height: 28px;
      border: 1.5px solid var(--color-brass); pointer-events: none; z-index: 3;
    }
    .cab-modal__inner::before { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
    .cab-modal__inner::after  { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }
    .cab-modal__close {
      position: absolute; top: 14px; right: 14px;
      width: 38px; height: 38px;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      font-family: var(--font-display); font-size: 22px; line-height: 1;
      color: var(--color-ink); cursor: pointer; z-index: 5;
      box-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    }
    .cab-modal__close:hover { background: var(--color-buddy-red); color: var(--color-cream); border-color: var(--color-buddy-red); }
    .cab-modal__photo-wrap {
      margin: 0; background: var(--color-walnut);
      position: relative; overflow: hidden; min-height: 100%;
    }
    .cab-modal__photo {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.95) contrast(1.04); display: block;
    }
    .cab-modal__body {
      padding: 2.25rem 2rem 1.75rem; overflow-y: auto;
      display: flex; flex-direction: column; gap: 0.75rem;
    }
    .cab-modal__category { color: var(--color-brass); margin: 0; }
    .cab-modal__title {
      font-family: var(--font-billing); font-weight: 700; color: var(--color-ink);
      font-size: clamp(26px, 3vw, 38px); line-height: 1.05; margin: 0;
    }
    .cab-modal__rule {
      width: 64px; height: 2px; background: var(--color-brass);
      margin: 0.25rem 0 0.5rem;
    }
    .cab-modal__blurb {
      font-family: var(--font-billing); font-style: italic;
      color: var(--color-ink); font-size: 17px; line-height: 1.55; margin: 0;
    }
    .cab-modal__tag {
      position: relative; margin: 1rem 0 0;
      padding: 1.6rem 1.1rem 1.1rem;
      background: var(--color-tag-paper);
      background-image:
        radial-gradient(rgba(61,42,30,0.10) 1px, transparent 1.2px),
        radial-gradient(rgba(61,42,30,0.06) 1px, transparent 1.2px);
      background-size: 5px 5px, 9px 9px;
      background-position: 0 0, 2px 2px;
      border: 1px solid rgba(61,42,30,0.45);
      box-shadow: 4px 5px 0 rgba(26,22,20,0.22);
      transform: rotate(-1deg);
    }
    .cab-modal__tag-hole {
      position: absolute; top: 8px; left: 50%;
      transform: translateX(-50%);
      width: 12px; height: 12px; border-radius: 50%;
      background: var(--color-cream);
      box-shadow: inset 0 0 0 1.8px rgba(61,42,30,0.75);
    }
    .cab-modal__tag-eyebrow {
      font-family: var(--font-label); letter-spacing: 0.22em;
      text-transform: uppercase; color: var(--color-walnut);
      font-size: 0.66rem; margin: 0 0 0.6rem; text-align: center;
    }
    .cab-modal__tag-note {
      font-family: var(--font-hand); color: var(--color-ink);
      font-size: 17px; line-height: 1.5; margin: 0 0 0.5rem;
    }
    .cab-modal__tag-price {
      font-family: var(--font-display); color: var(--color-buddy-red);
      font-size: 28px; line-height: 1; margin: 0.5rem 0 0;
      text-shadow: 1px 1px 0 rgba(26,22,20,0.16);
    }
    .cab-modal__cta { display: flex; gap: 0.6rem; flex-wrap: wrap; margin: 1rem 0 0; }

    @media (max-width: 820px) {
      .cab-modal__inner { grid-template-columns: 1fr; max-height: 92vh; }
      .cab-modal__photo-wrap { max-height: 45vh; }
      .cab-modal__body { padding: 1.5rem 1.25rem 1.25rem; }
      .sc-slot__caption { display: none; }
    }
    @media (max-width: 520px) {
      /* Cabinet interior bounds shift slightly on tall narrow screens */
      .sc-cabinet__shelves { top: 17%; bottom: 13%; left: 13%; right: 13%; }
    }
  </style>
</Layout>
