---
/**
 * ReelHeader.astro — Boxing-billing show-bill section header.
 * Roman-numeral REEL, brass rules above/below, billing italic subhead.
 */
interface Props {
  numeral: string;       // "I" | "II" | "III" | "IV" | "V"
  kicker?: string;       // "— FEATURING —" / "— FROM THE FLOOR —"
  title: string;         // "EVERY PIECE HAS A RECORD"
  subhead?: string;      // billing italic
}
const { numeral, kicker = "— FEATURING —", title, subhead } = Astro.props;
---

<header class="reel-header">
  <div class="reel-tag">
    <span class="reel-tag-rule"></span>
    <span class="reel-tag-text">REEL&nbsp;{numeral}</span>
    <span class="reel-tag-rule"></span>
  </div>

  <div class="kicker">{kicker}</div>

  <h2 class="reel-title">{title}</h2>

  {subhead && <p class="reel-subhead">{subhead}</p>}

  <div class="reel-rules" aria-hidden="true">
    <span class="r-rule top"></span>
    <span class="r-diamond">◆</span>
    <span class="r-rule bottom"></span>
  </div>
</header>

<style>
  .reel-header {
    text-align: center;
    margin: 0 auto;
    max-width: 48rem;
    padding: 1.25rem 1rem 0.5rem;
  }

  .reel-tag {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    margin-bottom: 0.6rem;
  }
  .reel-tag-rule {
    flex: 0 0 3rem;
    height: 1px;
    background: var(--color-brass);
  }
  .reel-tag-text {
    font-family: var(--font-label);
    font-size: 0.78rem;
    letter-spacing: 0.42em;
    color: var(--color-brass);
  }

  .kicker {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-walnut);
    font-size: 1rem;
    margin-bottom: 0.35rem;
    letter-spacing: 0.04em;
  }

  .reel-title {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: clamp(2.1rem, 5.5vw, 3.6rem);
    line-height: 0.95;
    letter-spacing: 0.012em;
    text-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    margin: 0 auto;
    max-width: 30ch;
  }

  .reel-subhead {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 1.05rem;
    margin: 0.55rem auto 0;
    max-width: 40rem;
    line-height: 1.45;
  }

  .reel-rules {
    margin: 0.95rem auto 0;
    max-width: 22rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    position: relative;
  }
  .r-rule {
    flex: 1;
    height: 0;
    border-top: 1.4px solid var(--color-brass);
    position: relative;
  }
  .r-rule.top::after {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 4px;
    border-top: 1px solid var(--color-brass);
    opacity: 0.55;
  }
  .r-rule.bottom::after {
    content: "";
    position: absolute;
    left: 0; right: 0; top: 4px;
    border-top: 1px solid var(--color-brass);
    opacity: 0.55;
  }
  .r-diamond {
    color: var(--color-brass);
    font-size: 0.85rem;
  }
</style>
