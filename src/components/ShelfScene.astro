---
/**
 * ShelfScene — a real photo of a booth shelf, with one or more
 * handwritten paper-tag callouts pinned to specific items.
 * Replaces the abstract "departments grid" for The Collection.
 *
 * Tag positions are passed as %-coordinates so they survive responsive resizing.
 */
interface Tag {
  era: string;
  item: string;
  note?: string;
  price?: string;
  top: string;       // "12%"
  left: string;      // "60%"
  rotate?: number;
}
interface Props {
  caption: string;       // e.g. "Shelf I — Toys & Pressed Steel"
  byline?: string;       // e.g. "Things built to outlive their owners."
  photo: string;
  tags?: Tag[];
}
const { caption, byline, photo, tags = [] } = Astro.props;
---

<article class="shelf">
  <div class="shelf__plaque">
    <span class="shelf__caption">{caption}</span>
    {byline && <span class="shelf__byline">{byline}</span>}
  </div>

  <div class="shelf__scene">
    <img src={photo} alt={caption} loading="lazy" />
    <div class="shelf__shadow" aria-hidden="true"></div>

    {tags.map((t) => (
      <span
        class="shelf__tag"
        style={`top: ${t.top}; left: ${t.left}; transform: rotate(${t.rotate ?? -4}deg);`}
      >
        <span class="shelf__tag-thread"></span>
        <span class="shelf__tag-hole"></span>
        <span class="shelf__tag-era">{t.era}</span>
        <strong class="shelf__tag-item">{t.item}</strong>
        {t.note && <span class="shelf__tag-note">{t.note}</span>}
        {t.price && <span class="shelf__tag-price">{t.price.startsWith("$") ? t.price : `$ ${t.price}`}</span>}
      </span>
    ))}
  </div>
</article>

<style>
  .shelf {
    position: relative;
    margin: 0 0 32px;
    background:
      linear-gradient(135deg, #4a2f1f 0%, #3D2A1E 50%, #2a1c12 100%);
    padding: 18px 18px 22px;
    box-shadow:
      inset 0 0 0 2px rgba(201,162,39,0.4),
      inset 0 0 0 4px var(--color-walnut),
      inset 0 0 50px rgba(0,0,0,0.5),
      0 6px 0 rgba(0,0,0,0.3);
  }

  .shelf__plaque {
    margin: 0 0 14px;
    background: linear-gradient(180deg,
      #d8b647 0%, #C9A227 40%, #a07e1d 100%);
    color: var(--color-walnut);
    padding: 8px 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 14px;
    justify-content: space-between;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.3),
      inset 0 -2px 0 rgba(0,0,0,0.25),
      0 2px 0 rgba(0,0,0,0.4);
    position: relative;
  }
  .shelf__plaque::before, .shelf__plaque::after {
    content: "";
    position: absolute;
    width: 7px; height: 7px;
    background: var(--color-walnut);
    border-radius: 50%;
    top: 50%; transform: translateY(-50%);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.3);
  }
  .shelf__plaque::before { left: 6px; }
  .shelf__plaque::after  { right: 6px; }

  .shelf__caption {
    font-family: var(--font-billing);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 17px;
    padding-left: 22px;
  }
  .shelf__byline {
    font-family: var(--font-billing);
    font-style: italic;
    font-size: 14px;
    color: rgba(61,42,30,0.78);
    padding-right: 22px;
  }

  .shelf__scene {
    position: relative;
    background: var(--color-walnut);
    border: 1px solid rgba(201,162,39,0.4);
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .shelf__scene img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.85) sepia(0.08) contrast(1.04);
    display: block;
  }
  .shelf__shadow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.45) 100%),
      linear-gradient(180deg, rgba(0,0,0,0.25), transparent 30%, transparent 70%, rgba(0,0,0,0.35));
    pointer-events: none;
  }

  /* The pinned paper tags */
  .shelf__tag {
    position: absolute;
    background: var(--color-tag-paper);
    background-image:
      radial-gradient(rgba(61,42,30,0.08) 1px, transparent 1px);
    background-size: 4px 4px;
    color: var(--color-ink);
    border: 1px solid rgba(61,42,30,0.4);
    box-shadow: 4px 5px 0 rgba(0,0,0,0.45);
    padding: 18px 14px 10px;
    width: 180px;
    font-family: var(--font-hand);
    line-height: 1.25;
    display: flex;
    flex-direction: column;
    gap: 2px;
    transition: transform 240ms cubic-bezier(0.3, 0.8, 0.4, 1);
  }
  .shelf__tag:hover {
    transform: translateY(-4px) rotate(0deg) scale(1.04) !important;
    z-index: 5;
    box-shadow: 5px 7px 0 rgba(0,0,0,0.55);
  }
  .shelf__tag-thread {
    position: absolute;
    top: -18px; left: 50%;
    transform: translateX(-50%) rotate(2deg);
    width: 1.5px; height: 22px;
    background: var(--color-brass);
  }
  .shelf__tag-hole {
    position: absolute;
    top: 6px; left: 50%;
    transform: translateX(-50%);
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--color-cream);
    box-shadow: inset 0 0 0 1px rgba(61,42,30,0.6);
  }
  .shelf__tag-era {
    font-size: 11px;
    color: var(--color-walnut);
    margin-top: 4px;
  }
  .shelf__tag-item {
    font-weight: 400;
    font-size: 15px;
    line-height: 1.15;
  }
  .shelf__tag-note {
    font-size: 12px;
    color: var(--color-walnut);
  }
  .shelf__tag-price {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 22px;
    letter-spacing: 0.02em;
    text-shadow: 1px 1px 0 rgba(26,22,20,0.18);
    margin-top: 4px;
  }

  @media (max-width: 720px) {
    .shelf__tag { width: 130px; padding: 14px 10px 8px; }
    .shelf__tag-item { font-size: 13px; }
    .shelf__tag-price { font-size: 18px; }
  }
</style>
