---
import Layout from "../../layouts/Layout.astro";

const BOOTH = {
  name: "Paradise Mall · Booth #18",
  street: "3565 E. Flamingo Road",
  city: "Las Vegas, Nevada 89121",
  phone: "(516) 446-2693",
  phoneHref: "tel:+15164462693",
  hoursLine: "Open daily, 10 'til 6",
  billLine: "Bill works the booth Weds & Sun",
  mapHref:
    "https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121",
};
---

<Layout title="Treasure Trove Finds — Step Into the Cabinet">
  <!-- ============================================================
       HERO — A REAL antique curio cabinet. Doors closed, then open.
       Photo crossfade on load. No CSS-drawn furniture.
       ============================================================ -->
  <section class="gm-hero" aria-label="The cabinet">
    <!-- Background photo: the dark ornate cabinet, doors closed -->
    <img
      class="gm-hero__img gm-hero__img--closed"
      src="/cabinet/pexels-36901179.jpg"
      alt="Antique walnut curio cabinet with ornate glass doors and brass handles, warmly lit from within"
      fetchpriority="high"
    />
    <!-- Background photo: cabinet with the doors swung open, shelves of antique bottles visible -->
    <img
      class="gm-hero__img gm-hero__img--open"
      src="/cabinet/pexels-13207903.jpg"
      alt="The same cabinet with one door open, shelves of antique apothecary bottles visible inside"
    />
    <!-- darken overlay for legibility -->
    <div class="gm-hero__vignette" aria-hidden="true"></div>

    <!-- Fixed brass HUD on top -->
    <header class="gm-hud">
      <a class="gm-hud__brand" href="#top">
        <span class="gm-hud__eyebrow">— Booth #18 · Paradise Mall —</span>
        <span class="gm-hud__mark">TREASURE TROVE FINDS</span>
      </a>
      <nav class="gm-hud__nav" aria-label="Shelves">
        <a href="#story">Story</a>
        <span aria-hidden="true">·</span>
        <a href="#lineup">Lineup</a>
        <span aria-hidden="true">·</span>
        <a href="#record">The Record</a>
        <span aria-hidden="true">·</span>
        <a href="#joint">Find Us</a>
      </nav>
      <a class="gm-hud__phone" href={BOOTH.phoneHref}>{BOOTH.phone}</a>
    </header>

    <!-- Hero billing card -->
    <div class="gm-hero__billing" id="top">
      <p class="gm-hero__plate">— Now Opening · Tonight at Booth #18 —</p>
      <h1 class="gm-hero__headline">Step into the cabinet.</h1>
      <p class="gm-hero__sub">
        A back-room of American oddments — pieces back to 1850 —
        kept by Bill &amp; Lisa since '73.
      </p>
      <div class="gm-hero__ctas">
        <a class="gm-btn gm-btn--primary" href="#joint">Drop in — Booth #18</a>
        <a class="gm-btn gm-btn--secondary" href={BOOTH.phoneHref}>Ring Bill up · {BOOTH.phone}</a>
      </div>
      <p class="gm-hero__cue">scroll · the doors are open <span aria-hidden="true">↓</span></p>
    </div>
  </section>

  <!-- ============================================================
       SHELF I — HOW WE GOT HERE
       Backdrop = real corner-shelf photo, content overlays
       ============================================================ -->
  <section class="gm-shelf" id="story" aria-label="How We Got Here">
    <img class="gm-shelf__bg" src="/cabinet/pexels-9704134.jpg" alt="" />
    <div class="gm-shelf__veil"></div>
    <span class="gm-shelf__nameplate">
      <span class="gm-shelf__no">Shelf I</span>
      <span class="gm-shelf__name">How We Got Here</span>
    </span>

    <div class="gm-shelf__content">
      <div class="gm-story">
        <h2 class="gm-story__pull">
          "Bill wasn't collecting antiques.
          <em>He was collecting the stories behind the numbers.</em>"
        </h2>
        <p>
          Bill caught the bug the way most boys did — a stack of baseball cards.
          But the <em>players</em> weren't the point. The <strong>numbers on the back</strong>
          were. Years, batting averages, stadium names — the history hiding inside
          the data. He'd memorize them. He'd cross-reference. He'd want to know
          what else was happening the year somebody hit .357.
        </p>
        <p>
          That curiosity never quit. Cards became bottles. Bottles became signs.
          Signs became toys. Toys became <em>anything with a story he hadn't heard yet.</em>
          Not just antique. Not just vintage. <em>Nostalgic</em> — pieces with a hold
          on the rooms they came out of.
        </p>
        <p>
          Lisa came along, made it a life. Walk into Booth #18 and point at anything.
          Bill <strong>will not hesitate.</strong> He'll tell you the year, the maker,
          what it sold for new, who probably bought it first, and what was on the
          radio in America that month — animated, hands moving, leaning on the case.
          <em>This is not your sixth-grade Social Studies teacher's lecture.</em>
        </p>
        <p class="gm-story__sig">— <span>Bill &amp; Lisa</span></p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SHELF II — TONIGHT'S LINEUP (real items overlaid on a real cabinet shot)
       ============================================================ -->
  <section class="gm-shelf gm-shelf--lineup" id="lineup" aria-label="Tonight's Lineup">
    <img class="gm-shelf__bg" src="/cabinet/pexels-34408722.jpg" alt="" />
    <div class="gm-shelf__veil"></div>
    <span class="gm-shelf__nameplate">
      <span class="gm-shelf__no">Shelf II</span>
      <span class="gm-shelf__name">Tonight's Lineup</span>
    </span>

    <div class="gm-shelf__content">
      <p class="gm-lineup__eyebrow">— Currently on the counter —</p>
      <h2 class="gm-lineup__title">Four pieces, hand-picked.</h2>
      <p class="gm-lineup__sub"><em>The lineup turns over fast.</em></p>

      <div class="gm-lineup__grid">
        <article class="gm-plate">
          <div class="gm-plate__frame">
            <img src="/photos/tag-perfume-bottle.jpg" alt="1934 Ludwig Scherk Renaissance perfume bottle on Bill's handwritten tag" />
            <span class="gm-plate__no">No. 01</span>
          </div>
          <p class="gm-plate__era">1934 · German silvered metalwork</p>
          <h3 class="gm-plate__name">Ludwig Scherk Perfume Bottle</h3>
          <p class="gm-plate__note">w/ Marie Antoinette miniature</p>
          <p class="gm-plate__price">$ 225.00</p>
        </article>

        <article class="gm-plate">
          <div class="gm-plate__frame">
            <img src="/photos/tag-race-car.jpg" alt="1930-40s Hobby Kiddie diecast race car on Bill's handwritten tag" />
            <span class="gm-plate__no">No. 02</span>
          </div>
          <p class="gm-plate__era">1930-40s · pressed steel</p>
          <h3 class="gm-plate__name">Hobby Kiddie Race Car</h3>
          <p class="gm-plate__note">green over silver · original rubber · #SH-457</p>
          <p class="gm-plate__price">$ 65.00</p>
        </article>

        <article class="gm-plate">
          <div class="gm-plate__frame">
            <img src="/photos/fan-perfumes.jpg" alt="1930s GE cast-iron oscillating fan among perfume bottles" />
            <span class="gm-plate__no">No. 03</span>
          </div>
          <p class="gm-plate__era">1930s · cast iron, brass blade</p>
          <h3 class="gm-plate__name">GE Oscillating Fan</h3>
          <p class="gm-plate__note">still works · ask Bill to plug it in</p>
          <p class="gm-plate__price">ask Bill</p>
        </article>

        <article class="gm-plate gm-plate--awaiting">
          <div class="gm-plate__frame">
            <div class="gm-plate__placeholder">No. 04<br/>AWAITING</div>
          </div>
          <p class="gm-plate__era">—</p>
          <h3 class="gm-plate__name">Bill hasn't picked the fourth yet</h3>
          <p class="gm-plate__note">he has thirty in mind, won't commit to one</p>
          <p class="gm-plate__price">check Sunday</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SHELF III — THE RECORD (emerald felt drawer pulled out)
       ============================================================ -->
  <section class="gm-shelf gm-shelf--felt" id="record" aria-label="Every Piece Has a Record">
    <span class="gm-shelf__nameplate">
      <span class="gm-shelf__no">Shelf III</span>
      <span class="gm-shelf__name">Every Piece Has a Record</span>
    </span>

    <div class="gm-shelf__content">
      <p class="gm-record__eyebrow">— The Homework, in our own hand —</p>
      <h2 class="gm-record__headline">Every Piece Has a Record.</h2>
      <p class="gm-record__sub">Other vendors put a price. We put the story.</p>

      <div class="gm-tag-scatter">
        <span class="gm-tag" style="transform: rotate(-4deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1934</span>
          <strong>Scherk Perfume Bottle</strong>
          <span class="gm-tag__note">w/ Marie Antoinette miniature</span>
          <span class="gm-tag__price">$225.00</span>
        </span>
        <span class="gm-tag" style="transform: rotate(2deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1930-40</span>
          <strong>Hobby Kiddie Race Car</strong>
          <span class="gm-tag__note">green · original rubber · #SH-457</span>
          <span class="gm-tag__price">$65.00</span>
        </span>
        <span class="gm-tag" style="transform: rotate(-1deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1938</span>
          <strong>Buddy L Fire Engine</strong>
          <span class="gm-tag__note">E. Moline IL · all-orig ladders</span>
          <span class="gm-tag__price">$285.00</span>
        </span>
        <span class="gm-tag" style="transform: rotate(4deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1942</span>
          <strong>Mobil Gas Porcelain Sign</strong>
          <span class="gm-tag__note">Pegasus crest · honest wear</span>
          <span class="gm-tag__price">$420.00</span>
        </span>
        <span class="gm-tag" style="transform: rotate(-3deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1930s</span>
          <strong>Carved Bakelite Cuff</strong>
          <span class="gm-tag__note">cherry red · two repairs Bill'll show you</span>
          <span class="gm-tag__price">$68.00</span>
        </span>
        <span class="gm-tag" style="transform: rotate(1deg);">
          <span class="gm-tag__thread"></span>
          <span class="gm-tag__hole"></span>
          <span class="gm-tag__era">1928</span>
          <strong>Tin Pan Alley Sheet Music</strong>
          <span class="gm-tag__note">signed in pencil · provenance on file</span>
          <span class="gm-tag__price">$42.00</span>
        </span>
      </div>

      <p class="gm-record__foot">
        Want the full story behind any of them? <a href={BOOTH.phoneHref}>Ring Bill up — {BOOTH.phone}</a>
      </p>
    </div>
  </section>

  <!-- ============================================================
       SHELF IV — FIND THE JOINT (real booth photo backdrop)
       ============================================================ -->
  <section class="gm-shelf" id="joint" aria-label="Find the Joint">
    <img class="gm-shelf__bg" src="/photos/booth-wide.jpg" alt="" />
    <div class="gm-shelf__veil gm-shelf__veil--heavy"></div>
    <span class="gm-shelf__nameplate">
      <span class="gm-shelf__no">Shelf IV</span>
      <span class="gm-shelf__name">Find the Joint</span>
    </span>

    <div class="gm-shelf__content">
      <p class="gm-joint__eyebrow">— No GPS required, but it helps —</p>
      <h2 class="gm-joint__title">Find the Joint.</h2>

      <div class="gm-joint__grid">
        <div class="gm-map">
          <iframe
            title="Map to Paradise Mall, Booth #18"
            src="https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <aside class="gm-card">
          <span class="gm-card__corner gm-card__corner--tl"></span>
          <span class="gm-card__corner gm-card__corner--tr"></span>
          <span class="gm-card__corner gm-card__corner--bl"></span>
          <span class="gm-card__corner gm-card__corner--br"></span>

          <p class="gm-card__label">Booth</p>
          <p class="gm-card__line gm-card__line--bold">{BOOTH.name.toUpperCase()}</p>
          <p class="gm-card__line">{BOOTH.street}</p>
          <p class="gm-card__line">{BOOTH.city}</p>
          <div class="gm-card__divider"></div>

          <p class="gm-card__label">Hours</p>
          <p class="gm-card__line">{BOOTH.hoursLine}</p>
          <p class="gm-card__line gm-card__line--italic">{BOOTH.billLine}</p>
          <div class="gm-card__divider"></div>

          <p class="gm-card__label">Ring Bill Up</p>
          <p class="gm-card__phone">{BOOTH.phone}</p>
          <p class="gm-card__line gm-card__line--italic">Call ahead and we'll set things aside.</p>

          <div class="gm-card__buttons">
            <a class="gm-btn gm-btn--primary gm-btn--sm" href={BOOTH.mapHref} target="_blank" rel="noopener">Get Directions</a>
            <a class="gm-btn gm-btn--secondary gm-btn--sm" href={BOOTH.phoneHref}>Call Bill</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SHELF V — ETSY
       ============================================================ -->
  <section class="gm-shelf gm-shelf--word" id="word" aria-label="Get the Word First">
    <img class="gm-shelf__bg" src="/cabinet/pexels-7997662.jpg" alt="" />
    <div class="gm-shelf__veil gm-shelf__veil--heavy"></div>
    <span class="gm-shelf__nameplate">
      <span class="gm-shelf__no">Shelf V</span>
      <span class="gm-shelf__name">Get the Word First</span>
    </span>

    <div class="gm-shelf__content gm-shelf__content--narrow">
      <p class="gm-word__eyebrow">— Etsy's coming —</p>
      <h2 class="gm-word__title">Jump the queue.</h2>
      <p class="gm-word__body">
        We're putting the listings together piece by piece. If you want first
        crack at the good stuff before it goes up — <em>and the first crack is
        what you want</em> — leave your name. No spam. No tricks. We don't
        have time for that.
      </p>
      <form class="gm-form" action="#" method="post">
        <input type="email" name="email" required placeholder="your.email@…" aria-label="Email address" />
        <button class="gm-btn gm-btn--primary" type="submit">Get the word first</button>
      </form>
    </div>
  </section>

  <!-- ============================================================
       FOOTER — wooden plinth
       ============================================================ -->
  <footer class="gm-foot">
    <p class="gm-foot__tag">
      Est. 2022 · Collecting since 1973 · <em>Pieces back to 1850.</em><br/>
      Bill knows everybody. <em>Ask no questions.</em>
    </p>
    <p class="gm-foot__legal">TREASURE TROVE FINDS · PARADISE MALL · BOOTH #18 · LAS VEGAS, NEVADA</p>
    <p class="gm-foot__labs">An Otranto Labs project · <a href="/concepts">other concepts</a></p>
  </footer>

  <script is:inline>
    // After load, crossfade hero from "closed cabinet" to "open cabinet"
    (function () {
      window.addEventListener('load', function () {
        var hero = document.querySelector('.gm-hero');
        if (!hero) return;
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        setTimeout(function () {
          hero.classList.add('gm-hero--open');
        }, reduce ? 0 : 650);
      });
    })();
  </script>
</Layout>

<style is:global>
  html { scroll-behavior: smooth; }
  body {
    background: #0d0807;
    background-image: none;
    color: var(--color-cream);
  }
</style>

<style>
  /* ============================================================
     HERO — real curio cabinet photo, doors closed → open
     ============================================================ */
  .gm-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    isolation: isolate;
  }
  .gm-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transition: opacity 1400ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gm-hero__img--closed { opacity: 1; z-index: 1; }
  .gm-hero__img--open   { opacity: 0; z-index: 2; }
  .gm-hero--open .gm-hero__img--closed { opacity: 0; }
  .gm-hero--open .gm-hero__img--open   { opacity: 1; }
  .gm-hero__vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    background:
      linear-gradient(180deg, rgba(13,8,7,0.55) 0%, rgba(13,8,7,0.15) 25%, rgba(13,8,7,0.15) 65%, rgba(13,8,7,0.85) 100%),
      radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,0.55) 100%);
    pointer-events: none;
  }

  /* HUD on top — sticky brass strip */
  .gm-hud {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
    padding: 14px 28px;
    background: linear-gradient(180deg, rgba(13,8,7,0.85) 0%, rgba(13,8,7,0) 100%);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
  }
  .gm-hud__brand {
    color: var(--color-cream);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .gm-hud__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 9px;
    margin-bottom: 3px;
  }
  .gm-hud__mark {
    font-family: var(--font-display);
    color: var(--color-cream);
    font-size: 22px;
    letter-spacing: 0.03em;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.5);
  }
  .gm-hud__nav {
    display: flex;
    gap: 14px;
    justify-content: center;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.26em;
    font-size: 11px;
    color: var(--color-brass);
  }
  .gm-hud__nav a { color: var(--color-brass); text-decoration: none; }
  .gm-hud__nav a:hover { color: var(--color-cream); }
  .gm-hud__nav span { opacity: 0.6; }
  .gm-hud__phone {
    justify-self: end;
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 20px;
    text-decoration: none;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
    letter-spacing: 0.02em;
  }
  @media (max-width: 720px) {
    .gm-hud { grid-template-columns: 1fr auto; padding: 10px 14px; gap: 10px; }
    .gm-hud__nav { display: none; }
    .gm-hud__mark { font-size: 17px; }
  }

  /* Hero billing card — sits over the open cabinet */
  .gm-hero__billing {
    position: absolute;
    bottom: 8vh;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    width: min(640px, 92vw);
    background: var(--color-cream);
    background-image: radial-gradient(rgba(61,42,30,0.07) 1px, transparent 1.4px);
    background-size: 4px 4px;
    color: var(--color-ink);
    padding: 32px 36px 28px;
    border: 1.5px solid var(--color-walnut);
    box-shadow: inset 0 0 0 5px var(--color-cream), inset 0 0 0 6px var(--color-brass), 0 14px 30px rgba(0,0,0,0.7);
    text-align: center;
    opacity: 0;
    animation: gm-fade-up 1200ms cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
    animation-delay: 1800ms;
  }
  @keyframes gm-fade-up {
    from { opacity: 0; transform: translateX(-50%) translateY(24px); }
    to   { opacity: 1; transform: translateX(-50%) translateY(0); }
  }
  .gm-hero__billing::before, .gm-hero__billing::after {
    content: "✦";
    position: absolute;
    color: var(--color-brass);
    font-size: 18px;
  }
  .gm-hero__billing::before { top: 10px; left: 14px; }
  .gm-hero__billing::after  { bottom: 10px; right: 14px; }
  .gm-hero__plate {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 11px;
    margin: 0 0 8px;
  }
  .gm-hero__headline {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 0.95;
    margin: 4px 0 12px;
    letter-spacing: 0.01em;
    text-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    transform: rotate(-0.4deg);
    text-transform: uppercase;
  }
  .gm-hero__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 17px;
    margin: 0 0 22px;
    line-height: 1.45;
  }
  .gm-hero__ctas {
    display: flex; gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .gm-hero__cue {
    margin: 22px 0 0;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 10px;
    animation: gm-bob 2.4s ease-in-out infinite;
  }
  @keyframes gm-bob {
    0%, 100% { opacity: 0.6; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(3px); }
  }

  /* ============================================================
     SHELVES — each section uses a real cabinet photo backdrop
     ============================================================ */
  .gm-shelf {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 96px 32px 96px;
    color: var(--color-cream);
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .gm-shelf__bg {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
    filter: saturate(0.85) contrast(1.05);
  }
  .gm-shelf__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(13,8,7,0.55), rgba(13,8,7,0.4) 35%, rgba(13,8,7,0.7));
    pointer-events: none;
  }
  .gm-shelf__veil--heavy {
    background:
      linear-gradient(180deg, rgba(13,8,7,0.75), rgba(13,8,7,0.6) 35%, rgba(13,8,7,0.85));
  }
  .gm-shelf__nameplate {
    position: absolute;
    top: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    background: linear-gradient(180deg, #d8b647 0%, #C9A227 40%, #a07e1d 100%);
    color: var(--color-walnut);
    padding: 8px 22px;
    border: 1.5px solid rgba(0,0,0,0.5);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,0.4),
