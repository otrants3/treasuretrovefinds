---
/**
 * AuctionNav — quiet brass horizontal nav anchored to top of viewport.
 *
 * A single line of Oswald small-caps lot links across the top, behaving
 * as the catalogue's running header. Stays visible during scroll-snap.
 */

const LOTS = [
  { href: "#lot-01", label: "01 · Front" },
  { href: "#lot-02", label: "02 · Perfume" },
  { href: "#lot-03", label: "03 · Race Car" },
  { href: "#lot-04", label: "04 · GE Fan" },
  { href: "#lot-05", label: "05 · Mobil Sign" },
  { href: "#lot-06", label: "06 · Reserve" },
  { href: "#lot-07", label: "07 · The Joint" },
  { href: "#lot-08", label: "08 · Etsy" },
];
---

<nav class="auction-nav" aria-label="Catalogue lots">
  <div class="auction-nav__inner">
    <a class="auction-nav__brand" href="#lot-01">
      <span class="auction-nav__brand-line">Treasure Trove Finds</span>
      <span class="auction-nav__brand-sub">Auction Catalogue · Vol. I</span>
    </a>
    <ol class="auction-nav__lots">
      {LOTS.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .auction-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 30;
    background: rgba(242, 232, 208, 0.92);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-bottom: 1.4px solid var(--color-brass);
  }
  .auction-nav__inner {
    max-width: 96rem;
    margin: 0 auto;
    padding: 0.65rem clamp(1rem, 4vw, 3rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .auction-nav__brand {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1;
    color: var(--color-ink);
    flex-shrink: 0;
  }
  .auction-nav__brand-line {
    font-family: var(--font-billing);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.01em;
  }
  .auction-nav__brand-sub {
    font-family: var(--font-billing);
    font-style: italic;
    font-size: 0.72rem;
    color: var(--color-smoke);
    margin-top: 2px;
  }
  .auction-nav__lots {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.4rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .auction-nav__lots::-webkit-scrollbar { display: none; }

  .auction-nav__lots a {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.72rem;
    color: var(--color-walnut);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition: border-color 120ms ease-out, color 120ms ease-out;
  }
  .auction-nav__lots a:hover {
    color: var(--color-buddy-red);
    border-bottom-color: var(--color-brass);
  }

  @media (max-width: 760px) {
    .auction-nav__brand-sub { display: none; }
    .auction-nav__inner { gap: 1rem; padding: 0.55rem 1rem; }
    .auction-nav__brand-line { font-size: 0.95rem; }
    .auction-nav__lots { gap: 1rem; }
  }
</style>
