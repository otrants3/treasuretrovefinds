---
/**
 * LotHeader — the upper-left LOT NN marker that anchors every spread.
 *
 * Massive Oswald lot number sitting in the top-left corner of each
 * full-screen spread, with a small caps "section" tag underneath.
 * Used by every Lot section in the auction-catalogue concept.
 */
interface Props {
  /** Lot number e.g. "01", "02" — zero-padded for typographic gravity */
  number: string;
  /** Short uppercase category line under the lot number */
  tag: string;
  /** Optional override of the right-side metadata block */
  meta?: string;
}

const { number, tag, meta } = Astro.props;
---

<header class="auction-lot-header">
  <div class="auction-lot-header__num">
    <span class="auction-lot-header__lot-label">Lot</span>
    <span class="auction-lot-header__lot-num">{number}</span>
  </div>
  <div class="auction-lot-header__center">
    <span class="auction-lot-header__tag">{tag}</span>
  </div>
  {meta && <div class="auction-lot-header__meta">{meta}</div>}
</header>

<style>
  .auction-lot-header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: end;
    gap: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1.5px solid var(--color-brass);
    margin-bottom: 2.5rem;
  }
  .auction-lot-header__num {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    line-height: 0.85;
  }
  .auction-lot-header__lot-label {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
  }
  .auction-lot-header__lot-num {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: clamp(3.25rem, 7vw, 5.5rem);
    color: var(--color-ink);
    letter-spacing: -0.01em;
    line-height: 0.85;
  }
  .auction-lot-header__center {
    text-align: center;
  }
  .auction-lot-header__tag {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.42em;
    font-size: 0.78rem;
    color: var(--color-brass);
  }
  .auction-lot-header__meta {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.95rem;
    text-align: right;
  }

  @media (max-width: 680px) {
    .auction-lot-header {
      grid-template-columns: auto 1fr;
      gap: 1rem;
    }
    .auction-lot-header__center {
      text-align: right;
    }
    .auction-lot-header__meta {
      grid-column: 1 / -1;
      text-align: left;
      padding-top: 0.5rem;
    }
  }
</style>
