---
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import Layout from "../layouts/Layout.astro";
import SiteBar from "../components/SiteBar.astro";
import SiteFooter from "../components/SiteFooter.astro";
import items from "../data/cabinet.json";

// Tag each item with whether a Gemini catalog-plate illustration exists.
// (Some items hit copyright filters and have no .png in /cabinet/plates/.)
const PLATES_DIR = fileURLToPath(new URL("../../public/cabinet/plates/", import.meta.url));
const itemsWithPlates = (items as any[]).map((it) => ({
  ...it,
  hasPlate: existsSync(`${PLATES_DIR}${it.slug}.png`),
  plate: `/cabinet/plates/${it.slug}.png`,
}));

// Categories in display order
const CATEGORIES = [
  "All",
  "Toys & Trucks",
  "Glass & Bottles",
  "Advertising & Signage",
  "Jewelry & Adornment",
  "Curiosities",
  "Textiles & Dolls",
];

const counts = CATEGORIES.reduce<Record<string, number>>((acc, c) => {
  acc[c] = c === "All" ? itemsWithPlates.length : itemsWithPlates.filter((i: any) => i.category === c).length;
  return acc;
}, {});
---

<Layout
  title="The Cabinet · TreasureTroveFinds · Bill's Hand-Tagged Pieces"
  description="Open the cabinet. 24 hand-picked pieces from Bill's booth at Paradise Mall — every one tagged in his own handwriting. Click any piece for the full record."
>
  <SiteBar />

  <!-- =========================================================
       HERO — Masthead + category filter
  ========================================================= -->
  <section class="cab-hero">
    <div class="cab-hero__inner">
      <p class="ttf-label cab-hero__eyebrow">— OPEN THE CABINET —</p>
      <h1 class="cab-hero__title">The Cabinet</h1>
      <div class="cab-hero__rule"></div>
      <p class="cab-hero__sub">
        Twenty-four pieces from the booth, each one tagged in Bill's own handwriting.
        Click any piece for the full record — maker, era, price, and the part of the story he could verify.
      </p>

      <div class="cab-filter" role="tablist" aria-label="Filter by category">
        {CATEGORIES.map((cat, i) => (
          <button
            type="button"
            class={`cab-chip ${i === 0 ? "is-active" : ""}`}
            data-filter={cat}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
          >
            <span class="cab-chip__label">{cat}</span>
            <span class="cab-chip__count">{counts[cat]}</span>
          </button>
        ))}
      </div>

      <div class="cab-view" role="radiogroup" aria-label="View style">
        <span class="cab-view__label">— VIEW —</span>
        <button type="button" class="cab-view__btn is-active" data-view="photos" role="radio" aria-checked="true">Real Photos</button>
        <button type="button" class="cab-view__btn" data-view="plates" role="radio" aria-checked="false">Catalog Plates</button>
      </div>
    </div>
  </section>

  <!-- =========================================================
       GRID — masonry cards
  ========================================================= -->
  <section class="cab-grid-wrap" data-view="photos">
    <div class="cab-grid">
      {itemsWithPlates.map((it: any, idx: number) => (
        <article
          class="cab-card"
          data-category={it.category}
          data-slug={it.slug}
          style={`--tilt: ${[-0.6, 0.4, -0.3, 0.5, -0.5, 0.3][idx % 6]}deg;`}
        >
          <button class="cab-card__btn" type="button" aria-label={`Open ${it.displayName}`}>
            <div class="cab-card__photo">
              <img
                class="cab-card__img cab-card__img--photo"
                src={it.thumb}
                alt={it.displayName}
                loading={idx < 6 ? "eager" : "lazy"}
                width="600"
                height="600"
              />
              {it.hasPlate && (
                <img
                  class="cab-card__img cab-card__img--plate"
                  src={it.plate}
                  alt={`Catalog illustration of ${it.displayName}`}
                  loading="lazy"
                  width="600"
                  height="600"
                />
              )}
              {!it.hasPlate && (
                <div class="cab-card__no-plate" aria-hidden="true">
                  <span>Plate<br/>not<br/>available</span>
                </div>
              )}
            </div>
            <div class="cab-card__tag">
              <span class="cab-card__tag-hole" aria-hidden="true"></span>
              <span class="cab-card__tag-twine" aria-hidden="true"></span>
              <p class="cab-card__tag-era">{it.era}</p>
              <p class="cab-card__tag-name">{it.itemName || it.displayName}</p>
              {it.maker && <p class="cab-card__tag-maker">{it.maker}</p>}
              <p class="cab-card__tag-price">{it.price}</p>
            </div>
          </button>
        </article>
      ))}
    </div>
    <p class="cab-grid__empty" data-empty hidden>
      <em>Nothing in that drawer right now. Try another category.</em>
    </p>
    <p class="cab-grid__showcase-link">
      <a href="/showcase">Or see the pieces arranged inside the cabinet →</a>
    </p>
  </section>

  <!-- =========================================================
       MODAL — native dialog for detail view
  ========================================================= -->
  <dialog class="cab-modal" id="cabModal" aria-labelledby="cabModalTitle">
    <button type="button" class="cab-modal__close" data-modal-close aria-label="Close">×</button>
    <div class="cab-modal__inner">
      <figure class="cab-modal__photo-wrap">
        <img class="cab-modal__photo" alt="" />
      </figure>
      <div class="cab-modal__body">
        <p class="ttf-label cab-modal__category"></p>
        <h2 class="cab-modal__title" id="cabModalTitle"></h2>
        <div class="cab-modal__rule"></div>
        <p class="cab-modal__blurb"></p>

        <aside class="cab-modal__tag">
          <span class="cab-modal__tag-hole" aria-hidden="true"></span>
          <p class="cab-modal__tag-eyebrow">— Bill's Tag —</p>
          <p class="cab-modal__tag-note"></p>
          <p class="cab-modal__tag-price"></p>
        </aside>

        <div class="cab-modal__cta">
          <a class="ttf-btn ttf-btn-primary" href="#" data-call-link>Ring Bill to Hold It</a>
          <a class="ttf-btn ttf-btn-secondary" href="/#find">Get Directions</a>
        </div>
        <p class="cab-modal__foot">
          <em>The cabinet rotates. If you see it here and want it, call ahead — favorites get set aside behind the counter.</em>
        </p>
      </div>
    </div>
  </dialog>

  <SiteFooter />

  <!-- =========================================================
       DATA + LOGIC
  ========================================================= -->
  <script is:inline define:vars={{ items: itemsWithPlates }}>
    window.__CAB_ITEMS__ = items;
  </script>
  <script>
    // View toggle (Real Photos / Catalog Plates)
    const viewBtns = document.querySelectorAll<HTMLButtonElement>(".cab-view__btn");
    const gridWrap = document.querySelector<HTMLElement>(".cab-grid-wrap");
    viewBtns.forEach((b) => {
      b.addEventListener("click", () => {
        const v = b.dataset.view || "photos";
        viewBtns.forEach((x) => {
          x.classList.toggle("is-active", x === b);
          x.setAttribute("aria-checked", x === b ? "true" : "false");
        });
        if (gridWrap) gridWrap.dataset.view = v;
      });
    });

    // Category filter
    const chips = document.querySelectorAll<HTMLButtonElement>(".cab-chip");
    const cards = document.querySelectorAll<HTMLElement>(".cab-card");
    const empty = document.querySelector<HTMLElement>("[data-empty]");

    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const f = chip.dataset.filter || "All";
        chips.forEach((c) => {
          c.classList.toggle("is-active", c === chip);
          c.setAttribute("aria-selected", c === chip ? "true" : "false");
        });
        let visible = 0;
        cards.forEach((card) => {
          const show = f === "All" || card.dataset.category === f;
          card.classList.toggle("is-hidden", !show);
          if (show) visible += 1;
        });
        if (empty) empty.hidden = visible > 0;
      });
    });

    // Modal
    const modal = document.getElementById("cabModal") as HTMLDialogElement | null;
    const closeBtn = document.querySelector<HTMLButtonElement>("[data-modal-close]");
    const photo = modal?.querySelector<HTMLImageElement>(".cab-modal__photo");
    const cat = modal?.querySelector<HTMLElement>(".cab-modal__category");
    const title = modal?.querySelector<HTMLElement>(".cab-modal__title");
    const blurb = modal?.querySelector<HTMLElement>(".cab-modal__blurb");
    const tagNote = modal?.querySelector<HTMLElement>(".cab-modal__tag-note");
    const tagPrice = modal?.querySelector<HTMLElement>(".cab-modal__tag-price");
    const callLink = modal?.querySelector<HTMLAnchorElement>("[data-call-link]");

    const PHONE = "+15164462693";
    if (callLink) callLink.href = `tel:${PHONE}`;

    function open(slug: string) {
      const all = (window as any).__CAB_ITEMS__ || [];
      const item = all.find((i: any) => i.slug === slug);
      if (!item || !modal) return;
      if (photo) { photo.src = item.image; photo.alt = item.displayName; }
      if (cat) cat.textContent = `— ${item.category} —`;
      if (title) title.textContent = item.displayName;
      if (blurb) blurb.textContent = item.shortBlurb;
      if (tagNote) {
        // Replace " / " with line breaks for the handwritten tag
        tagNote.innerHTML = (item.billsNote || "").replace(/\s*\/\s*/g, "<br/>");
      }
      if (tagPrice) tagPrice.textContent = item.price;
      modal.showModal();
      document.body.style.overflow = "hidden";
    }
    function close() {
      if (!modal) return;
      modal.close();
      document.body.style.overflow = "";
    }
    cards.forEach((card) => {
      const btn = card.querySelector<HTMLButtonElement>(".cab-card__btn");
      if (!btn) return;
      btn.addEventListener("click", () => open(card.dataset.slug || ""));
    });
    closeBtn?.addEventListener("click", close);
    modal?.addEventListener("click", (e) => {
      // Backdrop click closes
      if (e.target === modal) close();
    });
    modal?.addEventListener("close", () => { document.body.style.overflow = ""; });

    // Deep-link: ?item=<slug> opens that one on load
    const sp = new URLSearchParams(location.search);
    const initial = sp.get("item");
    if (initial) requestAnimationFrame(() => open(initial));
  </script>

  <style>
    body { padding-top: 48px; }
    @media (max-width: 720px) { body { padding-top: 42px; } }

    /* ============ HERO ============ */
    .cab-hero {
      padding: 4.5rem 1.5rem 2rem;
      text-align: center;
      background:
        radial-gradient(ellipse at top, rgba(31,77,63,0.05), transparent 60%),
        var(--color-cream);
    }
    .cab-hero__inner { max-width: 920px; margin: 0 auto; }
    .cab-hero__eyebrow { color: var(--color-brass); margin: 0 0 0.5rem; }
    .cab-hero__title {
      font-family: var(--font-display);
      color: var(--color-ink);
      font-size: clamp(48px, 8vw, 96px);
      line-height: 0.9; letter-spacing: 0.005em;
      margin: 0.25rem 0 0.75rem;
      text-shadow: 2px 3px 0 rgba(26,22,20,0.08);
    }
    .cab-hero__rule {
      width: 84px; height: 2px; background: var(--color-brass);
      margin: 0.5rem auto 1.5rem; position: relative;
    }
    .cab-hero__rule::before {
      content: "✦"; position: absolute; left: 50%; top: 50%;
      transform: translate(-50%, -50%); color: var(--color-brass);
      background: var(--color-cream); padding: 0 10px; font-size: 16px;
    }
    .cab-hero__sub {
      font-family: var(--font-serif); color: var(--color-ink);
      font-size: clamp(15px, 1.5vw, 17.5px); line-height: 1.65;
      max-width: 640px; margin: 0 auto 2rem;
    }

    /* ============ VIEW TOGGLE ============ */
    .cab-view {
      display: inline-flex; align-items: center; gap: 0.6rem;
      margin: 1.25rem auto 0; padding: 0.4rem 0.65rem;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      box-shadow: 3px 3px 0 rgba(26,22,20,0.12);
    }
    .cab-view__label {
      font-family: var(--font-label); letter-spacing: 0.22em;
      text-transform: uppercase; font-size: 0.66rem;
      color: var(--color-brass); padding-left: 0.25rem;
    }
    .cab-view__btn {
      font-family: var(--font-label); letter-spacing: 0.18em;
      text-transform: uppercase; font-size: 0.72rem;
      padding: 0.45rem 0.85rem; cursor: pointer;
      background: transparent; border: 1px solid transparent;
      color: var(--color-ink);
      transition: background 120ms ease, color 120ms ease, border-color 120ms ease;
    }
    .cab-view__btn:hover { background: rgba(26,22,20,0.06); }
    .cab-view__btn.is-active {
      background: var(--color-ink); color: var(--color-cream);
      border-color: var(--color-ink);
    }

    /* ============ FILTER CHIPS ============ */
    .cab-filter {
      display: flex; gap: 0.5rem; flex-wrap: wrap;
      justify-content: center; margin: 0 auto;
    }
    .cab-chip {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.55rem 1rem;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      box-shadow: 3px 3px 0 rgba(26,22,20,0.14);
      font-family: var(--font-label); letter-spacing: 0.18em;
      text-transform: uppercase; font-size: 0.72rem;
      color: var(--color-ink); cursor: pointer;
      transition: transform 120ms ease, background 120ms ease, color 120ms ease, box-shadow 120ms ease;
    }
    .cab-chip:hover {
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0 rgba(26,22,20,0.2);
    }
    .cab-chip__count {
      font-family: var(--font-billing); font-style: italic;
      font-size: 0.85rem; letter-spacing: 0;
      color: var(--color-smoke);
    }
    .cab-chip.is-active {
      background: var(--color-buddy-red);
      color: var(--color-cream);
      border-color: var(--color-buddy-red);
    }
    .cab-chip.is-active .cab-chip__count { color: rgba(242,232,208,0.85); }

    /* ============ GRID ============ */
    .cab-grid-wrap { padding: 2rem 1.5rem 5rem; }
    .cab-grid {
      max-width: 1320px; margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 2.5rem 1.75rem;
    }
    .cab-grid__empty {
      max-width: 720px; margin: 3rem auto;
      text-align: center;
      font-family: var(--font-billing); font-style: italic;
      color: var(--color-smoke); font-size: 17px;
    }
    .cab-grid__showcase-link {
      max-width: 720px; margin: 3.5rem auto 0;
      text-align: center;
    }
    .cab-grid__showcase-link a {
      font-family: var(--font-label); letter-spacing: 0.24em;
      text-transform: uppercase; font-size: 0.78rem;
      color: var(--color-walnut); text-decoration: none;
      padding-bottom: 4px; border-bottom: 1.5px solid var(--color-brass);
    }
    .cab-grid__showcase-link a:hover { color: var(--color-buddy-red); }

    /* ============ CARD ============ */
    .cab-card {
      transform: rotate(var(--tilt, 0));
      transition: opacity 220ms ease, transform 220ms ease;
    }
    .cab-card.is-hidden { display: none; }
    .cab-card__btn {
      display: block; width: 100%;
      background: none; border: 0; padding: 0; margin: 0;
      cursor: pointer; text-align: left;
      transition: transform 180ms ease;
    }
    .cab-card__btn:hover { transform: translate(-2px, -3px); }
    .cab-card__btn:focus-visible {
      outline: 2px dashed var(--color-brass);
      outline-offset: 6px;
    }
    .cab-card__photo {
      position: relative;
      padding: 10px;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      box-shadow: 5px 6px 0 rgba(26,22,20,0.2);
      aspect-ratio: 1/1; overflow: hidden;
    }
    .cab-card__photo::before, .cab-card__photo::after {
      content: ""; position: absolute; width: 18px; height: 18px;
      border: 1.5px solid var(--color-brass);
    }
    .cab-card__photo::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
    .cab-card__photo::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
    .cab-card__img {
      position: absolute; inset: 10px;
      width: calc(100% - 20px); height: calc(100% - 20px);
      object-fit: cover; display: block;
      border: 1px solid var(--color-walnut);
      transition: opacity 380ms ease, transform 600ms ease;
    }
    .cab-card__img--photo {
      filter: saturate(0.95) contrast(1.04);
      opacity: 1;
    }
    .cab-card__img--plate {
      object-fit: contain;
      background: var(--color-cream);
      filter: contrast(1.05);
      opacity: 0;
    }
    .cab-grid-wrap[data-view="plates"] .cab-card__img--photo { opacity: 0; }
    .cab-grid-wrap[data-view="plates"] .cab-card__img--plate { opacity: 1; }
    .cab-card__btn:hover .cab-card__img { transform: scale(1.04); }
    /* Fallback for items without a plate illustration */
    .cab-card__no-plate {
      position: absolute; inset: 10px;
      display: none; align-items: center; justify-content: center;
      background: var(--color-cream);
      border: 1px solid var(--color-walnut);
      font-family: var(--font-label); letter-spacing: 0.18em;
      text-transform: uppercase; font-size: 0.7rem;
      color: var(--color-smoke); text-align: center;
      pointer-events: none; opacity: 0;
      transition: opacity 380ms ease;
    }
    .cab-grid-wrap[data-view="plates"] .cab-card__no-plate {
      display: flex; opacity: 1;
    }

    /* Handwritten tag attached to the bottom of each card */
    .cab-card__tag {
      position: relative; margin: 1.25rem 1rem 0;
      padding: 1.4rem 1rem 0.85rem;
      background: var(--color-tag-paper);
      background-image:
        radial-gradient(rgba(61,42,30,0.10) 1px, transparent 1.2px),
        radial-gradient(rgba(61,42,30,0.06) 1px, transparent 1.2px);
      background-size: 5px 5px, 9px 9px;
      background-position: 0 0, 2px 2px;
      border: 1px solid rgba(61,42,30,0.45);
      box-shadow: 3px 4px 0 rgba(26,22,20,0.22);
      transform: rotate(calc(var(--tilt, 0) * -1.8));
    }
    .cab-card__tag-twine {
      position: absolute; top: -22px; left: 50%;
      transform: translateX(-50%) rotate(3deg);
      width: 1.5px; height: 26px;
      background: var(--color-walnut); opacity: 0.7;
    }
    .cab-card__tag-hole {
      position: absolute; top: 6px; left: 50%;
      transform: translateX(-50%);
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--color-cream);
      box-shadow: inset 0 0 0 1.6px rgba(61,42,30,0.7);
    }
    .cab-card__tag-era {
      font-family: var(--font-hand); color: var(--color-walnut);
      font-size: 12px; line-height: 1.2;
      margin: 0 0 4px;
    }
    .cab-card__tag-name {
      font-family: var(--font-hand); color: var(--color-ink);
      font-size: 16px; line-height: 1.2;
      margin: 0 0 4px;
    }
    .cab-card__tag-maker {
      font-family: var(--font-hand); color: var(--color-smoke);
      font-size: 12px; font-style: italic; line-height: 1.2;
      margin: 0 0 6px;
    }
    .cab-card__tag-price {
      font-family: var(--font-display); color: var(--color-buddy-red);
      font-size: 22px; line-height: 1;
      margin: 6px 0 0;
      text-shadow: 1px 1px 0 rgba(26,22,20,0.16);
    }

    /* ============ MODAL ============ */
    .cab-modal[open] {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
    }
    .cab-modal {
      padding: 0; border: 0; background: transparent;
      width: 100%; max-width: none; max-height: none;
      inset: 0; margin: 0; height: 100vh;
    }
    .cab-modal::backdrop {
      background: rgba(14, 10, 7, 0.82);
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
    }
    .cab-modal[open] .cab-modal__inner {
      animation: cab-modal-in 360ms cubic-bezier(0.2, 0.7, 0.2, 1) both;
    }
    @keyframes cab-modal-in {
      from { opacity: 0; transform: translateY(20px) scale(0.97); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .cab-modal__inner {
      position: relative;
      width: min(1100px, 94vw);
      max-height: 90vh;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      box-shadow: 0 30px 80px rgba(0,0,0,0.55), 0 0 0 1px rgba(201,162,39,0.4);
      display: grid;
      grid-template-columns: 1.05fr 1fr;
      overflow: hidden;
    }
    .cab-modal__inner::before, .cab-modal__inner::after {
      content: ""; position: absolute; width: 28px; height: 28px;
      border: 1.5px solid var(--color-brass); pointer-events: none;
      z-index: 3;
    }
    .cab-modal__inner::before { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
    .cab-modal__inner::after  { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }
    .cab-modal__close {
      position: absolute; top: 14px; right: 14px;
      width: 38px; height: 38px;
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      font-family: var(--font-display); font-size: 22px;
      line-height: 1; color: var(--color-ink);
      cursor: pointer;
      z-index: 5;
      box-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    }
    .cab-modal__close:hover { background: var(--color-buddy-red); color: var(--color-cream); border-color: var(--color-buddy-red); }
    .cab-modal__photo-wrap {
      margin: 0; background: var(--color-walnut);
      position: relative; overflow: hidden;
      min-height: 100%;
    }
    .cab-modal__photo {
      width: 100%; height: 100%; object-fit: cover;
      filter: saturate(0.95) contrast(1.04);
      display: block;
    }
    .cab-modal__body {
      padding: 2.25rem 2rem 1.75rem;
      overflow-y: auto;
      display: flex; flex-direction: column; gap: 0.75rem;
    }
    .cab-modal__category {
      color: var(--color-brass); margin: 0;
    }
    .cab-modal__title {
      font-family: var(--font-billing); font-weight: 700;
      color: var(--color-ink);
      font-size: clamp(26px, 3vw, 38px);
      line-height: 1.05; margin: 0;
    }
    .cab-modal__rule {
      width: 64px; height: 2px; background: var(--color-brass);
      margin: 0.25rem 0 0.5rem;
    }
    .cab-modal__blurb {
      font-family: var(--font-billing); font-style: italic;
