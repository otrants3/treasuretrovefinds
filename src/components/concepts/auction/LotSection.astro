---
/**
 * LotSection — the full-screen "spread" wrapper used for every Lot.
 *
 * Provides:
 *   - 100dvh full-height with scroll-snap-align: start
 *   - generous inner margin like a printed catalogue page
 *   - optional background variant for the closing/footer lots
 *
 * The page-level wrapper sets scroll-snap-type on the body, not here.
 */
interface Props {
  id: string;
  variant?: "cream" | "walnut" | "emerald";
}
const { id, variant = "cream" } = Astro.props;
---

<section id={id} class={`auction-spread auction-spread--${variant}`}>
  <div class="auction-spread__inner">
    <slot />
  </div>
</section>

<style>
  .auction-spread {
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    display: flex;
    align-items: stretch;
    padding: clamp(5.5rem, 9vh, 7rem) clamp(1.25rem, 5vw, 4rem) clamp(2rem, 5vh, 3.5rem);
    position: relative;
  }
  .auction-spread--cream {
    background: var(--color-cream);
    color: var(--color-ink);
  }
  .auction-spread--walnut {
    background: var(--color-walnut);
    color: var(--color-cream);
  }
  .auction-spread--emerald {
    background: var(--color-emerald);
    color: var(--color-cream);
  }
  .auction-spread__inner {
    width: 100%;
    max-width: 86rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }

  /* Dark variants flip header/field label colors via inheritance */
  .auction-spread--walnut :global(.auction-lot-header),
  .auction-spread--emerald :global(.auction-lot-header) {
    border-bottom-color: var(--color-brass);
  }
  .auction-spread--walnut :global(.auction-lot-header__lot-num),
  .auction-spread--emerald :global(.auction-lot-header__lot-num) {
    color: var(--color-cream);
  }
  .auction-spread--walnut :global(.auction-field__body),
  .auction-spread--emerald :global(.auction-field__body) {
    color: var(--color-cream);
  }
  .auction-spread--walnut :global(.auction-lot-header__meta),
  .auction-spread--emerald :global(.auction-lot-header__meta) {
    color: var(--color-cream);
    opacity: 0.75;
  }
</style>
