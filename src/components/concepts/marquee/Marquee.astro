---
/**
 * Marquee.astro — Period theatre marquee at top of page.
 * Brass-bulb panels spell out TREASURE TROVE FINDS.
 * Bulbs animate ON one at a time left-to-right (~1.2s), then
 * settle into a slow ~3s twinkle on a handful of bulbs.
 *
 * NOT neon — these are period theatre marquee bulbs (Joe Louis era).
 */

const word1 = "TREASURE";
const word2 = "TROVE";
const word3 = "FINDS";

// Total number of brass border bulbs (top + bottom rows + sides)
const topBulbs = 28;
const sideBulbs = 4;
---

<div class="marquee-wrap">
  <div class="marquee-outer">
    <!-- Brass border bulb panels -->
    <div class="bulb-row bulb-row-top">
      {Array.from({ length: topBulbs }).map((_, i) => (
        <span
          class="bulb"
          style={`--bulb-index:${i}; --twinkle-delay:${(i * 0.37) % 3}s;`}
        ></span>
      ))}
    </div>

    <div class="marquee-inner">
      <!-- Left side bulbs -->
      <div class="bulb-col bulb-col-left">
        {Array.from({ length: sideBulbs }).map((_, i) => (
          <span
            class="bulb bulb-side"
            style={`--bulb-index:${topBulbs + i}; --twinkle-delay:${(i * 0.51) % 3}s;`}
          ></span>
        ))}
      </div>

      <!-- The marquee face: brass-bulb letter panels -->
      <div class="marquee-face">
        <div class="marquee-header">
          <span class="header-rule"></span>
          <span class="header-text">— TONIGHT'S ENGAGEMENT —</span>
          <span class="header-rule"></span>
        </div>

        <div class="marquee-words">
          <div class="marquee-line">
            {[...word1].map((ch, i) => (
              <span
                class="letter-panel"
                style={`--letter-index:${i}`}
              >
                <span class="letter-bulb-top"></span>
                <span class="letter-glyph">{ch}</span>
                <span class="letter-bulb-bottom"></span>
              </span>
            ))}
          </div>
          <div class="marquee-line">
            {[...word2].map((ch, i) => (
              <span
                class="letter-panel"
                style={`--letter-index:${i + word1.length}`}
              >
                <span class="letter-bulb-top"></span>
                <span class="letter-glyph">{ch}</span>
                <span class="letter-bulb-bottom"></span>
              </span>
            ))}
          </div>
          <div class="marquee-line">
            {[...word3].map((ch, i) => (
              <span
                class="letter-panel"
                style={`--letter-index:${i + word1.length + word2.length}`}
              >
                <span class="letter-bulb-top"></span>
                <span class="letter-glyph">{ch}</span>
                <span class="letter-bulb-bottom"></span>
              </span>
            ))}
          </div>
        </div>

        <div class="marquee-subline">
          <span class="sub-divider">◆</span>
          <span class="sub-text">BOOTH&nbsp;18&nbsp;&nbsp;·&nbsp;&nbsp;NO COVER&nbsp;&nbsp;·&nbsp;&nbsp;ONE NIGHT ONLY</span>
          <span class="sub-divider">◆</span>
        </div>
      </div>

      <!-- Right side bulbs -->
      <div class="bulb-col bulb-col-right">
        {Array.from({ length: sideBulbs }).map((_, i) => (
          <span
            class="bulb bulb-side"
            style={`--bulb-index:${topBulbs + sideBulbs + i}; --twinkle-delay:${(i * 0.43) % 3}s;`}
          ></span>
        ))}
      </div>
    </div>

    <div class="bulb-row bulb-row-bottom">
      {Array.from({ length: topBulbs }).map((_, i) => (
        <span
          class="bulb"
          style={`--bulb-index:${topBulbs + sideBulbs * 2 + i}; --twinkle-delay:${(i * 0.29 + 0.7) % 3}s;`}
        ></span>
      ))}
    </div>
  </div>
</div>

<style>
  .marquee-wrap {
    background:
      repeating-linear-gradient(
        90deg,
        rgba(26,22,20,0.08) 0px,
        rgba(26,22,20,0.08) 1px,
        transparent 1px,
        transparent 6px
      ),
      linear-gradient(180deg, #2a1c12 0%, #1a1109 100%);
    padding: 2.25rem 1rem 2.5rem;
    border-bottom: 4px double var(--color-brass);
  }

  .marquee-outer {
    max-width: 60rem;
    margin: 0 auto;
    background:
      linear-gradient(180deg, #2e1f14 0%, #3d2a1e 50%, #2a1c12 100%);
    border: 2px solid var(--color-brass);
    box-shadow:
      inset 0 0 0 1px rgba(0,0,0,0.5),
      inset 0 0 40px rgba(0,0,0,0.45),
      0 6px 0 rgba(0,0,0,0.4);
    padding: 0;
  }

  /* ----- Brass bulb rows (top + bottom borders) ----- */
  .bulb-row {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0.55rem 0.5rem;
    background: linear-gradient(180deg, #3a2818 0%, #2a1c12 100%);
    border-bottom: 1px solid rgba(201,162,39,0.35);
  }
  .bulb-row-bottom {
    border-bottom: 0;
    border-top: 1px solid rgba(201,162,39,0.35);
  }

  /* Side columns of bulbs */
  .marquee-inner {
    display: flex;
    align-items: stretch;
  }
  .bulb-col {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: center;
    padding: 0.5rem 0.4rem;
    background: linear-gradient(90deg, #2a1c12, #3d2a1e);
  }
  .bulb-col-right {
    background: linear-gradient(270deg, #2a1c12, #3d2a1e);
  }

  /* ----- A single brass bulb ----- */
  .bulb {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 32%,
        #fff5c4 0%,
        #f7d774 28%,
        #c9a227 62%,
        #6b5215 100%);
    box-shadow:
      inset 0 0 0 1px rgba(0,0,0,0.4),
      0 0 4px rgba(201,162,39,0.55);
    /* Start dim — sequence animation will turn them on */
    opacity: 0.18;
    filter: saturate(0.7) brightness(0.65);
    animation:
      bulb-on 0.45s ease-out forwards,
      bulb-twinkle 3s ease-in-out infinite;
    animation-delay:
      calc(var(--bulb-index, 0) * 18ms),
      calc(1.3s + var(--twinkle-delay, 0s));
  }
  .bulb-side {
    width: 11px;
    height: 11px;
  }

  /* Mini bulbs above/below each letter glyph */
  .letter-bulb-top,
  .letter-bulb-bottom {
    display: block;
    width: 10px;
    height: 10px;
    margin: 0 auto;
    border-radius: 50%;
    background:
      radial-gradient(circle at 35% 32%,
        #fff5c4 0%,
        #f7d774 28%,
        #c9a227 62%,
        #6b5215 100%);
    box-shadow:
      inset 0 0 0 1px rgba(0,0,0,0.4),
      0 0 6px rgba(247,215,116,0.55);
    opacity: 0.2;
    filter: brightness(0.65);
    animation:
      bulb-on 0.5s ease-out forwards,
      bulb-twinkle 3.4s ease-in-out infinite;
    animation-delay:
      calc(0.15s + var(--letter-index, 0) * 55ms),
      calc(1.6s + (var(--letter-index, 0) * 0.13s));
  }

  @keyframes bulb-on {
    0%   { opacity: 0.18; filter: brightness(0.6) saturate(0.7); }
    60%  { opacity: 1;    filter: brightness(1.35) saturate(1.2); }
    100% { opacity: 0.92; filter: brightness(1) saturate(1); }
  }

  @keyframes bulb-twinkle {
    0%, 100% { opacity: 0.92; filter: brightness(1)    saturate(1); }
    45%      { opacity: 0.62; filter: brightness(0.75) saturate(0.85); }
    55%      { opacity: 1;    filter: brightness(1.15) saturate(1.05); }
  }

  /* ----- Marquee face / words ----- */
  .marquee-face {
    flex: 1;
    padding: 1.25rem 1rem 1rem;
    text-align: center;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(247,215,116,0.08) 0%, transparent 60%),
      linear-gradient(180deg, #3d2a1e 0%, #2a1c12 100%);
    color: var(--color-cream);
  }

  .marquee-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }
  .header-rule {
    flex: 1;
    max-width: 5rem;
    height: 1px;
    background: var(--color-brass);
    opacity: 0.7;
  }
  .header-text {
    font-family: var(--font-label);
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    color: var(--color-brass);
  }

  .marquee-words {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.35rem 0;
  }
  .marquee-line {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .letter-panel {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.2rem 0.35rem 0.15rem;
    background:
      linear-gradient(180deg, #1a1109 0%, #0d0805 100%);
    border: 1px solid rgba(201,162,39,0.55);
    box-shadow:
      inset 0 0 0 1px rgba(0,0,0,0.7),
      inset 0 0 12px rgba(247,215,116,0.12);
    min-width: 2.6rem;
  }
  .letter-glyph {
    font-family: var(--font-display);
    color: #fff5c4;
    font-size: clamp(2.2rem, 5.5vw, 3.6rem);
    line-height: 1;
    text-shadow:
      0 0 8px rgba(247,215,116,0.85),
      0 0 18px rgba(247,215,116,0.45),
      0 2px 0 rgba(0,0,0,0.5);
    letter-spacing: 0.02em;
    padding: 0.05em 0.05em 0;
  }

  .marquee-subline {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-family: var(--font-label);
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    color: var(--color-cream);
  }
  .sub-divider {
    color: var(--color-brass);
    font-size: 0.7rem;
  }

  @media (max-width: 640px) {
    .marquee-face { padding: 0.9rem 0.5rem 0.75rem; }
    .letter-panel { min-width: 1.8rem; padding: 0.15rem 0.2rem; }
    .letter-glyph { font-size: clamp(1.7rem, 9vw, 2.6rem); }
    .marquee-subline { font-size: 0.65rem; letter-spacing: 0.22em; }
    .header-text { font-size: 0.6rem; letter-spacing: 0.22em; }
  }

  /* Respect reduced motion: bulbs simply on, no twinkle */
  @media (prefers-reduced-motion: reduce) {
    .bulb, .letter-bulb-top, .letter-bulb-bottom {
      animation: none;
      opacity: 0.92;
      filter: none;
    }
  }
</style>
