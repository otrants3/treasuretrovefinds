---
/**
 * 1920s admission-stub ticket. Speakeasy / vaudeville energy.
 * Used near the hero as a visual flourish — "you're getting let in."
 */
interface Props {
  line1?: string;   // big, e.g. "ADMIT ONE"
  line2?: string;   // small, e.g. "NO COVER"
  line3?: string;   // smallest, e.g. "BILL'S ON DUTY WEDS & SUN"
  serial?: string;  // tiny serial number, top right
  rotate?: number;
}
const {
  line1 = "ADMIT ONE",
  line2 = "NO COVER",
  line3 = "Bill works the booth Wednesdays & Sundays",
  serial = "№ 0418",
  rotate = 4,
} = Astro.props;
---

<div class="ttf-stub" style={`transform: rotate(${rotate}deg);`}>
  <div class="ttf-stub__main">
    <span class="ttf-stub__serial">{serial}</span>
    <span class="ttf-stub__line1">{line1}</span>
    <span class="ttf-stub__line2">{line2}</span>
    <span class="ttf-stub__line3">{line3}</span>
  </div>
  <div class="ttf-stub__tear" aria-hidden="true"></div>
  <div class="ttf-stub__counter">
    <span>№</span>
    <strong>18</strong>
    <span>booth</span>
  </div>
</div>

<style>
  .ttf-stub {
    display: inline-flex;
    align-items: stretch;
    background: #efd9a6;
    background-image:
      radial-gradient(rgba(61,42,30,0.08) 1px, transparent 1px);
    background-size: 4px 4px;
    color: var(--color-walnut);
    border: 1.5px solid var(--color-walnut);
    box-shadow:
      3px 4px 0 rgba(26,22,20,0.22),
      inset 0 0 0 4px #efd9a6,
      inset 0 0 0 5px rgba(61,42,30,0.45);
    padding: 0;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    position: relative;
    overflow: hidden;
  }

  .ttf-stub__main {
    display: flex;
    flex-direction: column;
    padding: 10px 22px 10px 18px;
    align-items: center;
    text-align: center;
    position: relative;
  }
  .ttf-stub__serial {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-buddy-red);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: none;
    align-self: flex-start;
    margin-bottom: 2px;
  }
  .ttf-stub__line1 {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 24px;
    line-height: 1;
    letter-spacing: 0.04em;
    text-shadow: 1px 1px 0 rgba(26,22,20,0.18);
    margin: 2px 0 4px;
  }
  .ttf-stub__line2 {
    font-family: var(--font-billing);
    font-weight: 700;
    color: var(--color-walnut);
    font-size: 12px;
    letter-spacing: 0.32em;
    margin-bottom: 4px;
  }
  .ttf-stub__line3 {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-walnut);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: none;
    max-width: 200px;
    line-height: 1.3;
  }

  .ttf-stub__tear {
    width: 0;
    border-left: 1.5px dashed var(--color-walnut);
    position: relative;
    margin: 6px 0;
  }
  /* Half-circles cutting into the dashed seam */
  .ttf-stub__tear::before,
  .ttf-stub__tear::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 14px; height: 14px;
    background: var(--color-cream);
    border-radius: 50%;
  }
  .ttf-stub__tear::before { top: -10px; }
  .ttf-stub__tear::after  { bottom: -10px; }

  .ttf-stub__counter {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 8px 18px;
    background: var(--color-walnut);
    color: var(--color-cream);
    font-family: var(--font-display);
    line-height: 1;
    letter-spacing: 0.05em;
    min-width: 70px;
  }
  .ttf-stub__counter span { font-family: var(--font-billing); font-style: italic; font-size: 11px; letter-spacing: 0.1em; text-transform: lowercase; color: var(--color-brass); }
  .ttf-stub__counter strong { font-size: 32px; color: var(--color-cream); margin: 2px 0; font-weight: 400; }
</style>
