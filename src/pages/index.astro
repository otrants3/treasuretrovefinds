---
import Layout from "../layouts/Layout.astro";
import SunburstSeal from "../components/SunburstSeal.astro";
import CatalogPlate from "../components/CatalogPlate.astro";
import BoxingBilling from "../components/BoxingBilling.astro";

const BOOTH = {
  address1: "3565 E. Flamingo Road",
  address2: "Paradise Mall · Booth #18",
  city: "Las Vegas, NV 89121",
  phoneDisplay: "(516) 446-2693",
  phoneTel: "+15164462693",
  hours: "Weds & Sun · 10 AM – 6 PM",
  mapsQuery: "Paradise+Antique+Mall+3565+E+Flamingo+Rd+Las+Vegas+NV+89121",
};

const LINEUP = [
  {
    plate: "PLATE NO. 01",
    item: "Renaissance Perfume Bottle",
    era: "1934 · Ludwig Scherk · silver filigree, Marie Antoinette miniature",
    note: "Pre-war German atelier. Miniature painted on ivorine. Original stopper.",
    price: "$ 225",
    photo: "/photos/tag-perfume-bottle.jpg",
  },
  {
    plate: "PLATE NO. 02",
    item: "Hobby Kiddie Diecast Race Car",
    era: "1930-40s · #SH-457 · pressed steel, original green",
    note: "Driver intact. Original wheels. Patina untouched — never restored.",
    price: "$ 65",
    photo: "/photos/tag-race-car.jpg",
  },
  {
    plate: "PLATE NO. 03",
    item: "GE Cast-Iron Oscillating Fan",
    era: "1930s · General Electric · brass blades, cast-iron base",
    note: "Runs cool. Original cord. Ask Bill about the patent date stamp.",
    price: "Ask Bill",
    photo: "/photos/fan-perfumes.jpg",
  },
];
---

<Layout
  title="TreasureTroveFinds · Paradise Mall, Booth #18 · Las Vegas"
  description="Bill & Lisa's curated antique booth at Paradise Mall, Las Vegas. Every piece has a record. Collecting since 1973."
>
  <!-- =========================================================
       HERO — sticky scroll-scrubbed cabinet photo
  ========================================================= -->
  <section data-hero class="ttf-hero">
    <div data-hero-stage class="ttf-hero__stage">
      <!-- Layer 1: doors closed -->
      <div data-hero-closed data-parallax="14" class="ttf-hero__layer">
        <img src="/cabinet/pexels-36901179.jpg" alt="Antique ornate cabinet with glass doors closed" fetchpriority="high" />
      </div>
      <!-- Layer 2: door swung open, apothecary bottles -->
      <div data-hero-open data-parallax="10" class="ttf-hero__layer">
        <img src="/cabinet/pexels-13207903.jpg" alt="Apothecary cabinet with glass door swung open" />
      </div>
      <!-- Layer 3: camera inside the cabinet, rich shelves -->
      <div data-hero-inside data-parallax="6" class="ttf-hero__layer">
        <img src="/cabinet/pexels-9704134.jpg" alt="Inside the curio cabinet — shelves of curiosities" />
      </div>
      <!-- Cinematic vignette + atmosphere -->
      <div data-hero-vignette class="ttf-hero__vignette"></div>
    </div>

    <!-- Foreground brass nameplate -->
    <div data-hero-title data-parallax="-4" class="ttf-hero__plate-wrap">
      <div class="ttf-hero__scrim"></div>
      <div class="ttf-hero__plate">
        <p class="ttf-hero__eyebrow">— PARADISE MALL · LAS VEGAS · BOOTH №18 —</p>
        <h1 class="ttf-hero__wordmark">TreasureTrove<br/><span>FINDS</span></h1>
        <p class="ttf-hero__tag">Fine Curiosities &amp; Relics · Curated History, Plain Prices</p>
        <div class="ttf-hero__rule"></div>
        <p class="ttf-hero__sub"><em>Every piece has a record.</em></p>
      </div>
    </div>

    <div data-hero-cue class="ttf-hero__cue" aria-hidden="true">
      <span>SCROLL TO ENTER</span>
      <span class="ttf-hero__cue-line"></span>
    </div>
  </section>

  <!-- =========================================================
       SECTION — STORY (cream, pure typography)
  ========================================================= -->
  <section id="story" class="ttf-story" data-reveal>
    <div class="ttf-story__inner">
      <p class="ttf-label">— Fifty Years on the Hunt —</p>
      <blockquote class="ttf-story__quote">
        &ldquo;It started with baseball cards. The numbers on the back. The years, the batting averages — the history hiding inside the data.&rdquo;
      </blockquote>
      <div class="ttf-story__body">
        <p>
          Cards turned into bottles. Bottles turned into signs. Signs turned into toys, and toys turned into anything with a story
          worth telling. Bill's been on the hunt since 1973, and every piece he buys comes back to the booth with its homework done —
          maker, era, provenance, the bit you tell guests when they pick it up off the shelf.
        </p>
        <p>
          Lisa came along and turned it into a life. The two of them work the Paradise Mall booth on Wednesdays and Sundays —
          Bill leaning on the counter, hands moving, talking like a man who's been waiting fifty years to tell you what you just
          picked up. It is, in his words, <em>not your sixth-grade Social Studies teacher's lecture.</em>
        </p>
        <p>
          What you're looking at is the back room. The cabinet. The records he's kept on every piece he's ever loved enough to keep.
        </p>
      </div>
      <p class="ttf-story__sig">— Bill &amp; Lisa Otranto</p>
    </div>
  </section>

  <!-- =========================================================
       SECTION — TONIGHT'S LINEUP (cream, 3 plates)
  ========================================================= -->
  <section id="lineup" class="ttf-lineup">
    <div class="ttf-lineup__inner" data-reveal>
      <BoxingBilling
        eyebrow="On the Shelf This Week"
        title="Tonight's Lineup"
        sub="Three pieces Bill is rooting for. Each one has its record on the tag."
      />
      <div class="ttf-lineup__grid">
        {LINEUP.map((it) => (
          <CatalogPlate
            plate={it.plate}
            item={it.item}
            era={it.era}
            note={it.note}
            price={it.price}
            photo={it.photo}
          />
        ))}
      </div>
      <p class="ttf-lineup__foot">
        <em>The rest of the room rotates weekly. Drop in to see what hasn't made it to the website yet.</em>
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION — THE RECORD (emerald felt punch)
  ========================================================= -->
  <section id="record" class="ttf-record ttf-on-emerald" data-reveal>
    <div class="ttf-record__inner">
      <p class="ttf-record__eyebrow">— EVERY PIECE HAS A —</p>
      <h2 class="ttf-record__title">Record</h2>
      <div class="ttf-billing-rules"></div>
      <figure class="ttf-record__figure">
        <img src="/photos/tag-perfume-bottle.jpg" alt="Bill's handwritten tag on a 1934 Ludwig Scherk perfume bottle" />
      </figure>
      <p class="ttf-record__caption">
        Other vendors write a price. Bill writes the record — in his own handwriting,
        on the back of every tag in the booth.
      </p>
    </div>
  </section>

  <!-- =========================================================
       SECTION — FIND THE JOINT (cream, map + card)
  ========================================================= -->
  <section id="find" class="ttf-find" data-reveal>
    <div class="ttf-find__inner">
      <div class="ttf-find__map">
        <iframe
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src={`https://maps.google.com/maps?q=${BOOTH.mapsQuery}&t=&z=15&ie=UTF8&iwloc=&output=embed`}
          title="Paradise Antique Mall — Booth #18"
        ></iframe>
      </div>
      <aside class="ttf-find__card">
        <p class="ttf-label">— Find the Joint —</p>
        <h3 class="ttf-find__name">Paradise Mall<br/><span>Booth №18</span></h3>
        <div class="ttf-double-rule"></div>
        <p class="ttf-find__addr">
          {BOOTH.address1}<br/>
          {BOOTH.city}
        </p>
        <p class="ttf-find__hours">
          <span class="ttf-label" style="letter-spacing:0.24em;">Hours</span><br/>
          {BOOTH.hours}
        </p>
        <p class="ttf-find__phone">
          <span class="ttf-label" style="letter-spacing:0.24em;">Ring Bill</span><br/>
          <a href={`tel:${BOOTH.phoneTel}`}>{BOOTH.phoneDisplay}</a>
        </p>
        <div class="ttf-find__buttons">
          <a class="ttf-btn ttf-btn-primary" href={`https://www.google.com/maps/dir/?api=1&destination=${BOOTH.mapsQuery}`} target="_blank" rel="noopener">Get Directions</a>
          <a class="ttf-btn ttf-btn-secondary" href={`tel:${BOOTH.phoneTel}`}>Call Bill</a>
        </div>
      </aside>
    </div>
  </section>

  <!-- =========================================================
       SECTION — ETSY (cream, minimal)
  ========================================================= -->
  <section id="etsy" class="ttf-etsy" data-reveal>
    <div class="ttf-etsy__inner">
      <p class="ttf-label">— Etsy's Coming —</p>
      <h2 class="ttf-etsy__title">Get the Word First.</h2>
      <p class="ttf-etsy__sub">
        We're cataloging the booth piece by piece. When the listings go live, the first 200 names on this list hear about it before
        anyone else.
      </p>
      <form class="ttf-etsy__form" action="https://formspree.io/f/placeholder" method="POST">
        <input type="email" name="email" required placeholder="your@email.com" aria-label="Email address" />
        <button type="submit" class="ttf-btn ttf-btn-primary">Put Me On The List</button>
      </form>
    </div>
  </section>

  <!-- =========================================================
       FOOTER
  ========================================================= -->
  <footer class="ttf-foot">
    <div class="ttf-foot__inner">
      <SunburstSeal size={86} est="2022" since="'73" />
      <p class="ttf-foot__name">TreasureTroveFinds</p>
      <p class="ttf-foot__line">
        Paradise Mall · Booth №18 · Las Vegas, NV
      </p>
      <p class="ttf-foot__line ttf-foot__phone">
        <a href={`tel:${BOOTH.phoneTel}`}>{BOOTH.phoneDisplay}</a>
      </p>
      <div class="ttf-foot__rule"></div>
      <p class="ttf-foot__legal">
        Est. 2022 · Collecting since '73 · Pieces back to 1850. Ask no questions.
      </p>
    </div>
  </footer>

  <script>
    import "../scripts/cabinet-scroll.ts";
  </script>

  <style>
    /* ==============================================
       HERO
    ============================================== */
    .ttf-hero {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
      background: #0e0a07;
    }
    .ttf-hero__stage {
      position: absolute;
      inset: -4% -4%;
      will-change: transform;
    }
    .ttf-hero__layer {
      position: absolute;
      inset: 0;
      will-change: transform, opacity;
    }
    .ttf-hero__layer img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: saturate(0.92) contrast(1.06);
    }
    .ttf-hero__vignette {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse at center, rgba(0,0,0,0) 35%, rgba(0,0,0,0.65) 100%),
        linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.15) 45%, rgba(0,0,0,0.7));
    }

    .ttf-hero__plate-wrap {
      position: absolute;
      inset: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 0 1.5rem;
      will-change: transform, opacity;
    }
    .ttf-hero__scrim {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse at center,
          rgba(0,0,0,0.7) 0%,
          rgba(0,0,0,0.55) 35%,
          rgba(0,0,0,0.0) 75%);
      pointer-events: none;
    }
    .ttf-hero__plate {
      position: relative;
      z-index: 2;
      max-width: 900px;
    }
    .ttf-hero__eyebrow {
      font-family: var(--font-label);
      letter-spacing: 0.42em;
      text-transform: uppercase;
      color: var(--color-brass);
      font-size: 0.7rem;
      margin: 0 0 1.25rem;
      text-shadow: 1px 1px 0 rgba(0,0,0,0.6);
    }
    .ttf-hero__wordmark {
      font-family: var(--font-display);
      font-size: clamp(58px, 10vw, 148px);
      line-height: 0.86;
      color: var(--color-cream);
      letter-spacing: 0.01em;
      margin: 0;
      text-shadow:
        3px 4px 0 rgba(0,0,0,0.7),
        0 2px 18px rgba(0,0,0,0.85),
        0 0 48px rgba(201,162,39,0.18);
    }
    .ttf-hero__wordmark span {
      color: var(--color-brass);
      font-style: italic;
      font-family: var(--font-billing);
      font-weight: 700;
      letter-spacing: 0.18em;
      font-size: 0.55em;
      display: inline-block;
      transform: translateY(-0.05em);
    }
    .ttf-hero__tag {
      font-family: var(--font-billing);
      font-style: italic;
      color: var(--color-cream);
      opacity: 0.86;
      font-size: clamp(13px, 1.4vw, 16px);
      margin: 1rem 0 0.75rem;
      letter-spacing: 0.04em;
    }
    .ttf-hero__rule {
      width: 220px;
      max-width: 70vw;
      height: 1.2px;
      background: var(--color-brass);
      margin: 0.75rem auto;
      position: relative;
    }
    .ttf-hero__rule::before {
      content: "✦";
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      color: var(--color-brass);
      background: rgba(0,0,0,0.6);
      padding: 0 10px;
      font-size: 14px;
    }
    .ttf-hero__sub {
      font-family: var(--font-billing);
      color: var(--color-cream);
      font-style: italic;
      font-size: clamp(14px, 1.6vw, 19px);
      margin: 0.5rem 0 0;
      letter-spacing: 0.02em;
    }

    .ttf-hero__cue {
      position: absolute;
      bottom: 2.25rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      color: var(--color-brass);
      font-family: var(--font-label);
      letter-spacing: 0.38em;
      font-size: 0.66rem;
      text-transform: uppercase;
    }
    .ttf-hero__cue-line {
      width: 1.5px;
      height: 36px;
      background: var(--color-brass);
      animation: ttf-cue-pulse 1.8s ease-in-out infinite;
      transform-origin: top center;
    }
    @keyframes ttf-cue-pulse {
      0%, 100% { transform: scaleY(0.6); opacity: 0.5; }
      50% { transform: scaleY(1); opacity: 1; }
    }

    /* ==============================================
       STORY
    ============================================== */
    .ttf-story {
      position: relative;
      padding: 7.5rem 1.5rem 6rem;
    }
    .ttf-story__inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
    }
    .ttf-story__inner .ttf-label {
      display: block;
      margin: 0 0 2rem;
    }
    .ttf-story__quote {
      font-family: var(--font-billing);
      font-style: italic;
      font-weight: 400;
      font-size: clamp(22px, 3.2vw, 36px);
      line-height: 1.25;
      color: var(--color-ink);
      margin: 0 0 3rem;
      position: relative;
    }
    .ttf-story__quote::before,
    .ttf-story__quote::after {
      color: var(--color-brass);
      font-family: var(--font-billing);
      font-size: 1.4em;
      line-height: 0;
      position: relative;
      top: 0.18em;
    }
    .ttf-story__body {
      text-align: left;
      font-family: var(--font-serif);
      color: var(--color-ink);
      font-size: 17px;
      line-height: 1.7;
      max-width: 600px;
      margin: 0 auto;
    }
    .ttf-story__body p {
      margin: 0 0 1.1rem;
    }
    .ttf-story__sig {
      font-family: var(--font-hand);
      color: var(--color-walnut);
      font-size: 22px;
      margin: 2.25rem 0 0;
      letter-spacing: 0.01em;
      transform: rotate(-1.5deg);
      display: inline-block;
    }

    /* ==============================================
       LINEUP
    ============================================== */
    .ttf-lineup {
      padding: 5rem 1.5rem 6rem;
      background:
        linear-gradient(180deg, rgba(61,42,30,0.04), rgba(61,42,30,0));
    }
    .ttf-lineup__inner {
      max-width: 1180px;
      margin: 0 auto;
    }
    .ttf-lineup__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
      margin: 3rem 0 1.5rem;
    }
    .ttf-lineup__foot {
      text-align: center;
      font-family: var(--font-billing);
      color: var(--color-smoke);
      font-size: 15px;
      margin: 2rem 0 0;
    }

    /* ==============================================
       RECORD (emerald punch)
    ============================================== */
    .ttf-record {
      background: var(--color-emerald);
      padding: 6.5rem 1.5rem 7rem;
      position: relative;
    }
    .ttf-record::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1.4px),
        radial-gradient(rgba(0,0,0,0.18) 1px, transparent 1.4px);
      background-size: 4px 4px, 9px 9px;
      background-position: 0 0, 2px 2px;
      pointer-events: none;
    }
    .ttf-record__inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
      position: relative;
    }
    .ttf-record__eyebrow {
      font-family: var(--font-label);
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--color-brass);
      font-size: 0.72rem;
      margin: 0 0 0.5rem;
    }
    .ttf-record__title {
      font-family: var(--font-display);
      color: var(--color-cream);
      font-size: clamp(56px, 9vw, 120px);
      line-height: 0.9;
      letter-spacing: 0.005em;
      margin: 0 0 1rem;
      text-shadow: 2px 3px 0 rgba(0,0,0,0.4);
    }
    .ttf-record__figure {
      margin: 3rem auto 1.75rem;
      max-width: 560px;
      padding: 14px;
      background: var(--color-emerald);
      border: 1.5px solid var(--color-brass);
      position: relative;
      box-shadow:
        0 18px 48px rgba(0,0,0,0.4),
        inset 0 0 0 1px rgba(201,162,39,0.25);
    }
    .ttf-record__figure::before,
    .ttf-record__figure::after {
      content: "";
      position: absolute;
      width: 22px; height: 22px;
      border: 1.5px solid var(--color-brass);
    }
    .ttf-record__figure::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
    .ttf-record__figure::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
    .ttf-record__figure img {
      width: 100%;
      display: block;
      filter: saturate(0.95) contrast(1.04);
    }
    .ttf-record__caption {
      font-family: var(--font-billing);
      font-style: italic;
      color: var(--color-cream);
      opacity: 0.92;
      font-size: clamp(15px, 1.7vw, 20px);
      line-height: 1.55;
      margin: 1.25rem auto 0;
      max-width: 520px;
    }

    /* ==============================================
       FIND THE JOINT
    ============================================== */
    .ttf-find {
      padding: 6rem 1.5rem;
    }
    .ttf-find__inner {
      max-width: 1180px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 2.5rem;
      align-items: stretch;
    }
    .ttf-find__map {
      position: relative;
      border: 1.5px solid var(--color-walnut);
      background: var(--color-walnut);
      box-shadow: 6px 6px 0 rgba(26,22,20,0.18);
      min-height: 460px;
    }
    .ttf-find__map iframe {
      width: 100%;
      height: 100%;
      min-height: 460px;
      border: 0;
      display: block;
      filter: sepia(0.18) saturate(0.85) contrast(1.04);
    }
    .ttf-find__card {
      background: var(--color-cream);
      border: 1.5px solid var(--color-walnut);
      padding: 2.5rem 2rem;
      box-shadow: 6px 6px 0 rgba(26,22,20,0.18);
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .ttf-find__card::before,
    .ttf-find__card::after {
      content: "";
      position: absolute;
      width: 22px; height: 22px;
      border: 1.5px solid var(--color-brass);
    }
    .ttf-find__card::before { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
    .ttf-find__card::after  { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }
    .ttf-find__name {
      font-family: var(--font-display);
      color: var(--color-buddy-red);
      font-size: clamp(36px, 4.5vw, 54px);
      line-height: 0.95;
      letter-spacing: 0.005em;
      margin: 0.5rem 0 0;
      text-shadow: 2px 2px 0 rgba(26,22,20,0.14);
    }
    .ttf-find__name span {
      font-family: var(--font-billing);
      font-style: italic;
      font-weight: 700;
      color: var(--color-walnut);
      font-size: 0.6em;
      letter-spacing: 0.04em;
    }
    .ttf-find__addr,
    .ttf-find__hours,
    .ttf-find__phone {
      font-family: var(--font-serif);
      color: var(--color-ink);
      font-size: 16px;
      line-height: 1.5;
      margin: 1rem 0 0;
    }
    .ttf-find__phone a {
      font-family: var(--font-display);
      color: var(--color-buddy-red);
      font-size: 26px;
      text-decoration: none;
      letter-spacing: 0.01em;
    }
    .ttf-find__buttons {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      margin-top: 1.75rem;
    }

    /* ==============================================
       ETSY
    ============================================== */
    .ttf-etsy {
      padding: 5rem 1.5rem 6.5rem;
      background:
        linear-gradient(180deg, rgba(61,42,30,0), rgba(61,42,30,0.04));
    }
    .ttf-etsy__inner {
      max-width: 620px;
      margin: 0 auto;
      text-align: center;
    }
    .ttf-etsy__title {
      font-family: var(--font-display);
      color: var(--color-buddy-red);
      font-size: clamp(40px, 6vw, 68px);
      line-height: 0.95;
      letter-spacing: 0.005em;
      margin: 0.75rem 0 1rem;
      text-shadow: 2px 2px 0 rgba(26,22,20,0.14);
    }
    .ttf-etsy__sub {
      font-family: var(--font-serif);
      color: var(--color-ink);
      font-size: 16px;
      line-height: 1.6;
      max-width: 480px;
      margin: 0 auto 2rem;
    }
    .ttf-etsy__form {
      display: flex;
      gap: 0.5rem;
      max-width: 460px;
      margin: 0 auto;
      flex-wrap: wrap;
      justify-content: center;
    }
    .ttf-etsy__form input {
