---
/**
 * The Marquee — Vegas Vaudeville Show-Bill, Night of Engagement.
 * Concept #?: a 1928 vaudeville/boxing-card programme.
 * Marquee bulbs sequence-on at load, then settle into a slow twinkle.
 */
import Layout from "../../layouts/Layout.astro";
import Marquee from "../../components/concepts/marquee/Marquee.astro";
import ReelHeader from "../../components/concepts/marquee/ReelHeader.astro";
import Ribbon from "../../components/concepts/marquee/Ribbon.astro";
import CornerStamp from "../../components/concepts/marquee/CornerStamp.astro";
import CatalogPlate from "../../components/concepts/marquee/CatalogPlate.astro";

const lineup = [
  {
    plate: "PLATE NO. I",
    name: "1934 LUDWIG SCHERK PERFUME BOTTLE",
    era: "German, Renaissance figural, Marie Antoinette stopper",
    note: "Pulled it out of a Long Island estate. Cobalt's intact, the stopper still seats. Don't see these.",
    price: "$225",
    img: "/photos/tag-perfume-bottle.jpg",
    imgAlt: "1934 Ludwig Scherk Renaissance perfume bottle with Marie Antoinette figural stopper",
  },
  {
    plate: "PLATE NO. II",
    name: "1930s HOBBY KIDDIE RACE CAR",
    era: "American pressed-steel diecast, late Depression, hand-painted",
    note: "Hobby Kiddie ran small — most pressed-steels of the era were Buddy L or Marx. Survivor.",
    price: "$65",
    img: "/photos/tag-race-car.jpg",
    imgAlt: "1930s-40s Hobby Kiddie diecast race car",
  },
  {
    plate: "PLATE NO. III",
    name: "1930s GE CAST-IRON OSCILLATING FAN",
    era: "General Electric, brass blade cage, original cord, runs",
    note: "Plugged it in. Still moves the air like it's 1937. Heavy as a paperweight from hell.",
    price: "ASK BILL",
    img: "/photos/fan-perfumes.jpg",
    imgAlt: "1930s GE cast-iron oscillating fan on the booth shelf",
  },
  {
    plate: "PLATE NO. IV",
    name: "STILL ON THE FLOOR",
    era: "Bill's working his way through a shipment this week",
    note: "Whatever lands on the case Wednesday lands here Sunday. Worth the drive.",
    price: "—",
    placeholder: true,
  },
];
---

<Layout
  title="TreasureTroveFinds · Tonight's Engagement · Booth #18"
  description="The Marquee at Booth #18, Paradise Mall, Las Vegas. One-night-only programme of pieces curated by Bill — every piece has a record."
>
  <main class="show-bill">

    <!-- ============================================================ -->
    <!-- THE MARQUEE                                                   -->
    <!-- ============================================================ -->
    <Marquee />

    <!-- ============================================================ -->
    <!-- REEL ONE — BRAND PROMISE HERO BILLING                         -->
    <!-- ============================================================ -->
    <section class="reel reel-one">
      <div class="stamps stamps-top">
        <CornerStamp text="One Night Only" rotation={-8} />
        <CornerStamp text="No Cover" rotation={6} />
      </div>

      <ReelHeader
        numeral="I"
        kicker="— FROM THE PROPRIETOR —"
        title="EVERY PIECE HAS A RECORD."
        subhead="Other vendors write a price on a tag. Bill writes the record — the maker, the year, the homework. Fifty years of it, on every tag, in his own hand."
      />

      <div class="hero-billing">
        <Ribbon text="Tonight at Booth 18" />
        <p class="hero-flourish">
          Curated history. Plain prices. <em>Known to the right people.</em>
        </p>
      </div>

      <div class="hero-image-wrap">
        <div class="hero-frame">
          <img
            src="/photos/booth-wide.jpg"
            alt="Booth #18 at Paradise Mall — Bill and Lisa's curated antique floor"
            loading="eager"
          />
        </div>
        <p class="hero-caption">
          <span class="cap-label">THE HOUSE</span> ·
          Paradise Mall, 3565 E. Flamingo Road, Las Vegas
        </p>
      </div>
    </section>

    <hr class="ttf-triple-rule" />

    <!-- ============================================================ -->
    <!-- REEL TWO — TONIGHT'S LINEUP                                   -->
    <!-- ============================================================ -->
    <section class="reel reel-two">
      <ReelHeader
        numeral="II"
        kicker="— FEATURING —"
        title="TONIGHT'S LINEUP"
        subhead="Four pieces pulled from the case for the night. Take a look. If one talks to you, the booth's open Wednesday and Sunday."
      />

      <div class="lineup-stamp">
        <CornerStamp text="Held Over By Popular Demand" rotation={-4} />
      </div>

      <div class="plates-grid">
        {lineup.map((item) => (
          <CatalogPlate
            plate={item.plate}
            name={item.name}
            era={item.era}
            note={item.note}
            price={item.price}
            img={item.img}
            imgAlt={item.imgAlt}
            placeholder={item.placeholder}
          />
        ))}
      </div>

      <p class="lineup-foot">
        Prices in oldstyle figures. Cash, card, handshake — Bill takes the lot.
      </p>
    </section>

    <hr class="ttf-triple-rule" />

    <!-- ============================================================ -->
    <!-- REEL THREE — HOW WE GOT HERE                                  -->
    <!-- ============================================================ -->
    <section class="reel reel-three">
      <ReelHeader
        numeral="III"
        kicker="— FROM THE WINGS —"
        title="HOW WE GOT HERE"
        subhead="A short bill on the man who runs the booth. Tell him you read it; he'll laugh."
      />

      <div class="origin-spread">
        <aside class="origin-side">
          <div class="origin-portrait">
            <img src="/photos/case-buddy-l-trucks.jpg" alt="Bill's case of pressed-steel toy trucks" />
          </div>
          <p class="origin-cap">
            <span class="cap-label">CASE NO. 03</span> ·
            Toys, trucks, and pressed steel
          </p>
        </aside>

        <div class="origin-body">
          <p class="lead">
            <span class="dropcap">B</span>ill started with <em>baseball cards</em> — six, seven years old, flipping them
            for the numbers on the back. Not the front. The <em>back</em>. Stats. Years. Batting
            averages. The history hiding inside the data. He was the kid who knew
            who hit .342 in '36, and didn't think that was strange.
          </p>
          <p>
            Cards turned into bottles. Bottles turned into signs. Signs turned
            into toys, advertising, and anything else with a story he hadn't
            heard yet. It was never <em>antique</em> the way the magazines mean it.
            It was <em>nostalgic</em>. The pieces remembered a country he never lived
            in, and he wanted to know how they remembered.
          </p>
          <p>
            Lisa came along and made it a life. She has the eye for what people
            will love, he has the ear for what they'll buy. The booth is the two
            of them, fifty years in.
          </p>
          <p>
            Catch Bill in the booth and you'll see it — he leans on the case,
            picks a piece up, and starts in. It is <em>not</em> your sixth-grade
            Social Studies lecture. It's the version your uncle would tell after
            two beers. That's the part the tag can't carry. That's why you
            come to Flamingo Road.
          </p>
        </div>
      </div>
    </section>

    <hr class="ttf-triple-rule" />

    <!-- ============================================================ -->
    <!-- REEL FOUR — FIND THE JOINT                                    -->
    <!-- ============================================================ -->
    <section class="reel reel-four">
      <ReelHeader
        numeral="IV"
        kicker="— DIRECTIONS, HOURS, AND THE PHONE —"
        title="FIND THE JOINT"
        subhead="Paradise Mall. Booth eighteen. Open daily. Bill works the floor Wednesdays and Sundays."
      />

      <div class="joint-grid">
        <div class="joint-map">
          <iframe
            src="https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed"
            title="Map to Paradise Mall, 3565 E. Flamingo Road, Las Vegas, NV"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>

        <aside class="joint-card">
          <div class="jc-stamp">
            <CornerStamp text="Known to the Right People" rotation={-5} />
          </div>

          <p class="jc-label">— THE HOUSE —</p>
          <p class="jc-title">PARADISE MALL · BOOTH #18</p>
          <p class="jc-text">
            3565 E. Flamingo Road<br />
            Las Vegas, Nevada 89121
          </p>

          <div class="ttf-billing-rules"></div>

          <p class="jc-label">— HOURS —</p>
          <p class="jc-text">
            Open daily, 10 'til 6.<br />
            Bill works the booth <em>Wednesdays &amp; Sundays</em>.
          </p>

          <div class="ttf-billing-rules"></div>

          <p class="jc-label">— RING BILL UP —</p>
          <p class="jc-phone">(516) 446-2693</p>
          <p class="jc-italic">
            He likes to talk. Call ahead and he'll set things aside.
          </p>

          <div class="jc-cta-row">
            <a
              class="ttf-btn ttf-btn-primary"
              href="https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121"
              target="_blank"
              rel="noopener"
            >Get Directions</a>
            <a
              class="ttf-btn ttf-btn-secondary"
              href="tel:+15164462693"
            >Call Bill</a>
          </div>
        </aside>
      </div>
    </section>

    <hr class="ttf-triple-rule" />

    <!-- ============================================================ -->
    <!-- REEL FIVE — ETSY'S COMING                                     -->
    <!-- ============================================================ -->
    <section class="reel reel-five">
      <ReelHeader
        numeral="V"
        kicker="— A WORD FROM THE PROPRIETORS —"
        title="ETSY'S COMING."
        subhead="We're working through the catalog now. When the listings go live, the people on the list hear first. That's the deal."
      />

      <div class="etsy-card">
        <p class="etsy-we">
          We've been picking shipments apart all winter to find the pieces that
          travel. The first thirty go up when they're ready — not before.
          If you want first look, drop your address. We won't pester you.
          <em>— Bill &amp; Lisa</em>
        </p>

        <form class="etsy-form" onsubmit="return false;">
          <label class="etsy-label" for="email">YOUR&nbsp;ADDRESS</label>
          <div class="etsy-row">
            <input
              id="email"
              type="email"
              required
              placeholder="you@somewhere.com"
              class="etsy-input"
            />
            <button type="submit" class="ttf-btn ttf-btn-primary">Get on the List</button>
          </div>
          <p class="etsy-fineprint">No newsletter. No sales funnel. One note when listings drop.</p>
        </form>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- CLOSING CURTAIN                                               -->
    <!-- ============================================================ -->
    <footer class="curtain">
      <div class="curtain-rule"></div>
      <p class="curtain-line-1">
        Est. 2022 · Collecting since 1973 · Pieces back to 1850.<br />
        <em>Bill knows everybody. Ask no questions.</em>
      </p>
      <p class="curtain-line-2">
        TREASURE&nbsp;TROVE&nbsp;FINDS&nbsp;·&nbsp;PARADISE&nbsp;MALL&nbsp;·&nbsp;BOOTH&nbsp;#18&nbsp;·&nbsp;LAS&nbsp;VEGAS,&nbsp;NEVADA
      </p>
      <p class="curtain-line-3">
        An Otranto Labs project
      </p>
    </footer>

  </main>
</Layout>

<style>
  .show-bill {
    max-width: 100%;
    overflow-x: hidden;
  }

  .reel {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 1rem;
    position: relative;
  }

  /* ---------- Reel One ---------- */
  .stamps {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    max-width: 64rem;
    margin: 1rem auto -0.5rem;
    padding: 0 1.5rem;
    position: relative;
    z-index: 2;
  }
  .stamps-top { margin-top: 1.5rem; }

  .hero-billing {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin: 1.5rem auto 1.25rem;
  }
  .hero-flourish {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 1.1rem;
    text-align: center;
    max-width: 36rem;
    margin: 0;
    line-height: 1.45;
  }

  .hero-image-wrap {
    max-width: 52rem;
    margin: 0 auto;
    text-align: center;
  }
  .hero-frame {
    background: var(--color-walnut);
    padding: 12px;
    box-shadow:
      inset 0 0 0 1.5px rgba(201,162,39,0.55),
      inset 0 0 0 7px var(--color-walnut),
      4px 4px 0 rgba(26,22,20,0.22);
    position: relative;
  }
  .hero-frame img {
    display: block;
    width: 100%;
    height: auto;
    filter: saturate(0.92) contrast(1.03);
  }
  .hero-caption {
    margin-top: 0.7rem;
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.95rem;
  }
  .cap-label {
    font-family: var(--font-label);
    font-style: normal;
    color: var(--color-brass);
    letter-spacing: 0.28em;
    font-size: 0.72rem;
    margin-right: 0.35rem;
  }

  /* ---------- Reel Two ---------- */
  .lineup-stamp {
    display: flex;
    justify-content: center;
    margin: 1rem 0 1.5rem;
  }
  .plates-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.75rem;
    max-width: 56rem;
    margin: 0 auto;
  }
  .lineup-foot {
    text-align: center;
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    margin: 1.75rem auto 0;
    max-width: 32rem;
    font-size: 0.95rem;
  }

  /* ---------- Reel Three ---------- */
  .origin-spread {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 2.25rem;
    max-width: 56rem;
    margin: 1.75rem auto 0;
    align-items: start;
  }
  .origin-portrait {
    background: var(--color-walnut);
    padding: 10px;
    box-shadow:
      inset 0 0 0 1.5px rgba(201,162,39,0.5),
      4px 4px 0 rgba(26,22,20,0.22);
  }
  .origin-portrait img {
    width: 100%;
    height: auto;
    display: block;
    filter: saturate(0.85) contrast(1.05) sepia(0.08);
  }
  .origin-cap {
    margin: 0.6rem 0 0;
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.9rem;
  }
  .origin-body {
    font-family: var(--font-serif);
    color: var(--color-ink);
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .origin-body p { margin: 0 0 0.95rem; }
  .lead .dropcap {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 3.25rem;
    line-height: 0.8;
    float: left;
    padding: 0.18rem 0.55rem 0 0;
    text-shadow: 2px 2px 0 rgba(26,22,20,0.15);
  }
  .origin-body em {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-buddy-red);
  }

  /* ---------- Reel Four ---------- */
  .joint-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 1.75rem;
    max-width: 60rem;
    margin: 1.75rem auto 0;
    align-items: stretch;
  }
  .joint-map {
    background: var(--color-walnut);
    padding: 10px;
    box-shadow:
      inset 0 0 0 1.5px rgba(201,162,39,0.5),
      4px 4px 0 rgba(26,22,20,0.22);
    min-height: 360px;
    display: flex;
  }
  .joint-map iframe {
    width: 100%;
    height: 100%;
    min-height: 340px;
    border: 0;
    filter: sepia(0.12) saturate(0.85);
    flex: 1;
  }

  .joint-card {
    background: var(--color-cream);
    border: 1.5px solid var(--color-walnut);
    box-shadow:
      inset 0 0 0 4px var(--color-cream),
      inset 0 0 0 5px rgba(201,162,39,0.55),
      4px 4px 0 rgba(26,22,20,0.22);
    padding: 1.5rem 1.4rem 1.4rem;
    position: relative;
  }
  .jc-stamp {
    position: absolute;
    top: -0.6rem;
    right: -0.6rem;
  }
  .jc-label {
    font-family: var(--font-label);
    color: var(--color-brass);
    letter-spacing: 0.3em;
    font-size: 0.72rem;
    margin: 0.4rem 0 0.25rem;
    text-align: center;
  }
  .jc-title {
    font-family: var(--font-display);
    color: var(--color-ink);
    font-size: 1.5rem;
    line-height: 1.05;
    margin: 0 0 0.45rem;
    text-align: center;
    letter-spacing: 0.012em;
  }
  .jc-text {
    font-family: var(--font-billing);
    color: var(--color-ink);
    font-size: 1rem;
    line-height: 1.45;
    margin: 0 0 0.5rem;
    text-align: center;
  }
  .jc-text em {
    color: var(--color-buddy-red);
    font-style: italic;
  }
  .jc-phone {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 1.85rem;
    line-height: 1;
    margin: 0.2rem 0 0.35rem;
    text-align: center;
    text-shadow: 1.5px 1.5px 0 rgba(26,22,20,0.18);
  }
  .jc-italic {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.95rem;
    margin: 0 0 1rem;
    text-align: center;
  }
  .jc-cta-row {
    display: flex;
    gap: 0.65rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.4rem;
  }

  /* ---------- Reel Five ---------- */
  .etsy-card {
    max-width: 42rem;
    margin: 1.5rem auto 0;
    background: var(--color-cream);
    border: 1.5px solid var(--color-walnut);
    padding: 1.75rem 1.5rem;
    box-shadow:
      inset 0 0 0 4px var(--color-cream),
      inset 0 0 0 5px rgba(201,162,39,0.55),
      4px 4px 0 rgba(26,22,20,0.22);
  }
  .etsy-we {
    font-family: var(--font-serif);
    color: var(--color-ink);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 0 1.25rem;
    text-align: center;
  }
  .etsy-we em {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-buddy-red);
  }

  .etsy-form {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .etsy-label {
    font-family: var(--font-label);
    color: var(--color-brass);
    letter-spacing: 0.32em;
    font-size: 0.72rem;
  }
  .etsy-row {
    display: flex;
    gap: 0.55rem;
    width: 100%;
    max-width: 32rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .etsy-input {
    flex: 1 1 18rem;
    background: var(--color-tag-paper);
    border: 1.5px solid var(--color-walnut);
    padding: 0.75rem 0.85rem;
    font-family: var(--font-billing);
    font-size: 1rem;
    color: var(--color-ink);
    box-shadow: inset 2px 2px 0 rgba(26,22,20,0.08);
  }
  .etsy-input::placeholder {
    color: var(--color-smoke);
    font-style: italic;
  }
  .etsy-input:focus {
    outline: 2px solid var(--color-buddy-red);
    outline-offset: 1px;
  }
  .etsy-fineprint {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.85rem;
    margin: 0.65rem 0 0;
  }

  /* ---------- Closing Curtain ---------- */
  .curtain {
    margin-top: 3rem;
    background:
      repeating-linear-gradient(
        90deg,
        rgba(26,22,20,0.08) 0px,
        rgba(26,22,20,0.08) 1px,
        transparent 1px,
        transparent 6px
      ),
      linear-gradient(180deg, #3d2a1e 0%, #2a1c12 100%);
    color: var(--color-cream);
    text-align: center;
    padding: 2.5rem 1.25rem 3rem;
    border-top: 4px double var(--color-brass);
    position: relative;
  }
  .curtain-rule {
    width: 8rem;
    height: 6px;
    margin: 0 auto 1.25rem;
    border-top: 1.5px solid var(--color-brass);
    border-bottom: 1.5px solid var(--color-brass);
    position: relative;
  }
  .curtain-rule::after {
    content: "◆";
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    color: var(--color-brass);
    background: var(--color-walnut);
    padding: 0 8px;
  }
  .curtain-line-1 {
    font-family: var(--font-billing);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0 0 1.25rem;
    color: var(--color-cream);
  }
  .curtain-line-1 em {
    color: var(--color-brass);
    font-style: italic;
  }
  .curtain-line-2 {
    font-family: var(--font-label);
    color: var(--color-brass);
    letter-spacing: 0.34em;
    font-size: 0.78rem;
    margin: 0 0 1.4rem;
  }
  .curtain-line-3 {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 0.85rem;
    margin: 0;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 760px) {
    .plates-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .origin-spread {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    .joint-grid {
      grid-template-columns: 1fr;
    }
    .joint-map { min-height: 280px; }
    .joint-map iframe { min-height: 260px; }
    .stamps { padding: 0 0.5rem; }
    .reel { padding: 1.75rem 1rem 0.75rem; }
    .curtain-line-2 { letter-spacing: 0.2em; font-size: 0.7rem; }
  }
</style>
