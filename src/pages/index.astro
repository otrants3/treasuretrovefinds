---
import Layout from "../layouts/Layout.astro";
import SunburstSeal from "../components/SunburstSeal.astro";

const REAL_ASSET_CONCEPTS = [
  {
    slug: "gamma",
    no: "γ",
    name: "The Real Cabinet (photo composite)",
    blurb: "Built on actual antique-curio-cabinet photography. Doors-closed → doors-open crossfade on load (real photos, not CSS). Each section uses a different real cabinet/shelf photo as its backdrop with content laid over.",
    tone: "real photo · believable furniture · ships today",
    href: "/concepts/gamma",
    flag: "Recommended",
  },
  {
    slug: "delta",
    no: "δ",
    name: "Real 3D Cabinet (Three.js)",
    blurb: "Actual real-time WebGL cabinet built from primitive geometry + real wood texture. Two glass doors swing open in true 3D on load. Mouse-move parallax. Custom-built, runs in the browser.",
    tone: "real 3D · interactive · world-class polish",
    href: "/concepts/delta",
    flag: "Most unique",
  },
  {
    slug: "alpha-stub",
    no: "α",
    name: "AI-Generated Cabinet (needs Gemini key)",
    blurb: "When you drop a GEMINI_API_KEY into the project env, I can generate a custom photorealistic cabinet image set (closed, open, brass details, interior lighting) and composite them. Until then, GAMMA is the closest real-photo equivalent.",
    tone: "blocked · needs your key · ~2 min to enable",
    href: "/concepts/gamma",
    flag: "Blocked",
  },
  {
    slug: "beta-stub",
    no: "β",
    name: "3D Model Embed (Sketchfab / model-viewer)",
    blurb: "Would embed a free CC0 antique cabinet .glb via Google's model-viewer or a Sketchfab iframe. I haven't found a perfect cabinet model yet — if you point me to one on Sketchfab you like, I'll wire it up.",
    tone: "needs model · 30 min to wire up",
    href: "/concepts/delta",
    flag: "Pending model",
  },
];

const PREVIOUS_CONCEPTS = [
  { slug: "the-cabinet", no: "v4", name: "The CSS Cabinet (the one you said was crap)", blurb: "The previous attempt — drawn entirely in CSS. Confirmed not believable as furniture. Kept for comparison.", href: "/concepts/the-cabinet" },
  { slug: "walk-in", no: "v3·a", name: "The Walk-In", blurb: "Cinematic lights-come-on parallax scroll. No cabinet, just the room.", href: "/concepts/walk-in" },
  { slug: "notebook", no: "v3·b", name: "Bill's Notebook", blurb: "Hand-bound notebook with taped polaroids and red-pen margins.", href: "/concepts/notebook" },
  { slug: "card-catalog", no: "v3·c", name: "The Card Catalog", blurb: "Library card-catalog drawers that pull open with typed index cards.", href: "/concepts/card-catalog" },
  { slug: "auction", no: "v3·d", name: "The Auction Catalogue", blurb: "Christie's-style full-screen LOT spreads.", href: "/concepts/auction" },
  { slug: "marquee", no: "v3·e", name: "The Marquee", blurb: "Vaudeville show-bill with brass bulbs that light up on load.", href: "/concepts/marquee" },
];
---

<Layout title="Treasure Trove Finds — Pick a Cabinet">
  <header class="pk-mast">
    <div class="pk-mast__inner">
      <div class="pk-mast__center">
        <p class="pk-mast__eyebrow">— Concept Catalogue · Real-Asset Round —</p>
        <h1 class="pk-mast__wordmark">TREASURE TROVE FINDS</h1>
        <p class="pk-mast__sub">
          New round, built on <em>real cabinet photography and real 3D.</em> Pick a cabinet.
        </p>
      </div>
      <div class="pk-mast__seal">
        <SunburstSeal size={108} est="2022" since="'73" />
      </div>
    </div>
    <div class="pk-rule"></div>
  </header>

  <section class="pk-section">
    <h2 class="pk-section__title">Real Assets — built today</h2>
    <p class="pk-section__sub">Each of these uses actual photography or actual 3D, not CSS gradients pretending to be wood.</p>
    <div class="pk-grid">
      {REAL_ASSET_CONCEPTS.map((c) => (
        <a class={`pk-card pk-card--${c.slug}`} href={c.href}>
          {c.flag && <span class="pk-card__flag">{c.flag}</span>}
          <div class="pk-card__plate">
            <span class="pk-card__no">{c.no}</span>
            <h2 class="pk-card__name">{c.name}</h2>
          </div>
          <p class="pk-card__blurb">{c.blurb}</p>
          <p class="pk-card__tone">{c.tone}</p>
          <span class="pk-card__cta">Step inside <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <section class="pk-section pk-section--prev">
    <h2 class="pk-section__title">Previous round — kept for reference</h2>
    <p class="pk-section__sub">Concepts from the last few iterations. Still browsable in case anything's worth borrowing.</p>
    <div class="pk-grid pk-grid--mini">
      {PREVIOUS_CONCEPTS.map((c) => (
        <a class="pk-card pk-card--mini" href={c.href}>
          <div class="pk-card__plate">
            <span class="pk-card__no">{c.no}</span>
            <h3 class="pk-card__name pk-card__name--sm">{c.name}</h3>
          </div>
          <p class="pk-card__blurb pk-card__blurb--sm">{c.blurb}</p>
          <span class="pk-card__cta">Open →</span>
        </a>
      ))}
    </div>
  </section>

  <footer class="pk-foot">
    <p>
      Pick a winner from the top row. Tell me what to fix on the chosen one and I'll iterate.
      Once you settle, I promote that concept to <code>/</code> and we ship a real domain.
    </p>
    <p class="pk-foot__legal">
      TREASURE TROVE FINDS · PARADISE MALL · BOOTH #18 · LAS VEGAS, NEVADA · <em>An Otranto Labs project</em>
    </p>
  </footer>
</Layout>

<style>
  .pk-mast { max-width: 1280px; margin: 0 auto; padding: 32px 32px 0; }
  .pk-mast__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 24px;
    align-items: center;
  }
  @media (max-width: 720px) {
    .pk-mast__inner { grid-template-columns: 1fr; text-align: center; }
    .pk-mast__seal { justify-self: center; }
  }
  .pk-mast__center { text-align: center; }
  .pk-mast__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 12px;
    margin: 0;
  }
  .pk-mast__wordmark {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: clamp(40px, 6.4vw, 86px);
    line-height: 0.92;
    letter-spacing: 0.012em;
    margin: 10px 0 6px;
    text-shadow: 2px 2px 0 rgba(26,22,20,0.18);
    transform: rotate(-0.4deg);
  }
  .pk-mast__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    font-size: 18px;
    margin: 0;
  }
  .pk-mast__sub em { color: var(--color-walnut); }
  .pk-rule {
    border-top: 1.6px solid var(--color-brass);
    border-bottom: 1.6px solid var(--color-brass);
    height: 5px;
    margin: 20px 0 0;
    position: relative;
  }
  .pk-rule::after {
    content: "✦";
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    color: var(--color-brass);
    background: var(--color-cream);
    padding: 0 14px;
    font-size: 18px;
  }

  .pk-section {
    max-width: 1280px;
    margin: 56px auto;
    padding: 0 32px;
  }
  .pk-section--prev { margin-top: 80px; opacity: 0.78; }
  .pk-section__title {
    font-family: var(--font-billing);
    font-weight: 700;
    color: var(--color-ink);
    font-size: clamp(24px, 3vw, 34px);
    letter-spacing: 0.005em;
    margin: 0 0 6px;
    text-align: center;
  }
  .pk-section__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    text-align: center;
    margin: 0 0 28px;
  }

  .pk-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
  }
  @media (max-width: 720px) { .pk-grid { grid-template-columns: 1fr; } }
  .pk-grid--mini {
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  @media (max-width: 880px) { .pk-grid--mini { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .pk-grid--mini { grid-template-columns: 1fr; } }

  .pk-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--color-cream);
    color: var(--color-ink);
    text-decoration: none;
    border: 1.5px solid var(--color-walnut);
    box-shadow: 4px 5px 0 rgba(26,22,20,0.22);
    padding: 26px 26px 28px;
    transition: transform 120ms ease-out, box-shadow 120ms ease-out;
  }
  .pk-card::before, .pk-card::after {
    content: "";
    position: absolute;
    width: 14px; height: 14px;
    border: 1.5px solid var(--color-brass);
  }
  .pk-card::before { top: -1px; left: -1px; border-right: 0; border-bottom: 0; }
  .pk-card::after  { bottom: -1px; right: -1px; border-left: 0; border-top: 0; }
  .pk-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 7px 0 rgba(26,22,20,0.28);
  }
  .pk-card__flag {
    position: absolute;
    top: 10px; right: 14px;
    background: var(--color-buddy-red);
    color: var(--color-cream);
    padding: 4px 10px;
    font-family: var(--font-label);
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    box-shadow: 2px 2px 0 rgba(26,22,20,0.3);
    transform: rotate(3deg);
  }
  .pk-card__plate {
    display: flex;
    align-items: baseline;
    gap: 14px;
    margin-bottom: 14px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-brass);
  }
  .pk-card__no {
    font-family: var(--font-display);
    color: var(--color-brass);
    font-size: 32px;
    line-height: 1;
    letter-spacing: 0.04em;
  }
  .pk-card__name {
    font-family: var(--font-billing);
    font-weight: 700;
    color: var(--color-ink);
    font-size: 24px;
    letter-spacing: 0.005em;
    line-height: 1.05;
    margin: 0;
    text-transform: uppercase;
  }
  .pk-card__name--sm { font-size: 17px; text-transform: none; }
  .pk-card__blurb {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--color-ink);
    margin: 0 0 12px;
    flex: 1;
  }
  .pk-card__blurb--sm { font-size: 14px; }
  .pk-card__tone {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-smoke);
    font-size: 13px;
    margin: 0 0 18px;
  }
  .pk-card__cta {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-buddy-red);
    font-size: 12px;
    margin-top: auto;
  }
  .pk-card--mini { padding: 18px 20px; }

  .pk-card--alpha-stub, .pk-card--beta-stub {
    opacity: 0.7;
    background-image:
      repeating-linear-gradient(45deg,
        var(--color-cream) 0 16px,
        rgba(61,42,30,0.05) 16px 17px);
  }

  .pk-foot {
    max-width: 720px;
    margin: 0 auto 64px;
    padding: 32px 32px 0;
    text-align: center;
    border-top: 1.4px solid var(--color-brass);
  }
  .pk-foot p {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-ink);
    margin: 18px 0 0;
    font-size: 16px;
  }
  .pk-foot code {
    font-family: var(--font-label);
    background: rgba(201,162,39,0.18);
    color: var(--color-walnut);
    padding: 1px 6px;
    border: 1px solid var(--color-brass);
    font-size: 13px;
    letter-spacing: 0.1em;
  }
  .pk-foot__legal {
    font-family: var(--font-label) !important;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: var(--color-brass);
    font-style: normal !important;
    font-size: 10px !important;
    margin-top: 18px !important;
  }
  .pk-foot__legal em { color: var(--color-smoke); font-style: italic; }
</style>
