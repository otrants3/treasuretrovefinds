---
import Layout from "../../layouts/Layout.astro";

const BOOTH = {
  name: "Paradise Mall · Booth #18",
  street: "3565 E. Flamingo Road",
  city: "Las Vegas, Nevada 89121",
  phone: "(516) 446-2693",
  phoneHref: "tel:+15164462693",
  hoursLine: "Open daily, 10 'til 6",
  billLine: "Bill works the booth Weds & Sun",
  mapHref:
    "https://www.google.com/maps/search/?api=1&query=3565+E+Flamingo+Road+Las+Vegas+NV+89121",
};

// Items along the walk — each scroll moment surfaces one.
const STOPS = [
  {
    photo: "/photos/case-buddy-l-trucks.jpg",
    era: "1938",
    item: "Buddy L Fire Engine",
    note: "American, pressed steel, East Moline, Illinois. All-original ladders.",
    price: "$285.00",
    pose: "left",
  },
  {
    photo: "/photos/shelves-bottles.jpg",
    era: "1932-1948",
    item: "Embossed Milk-Bottle Lot",
    note: "Six pieces. NY dairies. The bottler wars nobody remembers but us.",
    price: "$95.00",
    pose: "right",
  },
  {
    photo: "/photos/tag-perfume-bottle.jpg",
    era: "1934",
    item: "Ludwig Scherk Renaissance Perfume Bottle",
    note: "w/ Marie Antoinette miniature. Original silvered metalwork.",
    price: "$225.00",
    pose: "left",
  },
  {
    photo: "/photos/tag-race-car.jpg",
    era: "1930-1940s",
    item: "Hobby Kiddie Diecast Race Car",
    note: "Green over silver. Original rubber. #SH-457, all-original.",
    price: "$65.00",
    pose: "right",
  },
  {
    photo: "/photos/fan-perfumes.jpg",
    era: "1930s",
    item: "GE Cast-Iron Oscillating Fan",
    note: "Still works. Brass blade. Ask Bill to plug it in.",
    price: "ask Bill",
    pose: "left",
  },
  {
    photo: "/photos/signage.jpg",
    era: "1942",
    item: "Mobil Gas Porcelain Sign",
    note: "Pegasus crest. Honest wear, no rust-through.",
    price: "$420.00",
    pose: "right",
  },
];
---

<Layout title="Treasure Trove Finds — Walk Into Booth #18">
  <!-- ============================================================
       THE WALK — full-screen, lights come on, you're inside
       ============================================================ -->
  <div class="wi-room">
    <!-- Backdrop: the booth, full-bleed, lights coming up -->
    <div class="wi-stage" aria-hidden="true">
      <img
        class="wi-stage__photo"
        src="/photos/booth-wide.jpg"
        alt=""
        fetchpriority="high"
      />
      <div class="wi-stage__dim"></div>
      <div class="wi-stage__warm"></div>
      <div class="wi-stage__grain"></div>
    </div>

    <!-- Floating quiet UI: brass plaque, phone, always visible -->
    <header class="wi-hud" aria-label="Treasure Trove Finds">
      <a class="wi-hud__brand" href="#top" aria-label="Treasure Trove Finds — back to start">
        <span class="wi-hud__brand-eyebrow">— Booth #18 · Paradise Mall —</span>
        <span class="wi-hud__brand-mark">TREASURE TROVE FINDS</span>
      </a>
      <div class="wi-hud__right">
        <a class="wi-hud__phone" href={BOOTH.phoneHref}>{BOOTH.phone}</a>
        <a class="wi-hud__btn" href="#joint">Drop in</a>
      </div>
    </header>

    <!-- HERO BILLING — fades up after the lights -->
    <section id="top" class="wi-hero">
      <p class="wi-hero__eyebrow">— Tonight at Booth Eighteen —</p>
      <h1 class="wi-hero__headline">Every piece<br/>has a record.</h1>
      <p class="wi-hero__sub">
        Fifty years on the hunt. Half a century of American oddments. <br/>
        Bill &amp; Lisa's back-room of the things that catch your mind.
      </p>
      <p class="wi-hero__cue">scroll down · you're inside <span aria-hidden="true">↓</span></p>
    </section>

    <!-- WALK-IN: a long scrolling track. Each stop reveals an item -->
    <main class="wi-walk">
      {STOPS.map((s, i) => (
        <section class={`wi-stop wi-stop--${s.pose}`} data-stop={i + 1}>
          <figure class="wi-stop__plate">
            <span class="wi-stop__no">Stop No. {String(i + 1).padStart(2, "0")}</span>
            <img src={s.photo} alt={s.item} loading="lazy" />
            <span class="wi-stop__tag">
              <span class="wi-stop__tag-thread"></span>
              <span class="wi-stop__tag-hole"></span>
              <span class="wi-stop__tag-era">{s.era}</span>
              <strong class="wi-stop__tag-item">{s.item}</strong>
              <span class="wi-stop__tag-note">{s.note}</span>
              <span class="wi-stop__tag-price">{s.price.startsWith("$") ? s.price : s.price.toUpperCase()}</span>
            </span>
          </figure>
        </section>
      ))}

      <!-- ORIGIN STOP — the story, mid-walk -->
      <section class="wi-stop wi-stop--story">
        <div class="wi-story">
          <h2 class="wi-story__pull">
            “Bill wasn't collecting antiques. <em>He was collecting the stories behind the numbers.</em>”
          </h2>
          <p>
            Bill caught the bug the way most boys did — a stack of baseball cards. But the
            players weren't the point. The <strong>numbers on the back</strong> were. Years,
            batting averages, stadium names, the history hiding inside the data. He'd
            memorize them. He'd cross-reference. He'd want to know what else was happening
            the year a player hit .357.
          </p>
          <p>
            That curiosity never quit. From cards he moved to bottles, then signs, then
            toys, then anything with a story he hadn't heard yet. Not just antique. Not
            just vintage. <em>Nostalgic</em> — pieces with a hold on the rooms they came
            out of.
          </p>
          <p>
            Lisa came along, made it a life. Walk into Booth&nbsp;#18 and point at anything.
            Bill will not hesitate. He'll tell you the year, the maker, who probably
            bought it first, and what was on the radio that month. <em>This is not your
            sixth-grade Social Studies teacher's lecture.</em>
          </p>
        </div>
      </section>

      <!-- EXIT — Find the Joint -->
      <section id="joint" class="wi-stop wi-stop--exit">
        <div class="wi-exit">
          <p class="wi-label">— On your way out —</p>
          <h2 class="wi-exit__title">Find the Joint</h2>
          <p class="wi-exit__sub">no GPS required, but it helps</p>

          <div class="wi-exit__grid">
            <div class="wi-map">
              <iframe
                title="Map to Paradise Mall, Booth #18"
                src="https://www.google.com/maps?q=3565+E+Flamingo+Road+Las+Vegas+NV&output=embed"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              ></iframe>
            </div>
            <div class="wi-card">
              <p class="wi-label">Booth</p>
              <p class="wi-card__line wi-card__line--bold">{BOOTH.name.toUpperCase()}</p>
              <p class="wi-card__line">{BOOTH.street}</p>
              <p class="wi-card__line">{BOOTH.city}</p>
              <div class="wi-card__divider"></div>
              <p class="wi-label">Hours</p>
              <p class="wi-card__line">{BOOTH.hoursLine}</p>
              <p class="wi-card__line wi-card__line--italic">{BOOTH.billLine}</p>
              <div class="wi-card__divider"></div>
              <p class="wi-label">Ring Bill Up</p>
              <p class="wi-card__phone">{BOOTH.phone}</p>
              <div class="wi-card__buttons">
                <a class="wi-btn wi-btn--primary" href={BOOTH.mapHref} target="_blank" rel="noopener">Get Directions</a>
                <a class="wi-btn wi-btn--secondary" href={BOOTH.phoneHref}>Call Bill</a>
              </div>
            </div>
          </div>

          <p class="wi-exit__sign">
            Est. 2022 · Collecting since 1973 · <em>Pieces back to 1850.</em><br/>
            Bill knows everybody. <em>Ask no questions.</em>
          </p>
          <p class="wi-exit__labs">An Otranto Labs project</p>
        </div>
      </section>
    </main>
  </div>

  <script is:inline>
    (function () {
      // Mouse-parallax: shift the backdrop slightly with the cursor.
      const stage = document.querySelector('.wi-stage');
      if (stage && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let ticking = false;
        let tx = 0, ty = 0;
        document.addEventListener('mousemove', function (e) {
          tx = (e.clientX / window.innerWidth - 0.5) * 14;
          ty = (e.clientY / window.innerHeight - 0.5) * 8;
          if (!ticking) {
            window.requestAnimationFrame(function () {
              stage.style.setProperty('--tx', tx + 'px');
              stage.style.setProperty('--ty', ty + 'px');
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }

      // IntersectionObserver: reveal each stop as it enters.
      const stops = document.querySelectorAll('.wi-stop');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('wi-stop--in');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.25 });
        stops.forEach(function (s) { io.observe(s); });
      } else {
        stops.forEach(function (s) { s.classList.add('wi-stop--in'); });
      }
    })();
  </script>
</Layout>

<style is:global>
  /* The Walk-In is a closed cinematic environment — clear the global cream
     paper texture for this concept so the stage takes over. */
  body { background: #0d0807; background-image: none; }
</style>

<style>
  /* ============================================================
     THE ROOM — a closed cinematic environment.
     ============================================================ */
  .wi-room {
    position: relative;
    color: var(--color-cream);
    font-family: var(--font-serif);
    background: #0d0807;
    overflow-x: hidden;
  }

  /* Fixed cinematic backdrop */
  .wi-stage {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    transform: translate3d(var(--tx, 0px), var(--ty, 0px), 0) scale(1.06);
    transition: transform 700ms ease-out;
    will-change: transform;
  }
  .wi-stage__photo {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: center 40%;
    filter: saturate(0.85) sepia(0.10) contrast(1.05);
  }
  /* dim layer — fades from heavy to soft (lights coming on) */
  .wi-stage__dim {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 100%),
      linear-gradient(180deg, rgba(13,8,7,0.85) 0%, rgba(13,8,7,0.25) 30%, rgba(13,8,7,0.45) 70%, rgba(13,8,7,0.9) 100%);
    animation: wi-lights-up 2200ms cubic-bezier(0.2, 0.6, 0.2, 1) forwards;
  }
  @keyframes wi-lights-up {
    0% {
      background:
        radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.95) 100%),
        linear-gradient(180deg, rgba(0,0,0,1), rgba(0,0,0,0.9));
      opacity: 1;
    }
    60% {
      background:
        radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0.2) 30%, rgba(0,0,0,0.75) 100%),
        linear-gradient(180deg, rgba(13,8,7,0.85) 0%, rgba(13,8,7,0.25) 30%, rgba(13,8,7,0.45) 70%, rgba(13,8,7,0.9) 100%);
      opacity: 1;
    }
    100% {
      background:
        radial-gradient(ellipse at 50% 50%, rgba(0,0,0,0) 30%, rgba(0,0,0,0.55) 100%),
        linear-gradient(180deg, rgba(13,8,7,0.85) 0%, rgba(13,8,7,0.25) 30%, rgba(13,8,7,0.45) 70%, rgba(13,8,7,0.9) 100%);
      opacity: 1;
    }
  }
  /* warm key-light pool — slight pulse */
  .wi-stage__warm {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 35%, rgba(201,162,39,0.18) 0%, transparent 60%);
    mix-blend-mode: screen;
    animation: wi-flicker 5400ms ease-in-out infinite;
  }
  @keyframes wi-flicker {
    0%, 100% { opacity: 0.95; }
    47% { opacity: 0.78; }
    50% { opacity: 1; }
    53% { opacity: 0.85; }
  }
  /* faint film grain */
  .wi-stage__grain {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1.4px),
      radial-gradient(rgba(0,0,0,0.4) 1px, transparent 1.6px);
    background-size: 3px 3px, 7px 7px;
    background-position: 0 0, 1px 1px;
    mix-blend-mode: overlay;
    opacity: 0.5;
    pointer-events: none;
  }

  /* ============================================================
     HUD — top brass plaque + phone + CTA, always visible
     ============================================================ */
  .wi-hud {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 28px;
    background: linear-gradient(180deg, rgba(13,8,7,0.85) 0%, rgba(13,8,7,0) 100%);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .wi-hud__brand {
    color: var(--color-cream);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .wi-hud__brand-eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 9px;
    margin-bottom: 4px;
  }
  .wi-hud__brand-mark {
    font-family: var(--font-display);
    color: var(--color-cream);
    font-size: 22px;
    letter-spacing: 0.04em;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.4);
  }
  .wi-hud__right {
    display: flex; align-items: center; gap: 18px;
  }
  .wi-hud__phone {
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 20px;
    text-decoration: none;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
    letter-spacing: 0.02em;
  }
  .wi-hud__btn {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 11px;
    padding: 10px 16px;
    background: var(--color-buddy-red);
    color: var(--color-cream);
    text-decoration: none;
    border: 1.5px solid var(--color-walnut);
    box-shadow: 3px 3px 0 rgba(0,0,0,0.5);
    position: relative;
  }
  .wi-hud__btn::before {
    content: "";
    position: absolute; top: 4px; bottom: 4px; left: 4px; right: 4px;
    border: 1px solid rgba(242,232,208,0.5);
    pointer-events: none;
  }
  @media (max-width: 640px) {
    .wi-hud__phone { display: none; }
    .wi-hud { padding: 10px 16px; }
    .wi-hud__brand-mark { font-size: 18px; }
  }

  /* ============================================================
     HERO BILLING
     ============================================================ */
  .wi-hero {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 24px;
    color: var(--color-cream);
    animation: wi-hero-in 1800ms cubic-bezier(0.2, 0.6, 0.2, 1) both;
    animation-delay: 1100ms;
  }
  @keyframes wi-hero-in {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .wi-hero__eyebrow {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.36em;
    color: var(--color-brass);
    font-size: 12px;
    margin: 0 0 28px;
  }
  .wi-hero__headline {
    font-family: var(--font-display);
    color: var(--color-cream);
    font-size: clamp(56px, 10vw, 144px);
    line-height: 0.9;
    letter-spacing: 0.005em;
    margin: 0;
    text-shadow:
      3px 3px 0 rgba(0,0,0,0.6),
      0 0 60px rgba(201,162,39,0.15);
    transform: rotate(-0.5deg);
    text-transform: uppercase;
  }
  .wi-hero__sub {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-cream);
    font-size: clamp(17px, 1.8vw, 22px);
    margin: 28px auto 36px;
    max-width: 42rem;
    line-height: 1.5;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.5);
  }
  .wi-hero__cue {
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-brass);
    font-size: 11px;
    margin: 0;
    animation: wi-cue 2.4s ease-in-out infinite;
  }
  @keyframes wi-cue {
    0%, 100% { opacity: 0.6; transform: translateY(0); }
    50% { opacity: 1; transform: translateY(4px); }
  }

  /* ============================================================
     THE WALK — long scrolling track of stops
     ============================================================ */
  .wi-walk {
    position: relative;
    z-index: 2;
  }
  .wi-stop {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 12vh 6vw;
    position: relative;
    opacity: 0;
    transform: translateY(36px);
    transition: opacity 900ms ease-out, transform 900ms ease-out;
  }
  .wi-stop--in {
    opacity: 1;
    transform: translateY(0);
  }
  .wi-stop--left { justify-content: flex-start; }
  .wi-stop--right { justify-content: flex-end; }
  .wi-stop--story, .wi-stop--exit { justify-content: center; }

  /* Photo plate — framed by brass, with a paper tag pinned beside it */
  .wi-stop__plate {
    position: relative;
    width: min(560px, 92vw);
    background:
      linear-gradient(135deg, #4a2f1f 0%, #3D2A1E 60%, #2a1c12 100%);
    padding: 14px;
    box-shadow:
      inset 0 0 0 1.5px rgba(201,162,39,0.5),
      inset 0 0 0 4px var(--color-walnut),
      inset 0 0 30px rgba(0,0,0,0.5),
      0 14px 30px rgba(0,0,0,0.6);
    margin: 0;
    transform: rotate(-0.6deg);
  }
  .wi-stop--right .wi-stop__plate { transform: rotate(0.5deg); }
  .wi-stop__no {
    position: absolute;
    top: -14px; left: 16px;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    background: var(--color-brass);
    color: var(--color-walnut);
    padding: 4px 12px;
    font-size: 10px;
    box-shadow: 0 2px 0 rgba(0,0,0,0.5);
  }
  .wi-stop__plate img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.04) brightness(1.02);
    border: 1px solid rgba(0,0,0,0.6);
    display: block;
  }

  /* Paper tag pinned to a corner */
  .wi-stop__tag {
    position: absolute;
    background: var(--color-tag-paper);
    background-image: radial-gradient(rgba(61,42,30,0.08) 1px, transparent 1px);
    background-size: 4px 4px;
    color: var(--color-ink);
    border: 1px solid rgba(61,42,30,0.4);
    padding: 22px 16px 14px;
    width: 240px;
    font-family: var(--font-hand);
    line-height: 1.3;
    box-shadow: 4px 6px 0 rgba(0,0,0,0.55);
    transform: rotate(-4deg);
    transition: transform 240ms cubic-bezier(0.3, 0.8, 0.4, 1);
    bottom: -38px;
    right: -28px;
  }
  .wi-stop--right .wi-stop__tag {
    right: auto;
    left: -28px;
    transform: rotate(3deg);
    bottom: -38px;
  }
  .wi-stop__plate:hover .wi-stop__tag {
    transform: rotate(0deg) translateY(-4px) scale(1.05);
    box-shadow: 5px 8px 0 rgba(0,0,0,0.65);
  }
  .wi-stop__tag-thread {
    position: absolute;
    top: -22px; left: 50%;
    transform: translateX(-50%) rotate(2deg);
    width: 1.5px; height: 28px;
    background: var(--color-brass);
  }
  .wi-stop__tag-hole {
    position: absolute;
    top: 8px; left: 50%;
    transform: translateX(-50%);
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--color-cream);
    box-shadow: inset 0 0 0 1px rgba(61,42,30,0.6);
  }
  .wi-stop__tag-era {
    display: block;
    font-size: 12px;
    color: var(--color-walnut);
    margin-top: 4px;
  }
  .wi-stop__tag-item {
    display: block;
    font-size: 16px;
    color: var(--color-ink);
    font-weight: 400;
    line-height: 1.15;
    margin: 2px 0 4px;
  }
  .wi-stop__tag-note {
    display: block;
    font-size: 13px;
    color: var(--color-walnut);
    margin-bottom: 4px;
  }
  .wi-stop__tag-price {
    display: block;
    font-family: var(--font-display);
    color: var(--color-buddy-red);
    font-size: 22px;
    letter-spacing: 0.02em;
    text-shadow: 1px 1px 0 rgba(26,22,20,0.18);
  }

  /* Story stop */
  .wi-story {
    max-width: 720px;
    background: var(--color-cream);
    background-image: radial-gradient(rgba(61,42,30,0.06) 1px, transparent 1.4px);
    background-size: 4px 4px;
    color: var(--color-ink);
    padding: 56px 56px 48px;
    border: 1.5px solid var(--color-walnut);
    box-shadow:
      0 0 0 5px var(--color-cream),
      0 0 0 6px var(--color-brass),
      0 12px 30px rgba(0,0,0,0.6);
    position: relative;
  }
  .wi-story::before, .wi-story::after {
    content: "✦";
    position: absolute;
    color: var(--color-brass);
    font-size: 18px;
  }
  .wi-story::before { top: 12px; left: 14px; }
  .wi-story::after  { bottom: 12px; right: 14px; }
  .wi-story__pull {
    font-family: var(--font-billing);
    font-style: italic;
    color: var(--color-buddy-red);
    font-size: clamp(22px, 2.6vw, 32px);
    line-height: 1.3;
    margin: 0 0 1.5rem;
    border-left: 3px solid var(--color-brass);
    padding-left: 1.25rem;
  }
  .wi-story__pull em { color: var(--color-walnut); }
  .wi-story p {
    font-family: var(--font-serif);
    font-size: 18px;
    line-height: 1.7;
    margin: 0 0 1rem;
    color: var(--color-ink);
  }
